# WebAuthn Configuration
WEBAUTHN_RP_NAME=Emerald Pearl Events
WEBAUTHN_RP_ID=emeraldpearlandevents.com
WEBAUTHN_ORIGIN=https://portal.emeraldpearlandevents.com

# Server Configuration
PORT_ADMIN=3000
PORT_STAFF=3001
NODE_ENV=production

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/emerald_production

# JWT Secrets - Must all be different unique values minimum 64 characters
JWT_SECRET=
STAFF_JWT_SECRET=
CLIENT_JWT_SECRET=
SSO_JWT_SECRET=

# Client Portal
CLIENT_JWT_EXPIRY=15m
CLIENT_REFRESH_EXPIRY=30d
CLIENT_PORTAL_URL=https://portal.emeraldpearlandevents.com

# Admin Portal
BASE_URL_ADMIN=https://admin.emeraldpearlandevents.com
BASE_URL_STAFF=https://staff.emeraldpearlandevents.com

# M-Pesa Daraja B2C - MUST use standardized names
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_ENVIRONMENT=production
MPESA_B2C_SHORT_CODE=
MPESA_B2C_INITIATOR_NAME=
MPESA_B2C_SECURITY_CREDENTIAL=
MPESA_B2C_QUEUE_TIMEOUT_URL=https://your_render_url.onrender.com/portal/admin-staff/mpesa/timeout
MPESA_B2C_RESULT_URL=https://your_render_url.onrender.com/portal/admin-staff/mpesa/callback

# Email
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@emeraldpearlandevents.com

# Cloudinary
CLOUDINARY_URL=

# Security
ALLOWED_ORIGINS=https://emeraldpearlandevents.netlify.app,https://portal.emeraldpearlandevents.com
EMERGENCY_THRESHOLD=10000
SOCKET_AUTH_REQUIRED=true

# Internal sync secret between port 3000 and 3001
SYNC_SECRET=7aa57bc1e3457bc2f5efb0fe9863ef63ad3ca92cf80fe79b4161712a2e4a167306e5e8be74f4e2272a6c5af4512097ed30a967d8a0889baa8e9f0597723e4483
