<!-- ══ Settings ══ -->
<div class="flex items-center justify-between mb-6 animate-fade-up">
    <div>
        <h1 class="font-display text-2xl font-extrabold text-tx-1 tracking-tight flex items-center gap-3">
            <i class="fa-solid fa-sliders text-blue-400"></i>
            <span>Settings</span>
        </h1>
        <p class="text-[0.7rem] text-tx-3 mt-1 uppercase tracking-widest">Account Configuration</p>
    </div>
</div>

<!-- ══ Profile Section ══ -->
<div class="glass-card mb-4 animate-fade-up delay-1">
    <div class="px-5 py-4 border-b border-white/5 flex items-center gap-2">
        <i class="fa-solid fa-user-pen text-blue-400 text-sm"></i>
        <h3 class="text-sm font-bold text-tx-1 uppercase tracking-widest">Profile Information</h3>
    </div>
    <div class="p-5">
        <form id="profileForm" onsubmit="updateProfile(event)" class="space-y-4">
            <div>
                <label class="block text-[0.65rem] font-bold uppercase tracking-widest text-tx-3 mb-2">Full Name</label>
                <input type="text" id="profileName" value="<%= user.name %>" required
                    class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-sm text-tx-1 placeholder-tx-3/50 focus:border-blue-500/50 focus:ring-0 focus:outline-none transition-colors">
            </div>
            <div>
                <label class="block text-[0.65rem] font-bold uppercase tracking-widest text-tx-3 mb-2">Email Address</label>
                <input type="email" value="<%= user.email %>" disabled
                    class="w-full bg-black/20 border border-white/5 rounded-xl px-4 py-3 text-sm text-tx-3 cursor-not-allowed opacity-60">
                <p class="text-[0.6rem] text-tx-3 mt-1.5 font-mono opacity-70">Contact an administrator to change email.</p>
            </div>
            <div>
                <label class="block text-[0.65rem] font-bold uppercase tracking-widest text-tx-3 mb-2">Phone Number</label>
                <input type="tel" id="profilePhone" value="<%= user.phone || '' %>" placeholder="e.g. +254 700 000 000"
                    class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-sm text-tx-1 placeholder-tx-3/50 focus:border-blue-500/50 focus:ring-0 focus:outline-none transition-colors">
            </div>
            <button type="submit" class="btn btn-primary bg-gradient-to-r from-blue-600 to-blue-400 border-none text-white font-bold shadow-[0_0_20px_rgba(59,130,246,0.2)]">
                <i class="fa-solid fa-floppy-disk mr-2"></i> Update Profile
            </button>
        </form>
    </div>
</div>

<!-- ══ Security Section ══ -->
<div class="glass-card mb-[80px] animate-fade-up delay-2">
    <div class="px-5 py-4 border-b border-white/5 flex items-center gap-2">
        <i class="fa-solid fa-lock text-gold-400 text-sm"></i>
        <h3 class="text-sm font-bold text-tx-1 uppercase tracking-widest">Security & Password</h3>
    </div>
    <div class="p-5">
        <% if (user.mustChangePassword) { %>
            <div class="bg-gold-500/10 border border-gold-500/40 rounded-xl px-4 py-3 mb-4 flex items-start gap-3">
                <i class="fa-solid fa-triangle-exclamation text-gold-400 mt-0.5"></i>
                <div>
                    <div class="text-[0.65rem] font-bold text-gold-400 uppercase tracking-wider mb-0.5">Security Notice</div>
                    <p class="text-xs text-tx-2">You must change your default password before accessing all features.</p>
                </div>
            </div>
        <% } %>
        
        <form id="passwordForm" onsubmit="requestPasswordChangeOTP(event)" class="space-y-4">
            <div>
                <label class="block text-[0.65rem] font-bold uppercase tracking-widest text-tx-3 mb-2">Current Password</label>
                <input type="password" id="currentPassword" required
                    class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-sm text-tx-1 placeholder-tx-3/50 focus:border-gold-500/50 focus:ring-0 focus:outline-none transition-colors">
            </div>
            <div>
                <label class="block text-[0.65rem] font-bold uppercase tracking-widest text-tx-3 mb-2">New Password</label>
                <input type="password" id="newPassword" required minlength="8"
                    class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-sm text-tx-1 placeholder-tx-3/50 focus:border-gold-500/50 focus:ring-0 focus:outline-none transition-colors">
            </div>
            <div>
                <label class="block text-[0.65rem] font-bold uppercase tracking-widest text-tx-3 mb-2">Confirm New Password</label>
                <input type="password" id="confirmPassword" required minlength="8"
                    class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-sm text-tx-1 placeholder-tx-3/50 focus:border-gold-500/50 focus:ring-0 focus:outline-none transition-colors">
            </div>
            <button type="submit" id="sendOtpBtn" class="btn btn-primary bg-gradient-to-r from-gold-600 to-gold-400 border-none text-dark-bg font-bold shadow-[0_0_20px_rgba(245,158,11,0.2)]">
                <i class="fa-solid fa-paper-plane mr-2"></i> Send OTP
            </button>
        </form>
    </div>
</div>

<!-- OTP Verification Modal -->
<div id="otpModal" class="fixed inset-0 z-[10000] hidden items-center justify-center bg-black/60 backdrop-blur-sm opacity-0 transition-opacity duration-300">
    <div class="glass-strong border border-gold-500/30 rounded-2xl w-[90%] max-w-[420px] p-6 text-center scale-90 transition-transform duration-300 shadow-2xl" id="otpModalContent">
        <div class="mb-4">
            <div class="w-12 h-12 rounded-full bg-gold-500/10 text-gold-400 flex items-center justify-center text-xl mx-auto mb-3">
                <i class="fa-solid fa-key"></i>
            </div>
            <h3 class="font-display text-lg font-extrabold text-tx-1">Enter Verification Code</h3>
            <p class="text-xs text-tx-2 mt-2 leading-relaxed">We've sent a 6-digit OTP code to your email to verify this password change request.</p>
        </div>
        <div id="otpModalErrorMessage" class="hidden text-xs font-semibold text-red-400 bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3 mb-4"></div>
        <div class="flex justify-between gap-2 my-6">
            <input type="text" class="otp-input-field w-12 h-12 bg-black/40 border border-white/10 rounded-xl text-lg font-bold text-center text-tx-1 focus:border-gold-500/50 focus:outline-none transition-all" maxlength="1" pattern="[0-9]" inputmode="numeric" required>
            <input type="text" class="otp-input-field w-12 h-12 bg-black/40 border border-white/10 rounded-xl text-lg font-bold text-center text-tx-1 focus:border-gold-500/50 focus:outline-none transition-all" maxlength="1" pattern="[0-9]" inputmode="numeric" required>
            <input type="text" class="otp-input-field w-12 h-12 bg-black/40 border border-white/10 rounded-xl text-lg font-bold text-center text-tx-1 focus:border-gold-500/50 focus:outline-none transition-all" maxlength="1" pattern="[0-9]" inputmode="numeric" required>
            <input type="text" class="otp-input-field w-12 h-12 bg-black/40 border border-white/10 rounded-xl text-lg font-bold text-center text-tx-1 focus:border-gold-500/50 focus:outline-none transition-all" maxlength="1" pattern="[0-9]" inputmode="numeric" required>
            <input type="text" class="otp-input-field w-12 h-12 bg-black/40 border border-white/10 rounded-xl text-lg font-bold text-center text-tx-1 focus:border-gold-500/50 focus:outline-none transition-all" maxlength="1" pattern="[0-9]" inputmode="numeric" required>
            <input type="text" class="otp-input-field w-12 h-12 bg-black/40 border border-white/10 rounded-xl text-lg font-bold text-center text-tx-1 focus:border-gold-500/50 focus:outline-none transition-all" maxlength="1" pattern="[0-9]" inputmode="numeric" required>
        </div>
        <div class="flex gap-3">
            <button type="button" onclick="closeOtpModal()" class="flex-1 py-3 border border-white/10 rounded-xl text-xs font-bold text-tx-2 hover:bg-white/5 transition-colors">Cancel</button>
            <button type="button" onclick="submitOtpAndChangePassword()" id="otpSubmitBtn" class="flex-1 py-3 bg-gradient-to-r from-gold-600 to-gold-400 text-dark-bg rounded-xl text-xs font-bold shadow-[0_0_20px_rgba(245,158,11,0.2)]">Verify & Change</button>
        </div>
    </div>
</div>

<script>
    const _portalBase = '/portal/<%= user.role === "Admin" ? "admin-staff" : (user.role === "Supervisor" ? "supervisor" : "staff") %>';
    
    function updateProfile(e) {
        e.preventDefault();
        const name = document.getElementById('profileName').value;
        const phone = document.getElementById('profilePhone').value;

        fetch(_portalBase + '/profile', {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
                'CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
            },
            credentials: 'include',
            body: JSON.stringify({ name, phone })
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) showToast('Profile updated!', 'success');
            else showToast('Error: ' + data.error, 'error');
        })
        .catch(() => showToast('An error occurred.', 'error'));
    }

    async function requestPasswordChangeOTP(e) {
        e.preventDefault();
        const currentPassword = document.getElementById('currentPassword').value.trim();
        const newPassword = document.getElementById('newPassword').value.trim();
        const confirmPassword = document.getElementById('confirmPassword').value.trim();
        const btn = document.getElementById('sendOtpBtn');

        if (newPassword !== confirmPassword) { showToast('Passwords do not match.', 'error'); return; }
        if (currentPassword === newPassword) { showToast('New password must be different from current password.', 'error'); return; }

        try {
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> Sending...';

            const response = await fetch('/api/auth/password/request-otp', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json',
                    'CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
                },
                credentials: 'include',
                body: JSON.stringify({ currentPassword, newPassword })
            });

            const data = await response.json();

            if (!response.ok || !data.success) {
                showToast(data.message || 'Failed to send OTP code.', 'error');
                return;
            }

            openOtpModal();
        } catch (error) {
            showToast('Network error. Please try again.', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-paper-plane mr-2"></i> Send OTP';
        }
    }

    function openOtpModal() {
        const modal = document.getElementById('otpModal');
        const content = document.getElementById('otpModalContent');
        modal.style.display = 'flex';
        setTimeout(() => {
            modal.classList.remove('opacity-0');
            content.classList.remove('scale-90');
        }, 10);
        
        const firstInput = document.querySelector('.otp-input-field');
        if (firstInput) {
            firstInput.focus();
        }

        document.querySelectorAll('.otp-input-field').forEach(inp => inp.value = '');
        document.getElementById('otpModalErrorMessage').classList.add('hidden');
    }

    function closeOtpModal() {
        const modal = document.getElementById('otpModal');
        const content = document.getElementById('otpModalContent');
        modal.classList.add('opacity-0');
        content.classList.add('scale-90');
        setTimeout(() => modal.style.display = 'none', 300);
    }

    async function submitOtpAndChangePassword() {
        const currentPassword = document.getElementById('currentPassword').value.trim();
        const newPassword = document.getElementById('newPassword').value.trim();
        const modalErrorMsg = document.getElementById('otpModalErrorMessage');
        const submitBtn = document.getElementById('otpSubmitBtn');

        modalErrorMsg.classList.add('hidden');

        const otpFields = document.querySelectorAll('.otp-input-field');
        const otp = Array.from(otpFields).map(inp => inp.value).join('');

        if (otp.length < 6) {
            modalErrorMsg.textContent = '❌ Please enter the full 6-digit code';
            modalErrorMsg.classList.remove('hidden');
            return;
        }

        try {
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> Verifying...';

            const response = await fetch('/api/auth/password/verify-and-change', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json',
                    'CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
                },
                credentials: 'include',
                body: JSON.stringify({ currentPassword, newPassword, otp })
            });

            const data = await response.json();

            if (!response.ok || !data.success) {
                modalErrorMsg.textContent = '❌ ' + (data.message || 'Verification failed');
                modalErrorMsg.classList.remove('hidden');
                return;
            }

            closeOtpModal();
            showToast(data.message || 'Password changed successfully!', 'success');

            // Reset form
            document.getElementById('currentPassword').value = '';
            document.getElementById('newPassword').value = '';
            document.getElementById('confirmPassword').value = '';

            setTimeout(() => {
                window.location.href = _portalBase + '/dashboard';
            }, 1500);

        } catch (error) {
            modalErrorMsg.textContent = '❌ Network error. Please try again.';
            modalErrorMsg.classList.remove('hidden');
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = 'Verify & Change';
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        const otpInputs = document.querySelectorAll('.otp-input-field');
        otpInputs.forEach((input, index) => {
            input.addEventListener('input', (e) => {
                const val = e.target.value;
                e.target.value = val.replace(/[^0-9]/g, '');
                if (e.target.value && index < otpInputs.length - 1) {
                    otpInputs[index + 1].focus();
                }
            });

            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && !e.target.value && index > 0) {
                    otpInputs[index - 1].focus();
                }
            });
        });
    });
</script>