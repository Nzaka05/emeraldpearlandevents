<% currentPage='payments' ; %>

<!-- ══ Header ══ -->
<div class="flex items-center justify-between mb-6 animate-fade-up">
    <div>
        <h1 class="font-display text-2xl font-extrabold text-tx-1 tracking-tight flex items-center gap-3">
            <i class="fa-solid fa-wallet text-emerald-400"></i>
            <span class="text-gradient-emerald">My Payments</span>
        </h1>
        <p class="text-[0.7rem] text-tx-3 mt-1 uppercase tracking-widest font-mono">All amounts in Kenyan Shillings (KSh)</p>
    </div>
</div>

<!-- ══ Disputed Alert Banner ══ -->
<% if (stats.disputed > 0) { %>
    <div class="bg-red-500/10 border border-red-500/40 rounded-xl px-4 py-3 mb-5 flex items-center gap-3 animate-fade-up shadow-[0_0_20px_rgba(239,68,68,0.1)]">
        <div class="w-8 h-8 rounded-lg bg-red-500/20 flex items-center justify-center text-red-400 flex-shrink-0 border border-red-500/30">
            <i class="fa-solid fa-triangle-exclamation text-sm"></i>
        </div>
        <div>
            <div class="text-[0.65rem] font-bold uppercase tracking-widest text-red-400 mb-0.5">System Alert</div>
            <p class="text-xs text-tx-2"><%= stats.disputed %> disputed payment(s) submitted. Admin review in progress.</p>
        </div>
    </div>
<% } %>

<!-- ══ Stats Grid ══ -->
<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6 animate-fade-up delay-1">
    <div class="glass-card p-4 text-center border-t border-gold-500/30">
        <div class="text-[0.6rem] text-tx-3 uppercase tracking-wider font-bold mb-2">Pending</div>
        <div class="font-display text-2xl font-extrabold text-gold-400"><%= stats.pending %></div>
    </div>
    <div class="glass-card p-4 text-center border-t border-blue-500/30">
        <div class="text-[0.6rem] text-tx-3 uppercase tracking-wider font-bold mb-2">Sent</div>
        <div class="font-display text-2xl font-extrabold text-blue-400"><%= stats.sent %></div>
    </div>
    <div class="glass-card p-4 text-center border-t border-emerald-500/30">
        <div class="text-[0.6rem] text-tx-3 uppercase tracking-wider font-bold mb-2">Received</div>
        <div class="font-display text-2xl font-extrabold text-emerald-400"><%= stats.received %></div>
    </div>
    <div class="glass-card p-4 text-center border-t border-white/10 col-span-2 sm:col-span-1">
        <div class="text-[0.6rem] text-tx-3 uppercase tracking-wider font-bold mb-2">Total Yield</div>
        <div class="font-mono text-base font-extrabold text-tx-1 leading-tight">KSh <span class="text-emerald-400"><%= stats.total.toLocaleString() %></span></div>
    </div>
</div>

<!-- ══ Payment Cards ══ -->
<div class="space-y-4 mb-[80px] animate-fade-up delay-2">
    <% assignments.forEach(function(a) { 
        var ps = a.my_payment_status || a.payment_status || 'Pending';
        var statusColor = ps === 'Received' ? 'text-emerald-400 bg-emerald-500/10 border-emerald-500/30' : ps === 'Sent' ? 'text-blue-400 bg-blue-500/10 border-blue-500/30' : ps === 'Disputed' ? 'text-red-400 bg-red-500/10 border-red-500/30' : 'text-gold-400 bg-gold-500/10 border-gold-500/30';
        var accentColor = ps === 'Received' ? 'border-l-emerald-500' : ps === 'Sent' ? 'border-l-blue-500' : ps === 'Disputed' ? 'border-l-red-500' : 'border-l-gold-500';
    %>
        <div class="glass-card border-l-2 <%= accentColor %> hover:bg-white/[0.03] transition-colors">
            <!-- Card Top -->
            <div class="p-4 pb-3 border-b border-white/5">
                <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <h3 class="font-bold text-sm text-tx-1 truncate mb-1"><%= a.title %></h3>
                        <div class="flex items-center gap-3 text-[0.65rem] text-tx-3 font-mono">
                            <span><i class="fa-regular fa-calendar-check mr-1 opacity-60"></i> <%= new Date(a.date).toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'}) %></span>
                            <% if(a.location) { %><span class="hidden sm:inline"><i class="fa-solid fa-location-dot mr-1 opacity-60"></i><%= a.location %></span><% } %>
                        </div>
                    </div>
                    <div class="shrink-0 flex flex-col items-end gap-1">
                        <span class="text-[0.55rem] font-bold tracking-widest uppercase border rounded px-1.5 py-0.5 <%= statusColor %>"><%= ps %></span>
                        <% if(a.vip_flag) { %><span class="badge-gold text-[0.5rem] font-bold px-1.5 py-0.5 rounded tracking-widest uppercase"><i class="fa-solid fa-star mr-0.5 text-[0.45rem]"></i> VIP</span><% } %>
                    </div>
                </div>
            </div>

            <!-- Card Body: Pay Details -->
            <div class="p-4 flex items-center justify-between">
                <div class="flex items-center gap-6">
                    <% if(a.start_time) { %>
                    <div>
                        <div class="text-[0.55rem] text-tx-3 uppercase tracking-widest font-bold mb-0.5">Window</div>
                        <div class="text-xs text-tx-2 font-mono"><%= a.start_time %> – <%= a.end_time||'TBD' %></div>
                    </div>
                    <% } %>
                    <div>
                        <div class="text-[0.55rem] text-tx-3 uppercase tracking-widest font-bold mb-0.5">Event Pay</div>
                        <div class="font-mono font-extrabold text-base text-emerald-400">KSh <%= (a.pay_rate||0).toLocaleString() %></div>
                    </div>
                </div>
                
                <!-- Action Buttons -->
                <div class="flex gap-2 shrink-0">
                    <% if (ps === 'Sent') { %>
                        <button class="btn btn-primary btn-sm py-1.5 px-3 text-[0.65rem] font-bold bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 hover:bg-emerald-500 hover:text-dark-bg shadow-none" onclick="confirmReceipt('<%= a._id %>')">
                            <i class="fa-solid fa-circle-check mr-1"></i> Confirm
                        </button>
                        <button class="btn btn-outline btn-sm py-1.5 px-3 text-[0.65rem] font-bold border-red-500/30 text-red-400 hover:bg-red-500/20" onclick="openDisputeModal('<%= a._id %>','<%= a.title %>')">
                            <i class="fa-solid fa-flag mr-1"></i> Dispute
                        </button>
                    <% } else if (ps === 'Received') { %>
                        <a href="/portal/staff/payments/<%= a._id %>/receipt" target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm py-1.5 px-3 text-[0.65rem] font-bold border-emerald-500/20 text-emerald-400 hover:bg-emerald-500/10 flex items-center">
                            <i class="fa-solid fa-file-arrow-down mr-1.5"></i> Receipt
                        </a>
                    <% } else if (ps === 'Disputed' && a.payment_disputed_reason) { %>
                        <div class="text-[0.65rem] text-red-400/70 font-mono bg-red-500/5 border border-red-500/20 p-2 rounded text-right max-w-[180px] truncate">
                            <i class="fa-solid fa-circle-info mr-1 opacity-70"></i><%= a.payment_disputed_reason %>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    <% }); %>
    
    <% if (assignments.length === 0) { %>
        <div class="glass-card p-12 flex flex-col items-center justify-center text-tx-3 opacity-60 text-center">
            <i class="fa-solid fa-money-bill-slash text-4xl mb-4"></i>
            <p class="text-xs font-bold uppercase tracking-wider">No Payment Records Found</p>
        </div>
    <% } %>
</div>

<!-- ══ Dispute Modal ══ -->
<div class="modal-overlay hidden bg-black/80 backdrop-blur-md" id="disputeModal">
    <div class="modal-content max-w-md bg-dark-card border border-red-500/30 rounded-2xl shadow-[0_0_40px_rgba(239,68,68,0.15)]">
        
        <div class="px-5 py-4 border-b border-red-500/20 bg-black/30 flex items-center justify-between">
            <h3 class="text-sm font-bold text-red-400 flex items-center gap-2">
                <i class="fa-solid fa-triangle-exclamation"></i> Lodge Payment Dispute
            </h3>
            <button class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center text-tx-3 hover:text-tx-1 hover:bg-white/5 transition-colors" onclick="closeModal('disputeModal')">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        
        <div class="p-5 space-y-4">
            <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-lg bg-red-500/10 text-red-400 flex items-center justify-center shrink-0 border border-red-500/20">
                    <i class="fa-solid fa-calendar-xmark text-xs"></i>
                </div>
                <div>
                    <div class="text-[0.6rem] text-tx-3 uppercase tracking-widest font-bold mb-0.5">Disputed Event</div>
                    <div class="text-sm font-bold text-tx-1" id="disputeEventTitle">—</div>
                </div>
            </div>
            
            <div>
                <label class="block text-[0.65rem] font-bold uppercase tracking-widest text-tx-3 mb-2">Reason <span class="text-red-400">*</span></label>
                <textarea class="w-full bg-black/40 border border-white/10 rounded-xl p-3 text-sm text-tx-2 placeholder-tx-3/50 focus:border-red-500/40 focus:ring-0 focus:outline-none resize-none font-mono leading-relaxed" id="disputeReason" rows="4" placeholder="Describe the payment discrepancy in detail…"></textarea>
            </div>
            
            <button class="btn btn-primary w-full bg-gradient-to-r from-red-700 to-red-500 text-white border-none shadow-[0_0_20px_rgba(239,68,68,0.2)] font-bold tracking-wider" onclick="submitDispute()">
                <i class="fa-solid fa-flag mr-2"></i> SUBMIT DISPUTE
            </button>
        </div>
    </div>
</div>

<script>
    let activeDisputeId = null;
    
    function openDisputeModal(id, title) {
        activeDisputeId = id;
        document.getElementById('disputeEventTitle').textContent = title;
        document.getElementById('disputeReason').value = '';
        openModal('disputeModal');
    }
    
    async function confirmReceipt(id) {
        if (!confirm('Confirm receipt of payment for this event?')) return;
        showToast('Confirming receipt...', 'info');
        const r = await fetch('/portal/staff/assignments/' + id + '/payment/confirm', { 
            method: 'POST',
            headers: { 'CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '' }
        });
        const d = await r.json();
        if (d.success) { showToast('Payment confirmed!', 'success'); setTimeout(() => location.reload(), 1000); }
        else showToast(d.error || 'Error', 'error');
    }
    
    async function submitDispute() {
        const reason = document.getElementById('disputeReason').value.trim();
        if (!reason) return showToast('Enter a reason for the dispute.', 'error');
        showToast('Logging dispute...', 'info');
        const r = await fetch('/portal/staff/assignments/' + activeDisputeId + '/payment/dispute', {
            method: 'POST', 
            headers: { 
                'Content-Type': 'application/json',
                'CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
            },
            body: JSON.stringify({ reason })
        });
        const d = await r.json();
        if (d.success) { 
            showToast('Dispute logged. Admin will review.', 'success'); 
            closeModal('disputeModal'); 
            setTimeout(() => location.reload(), 1000); 
        } else showToast(d.error || 'Error', 'error');
    }
</script>