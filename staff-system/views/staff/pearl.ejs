<% currentPage = 'pearl' %>
<style>
  /* Hide the default page padding so Pearl fills everything */
  .main-content, main, .pt-\[72px\] { padding: 0 !important; }
  #pearlFloatBtn { display: none !important; }
</style>

<div id="pearlWrap" style="position:fixed;top:56px;left:0;right:0;bottom:0;display:flex;flex-direction:column;background:var(--bg-base, #0a0f1e);z-index:50;">

  <!-- Header -->
  <div style="display:flex;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid rgba(255,255,255,0.07);flex-shrink:0;">
    <div style="width:36px;height:36px;border-radius:50%;overflow:hidden;flex-shrink:0;border:2px solid rgba(5,150,105,0.4);">
      <img src="/images/pearl-logo.png" style="width:100%;height:100%;object-fit:cover;" onerror="this.style.display='none'">
    </div>
    <div>
      <div style="font-weight:700;font-size:0.95rem;color:var(--tx-1,#f1f5f9);">PEARL</div>
      <div style="font-size:0.7rem;color:#10b981;" id="pearlStatus">Personal Emerald Assistant</div>
    </div>
    <button onclick="clearChat()" style="margin-left:auto;font-size:0.72rem;color:var(--tx-3,#64748b);background:none;border:none;cursor:pointer;padding:4px 8px;border-radius:6px;hover:background:rgba(255,255,255,0.05);">Clear</button>
  </div>

  <!-- Messages -->
  <div id="chatMessages" style="flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:12px;">
    <div class="pearl-msg ai" style="display:flex;gap:10px;align-items:flex-start;">
      <div style="width:30px;height:30px;border-radius:50%;overflow:hidden;flex-shrink:0;">
        <img src="/images/pearl-logo.png" style="width:100%;height:100%;object-fit:cover;">
      </div>
      <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:0 14px 14px 14px;padding:10px 14px;max-width:80%;font-size:0.875rem;color:var(--tx-1,#f1f5f9);line-height:1.6;" id="greetMsg">
        Loading...
      </div>
    </div>
  </div>

  <!-- Quick prompts -->
  <div id="quickPrompts" style="padding:8px 16px;display:flex;gap:8px;flex-wrap:wrap;flex-shrink:0;">
    <% if (user && (user.role === 'Admin' || user.role === 'Supervisor')) { %>
    <button onclick="quickAsk('Show me all pending bookings')" style="font-size:0.72rem;padding:5px 12px;border-radius:20px;background:rgba(5,150,105,0.1);border:1px solid rgba(5,150,105,0.3);color:#10b981;cursor:pointer;">Pending bookings</button>
    <button onclick="quickAsk('Give me a business summary')" style="font-size:0.72rem;padding:5px 12px;border-radius:20px;background:rgba(5,150,105,0.1);border:1px solid rgba(5,150,105,0.3);color:#10b981;cursor:pointer;">Business summary</button>
    <button onclick="quickAsk('List all staff contacts')" style="font-size:0.72rem;padding:5px 12px;border-radius:20px;background:rgba(5,150,105,0.1);border:1px solid rgba(5,150,105,0.3);color:#10b981;cursor:pointer;">Staff contacts</button>
    <button onclick="quickAsk('What events are coming up this week?')" style="font-size:0.72rem;padding:5px 12px;border-radius:20px;background:rgba(5,150,105,0.1);border:1px solid rgba(5,150,105,0.3);color:#10b981;cursor:pointer;">Upcoming events</button>
    <% } else { %>
    <button onclick="quickAsk('What are my upcoming assignments?')" style="font-size:0.72rem;padding:5px 12px;border-radius:20px;background:rgba(5,150,105,0.1);border:1px solid rgba(5,150,105,0.3);color:#10b981;cursor:pointer;">My assignments</button>
    <button onclick="quickAsk('What is my attendance record?')" style="font-size:0.72rem;padding:5px 12px;border-radius:20px;background:rgba(5,150,105,0.1);border:1px solid rgba(5,150,105,0.3);color:#10b981;cursor:pointer;">My attendance</button>
    <button onclick="quickAsk('What are my recent payments?')" style="font-size:0.72rem;padding:5px 12px;border-radius:20px;background:rgba(5,150,105,0.1);border:1px solid rgba(5,150,105,0.3);color:#10b981;cursor:pointer;">My payments</button>
    <button onclick="quickAsk('What events are coming up this week?')" style="font-size:0.72rem;padding:5px 12px;border-radius:20px;background:rgba(5,150,105,0.1);border:1px solid rgba(5,150,105,0.3);color:#10b981;cursor:pointer;">Upcoming events</button>
    <% } %>
  </div>

  <!-- Input -->
  <div style="padding:10px 16px 16px;flex-shrink:0;border-top:1px solid rgba(255,255,255,0.06);">
    <div style="display:flex;gap:8px;align-items:center;">
      <input type="text" id="aiInput" placeholder="Ask PEARL anything..."
        style="flex:1;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:24px;padding:10px 16px;font-size:0.875rem;color:var(--tx-1,#f1f5f9);outline:none;transition:border-color 0.2s;"
        onfocus="this.style.borderColor='rgba(5,150,105,0.6)'"
        onblur="this.style.borderColor='rgba(255,255,255,0.1)'"
        onkeypress="if(event.key==='Enter') sendMessage()">
      <button onclick="sendMessage()" id="sendBtn"
        style="width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,#059669,#0d9488);border:none;color:white;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform 0.15s;"
        onmouseover="this.style.transform='scale(1.08)'" onmouseout="this.style.transform='scale(1)'">
        <i class="fa-solid fa-paper-plane" style="font-size:0.8rem;"></i>
      </button>
    </div>
  </div>
</div>

<script>
const csrf = document.querySelector('meta[name="csrf-token"]')?.content || '';
const conversationHistory = [];
function quickAsk(q) { document.getElementById('aiInput').value = q; sendMessage(); }
const userName = '<%= user && user.name ? user.name.split(" ")[0] : "there" %>';
const userRole = '<%= user && user.role ? user.role : "Staff" %>';

// Greeting based on time
const hour = new Date().getHours();
const greet = hour < 12 ? 'Good morning' : hour < 17 ? 'Good afternoon' : 'Good evening';
const greetings = {
  Admin: greet + ', ' + userName + '. What do you need?',
  Supervisor: greet + ', ' + userName + '. How can I help?',
  Staff: greet + ', ' + userName + '. What can I do for you?'
};
document.addEventListener("DOMContentLoaded", function() { document.getElementById("greetMsg").textContent = greetings[userRole] || greetings.Staff; });

function quickAsk(q) {
  document.getElementById('aiInput').value = q;
  sendMessage();
}

function clearChat() {
  const msgs = document.getElementById('chatMessages');
  msgs.innerHTML = '';
  conversationHistory.length = 0;
  addMessage(greetings[userRole] || greetings.Staff, 'ai');
}

async function sendMessage() {
  const input = document.getElementById('aiInput');
  const query = input.value.trim();
  if (!query) return;
  input.value = '';

  // Hide quick prompts after first message
  document.getElementById('quickPrompts').style.display = 'none';

  addMessage(query, 'user');
  const typing = addTyping();
  document.getElementById('sendBtn').disabled = true;
  document.getElementById('pearlStatus').textContent = 'Thinking...';

  try {
    const res = await fetch('/portal/staff/ai/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'csrf-token': csrf, 'x-csrf-token': csrf, 'CSRF-Token': csrf },
      body: JSON.stringify({
        _csrf: csrf,
        query,
        eventContext: { userName: '<%= user && user.name ? user.name : "Staff" %>', role: userRole },
        history: conversationHistory
      })
    });
    const data = await res.json();
    typing.remove();
    // Properly handle error message - convert objects to strings
    let reply;
    if (data.success) {
      reply = data.data?.reply || data.data?.response || 'No response';
    } else {
      const msg = data.message || data.error || 'Something went wrong.';
      reply = typeof msg === 'object' ? JSON.stringify(msg) : msg;
    }
    addMessage(reply, 'ai');
    conversationHistory.push({ query, response: reply });
  } catch (err) {
    typing.remove();
    addMessage('Connection error — please try again.', 'ai');
  } finally {
    document.getElementById('sendBtn').disabled = false;
    document.getElementById('pearlStatus').textContent = 'Personal Emerald Assistant';
  }
}

function addMessage(text, from) {
  const wrap = document.getElementById('chatMessages');
  const div = document.createElement('div');
  div.style.cssText = 'display:flex;gap:10px;align-items:flex-start;' + (from === 'user' ? 'flex-direction:row-reverse;' : '');

  const bubble = document.createElement('div');
  bubble.style.cssText = from === 'user'
    ? 'background:rgba(5,150,105,0.15);border:1px solid rgba(5,150,105,0.25);border-radius:14px 0 14px 14px;padding:10px 14px;max-width:80%;font-size:0.875rem;color:var(--tx-1,#f1f5f9);line-height:1.6;white-space:pre-wrap;'
    : 'background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:0 14px 14px 14px;padding:10px 14px;max-width:80%;font-size:0.875rem;color:var(--tx-1,#f1f5f9);line-height:1.6;white-space:pre-wrap;';
  bubble.innerHTML = text;

  if (from === 'ai') {
    const avatar = document.createElement('div');
    avatar.style.cssText = 'width:30px;height:30px;border-radius:50%;overflow:hidden;flex-shrink:0;';
    avatar.innerHTML = '<img src="/images/pearl-logo.png" style="width:100%;height:100%;object-fit:cover;">';
    div.appendChild(avatar);
  }
  div.appendChild(bubble);
  wrap.appendChild(div);
  wrap.scrollTop = wrap.scrollHeight;
  return div;
}

function addTyping() {
  return addMessage('<span style="opacity:0.5;font-style:italic;font-size:0.8rem;">typing...</span>', 'ai');
}
</script>
