<% currentPage = 'pearl' %>
<div class="max-w-2xl mx-auto">
    <div class="mb-4 flex items-center gap-3">
        <img src="/images/pearl-logo.png" class="w-10 h-10 rounded-xl object-contain">
        <div>
            <h1 class="font-display text-xl font-bold text-tx-1">PEARL</h1>
            <p class="text-xs text-tx-3">Personal Emerald Assistant</p>
        </div>
    </div>
    <div class="glass-card rounded-2xl overflow-hidden" style="height:60vh;display:flex;flex-direction:column;">
        <div id="chatMessages" class="flex-1 overflow-y-auto p-4 space-y-4">
            <div class="flex gap-3">
                <div class="w-8 h-8 rounded-xl overflow-hidden flex-shrink-0">
                    <img src="/images/pearl-logo.png" class="w-full h-full object-contain">
                </div>
                <div class="glass-card rounded-xl rounded-tl-none p-3 max-w-xs">
                    <p class="text-sm text-tx-1">Hello! I am PEARL, your Emerald assistant. How can I help you today?</p>
                </div>
            </div>
        </div>
        <div class="border-t border-white/8 p-3">
            <div class="flex gap-2 px-3 pt-2 pb-1 flex-wrap">
                <button onclick="quickAsk('What are my upcoming assignments?')" class="text-xs px-3 py-1.5 rounded-lg bg-cosmos-600 border border-white/10 text-tx-3 hover:text-tx-1 hover:border-emerald-500 transition-colors">My assignments</button>
                <button onclick="quickAsk('What is my attendance record?')" class="text-xs px-3 py-1.5 rounded-lg bg-cosmos-600 border border-white/10 text-tx-3 hover:text-tx-1 hover:border-emerald-500 transition-colors">My attendance</button>
                <button onclick="quickAsk('What are my recent payments?')" class="text-xs px-3 py-1.5 rounded-lg bg-cosmos-600 border border-white/10 text-tx-3 hover:text-tx-1 hover:border-emerald-500 transition-colors">My payments</button>
                <button onclick="quickAsk('What events are coming up this week?')" class="text-xs px-3 py-1.5 rounded-lg bg-cosmos-600 border border-white/10 text-tx-3 hover:text-tx-1 hover:border-emerald-500 transition-colors">Upcoming events</button>
            </div>
            <div class="flex gap-2 px-3 pb-3">
                <input type="text" id="aiInput" placeholder="Ask PEARL anything..."
                    class="flex-1 form-input rounded-xl bg-cosmos-600 border border-white/10 text-tx-1 px-3 py-2 text-sm focus:outline-none focus:border-emerald-500"
                    onkeypress="if(event.key==='Enter') sendMessage()">
                <button onclick="sendMessage()" class="w-10 h-10 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white flex items-center justify-center transition-colors">
                    <i class="fa-solid fa-paper-plane text-sm"></i>
                </button>
            </div>
        </div>
    </div>
</div>
<script>
const csrf = document.querySelector('meta[name="csrf-token"]')?.content || '';
const conversationHistory = [];
function quickAsk(q) { document.getElementById('aiInput').value = q; sendMessage(); }

async function sendMessage() {
    const input = document.getElementById('aiInput');
    const query = input.value.trim();
    if (!query) return;
    input.value = '';
    addMessage(query, 'user');
    const typing = addTyping();
    try {
        const res = await fetch('/portal/staff/ai/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrf },
            body: JSON.stringify({ query, eventContext: {
                userName: '<%= user && user.name ? user.name : "Staff" %>',
                role: '<%= user && user.role ? user.role : "Staff" %>'
            }, history: conversationHistory })
        });
        const data = await res.json();
        typing.remove();
        const reply = data.success ? (data.data?.reply || data.data?.response) : (data.message || 'Error');
        addMessage(reply, 'ai');
        conversationHistory.push({ query, response: reply });
    } catch (err) {
        typing.remove();
        addMessage('Connection error: ' + err.message, 'ai');
    }
}

function addMessage(text, from) {
    const div = document.createElement('div');
    div.className = 'flex gap-3' + (from === 'user' ? ' flex-row-reverse' : '');
    div.innerHTML = from === 'user'
        ? '<div class="glass-card rounded-xl rounded-tr-none p-3 max-w-xs bg-emerald-900/30"><p class="text-sm text-tx-1">' + text + '</p></div>'
        : '<div class="w-8 h-8 rounded-xl overflow-hidden flex-shrink-0"><img src="/images/pearl-logo.png" class="w-full h-full object-contain"></div><div class="glass-card rounded-xl rounded-tl-none p-3 max-w-xs"><p class="text-sm text-tx-1">' + text + '</p></div>';
    document.getElementById('chatMessages').appendChild(div);
    document.getElementById('chatMessages').scrollTop = 999999;
    return div;
}

function addTyping() { return addMessage('<span class="animate-pulse">PEARL is thinking...</span>', 'ai'); }
</script>
