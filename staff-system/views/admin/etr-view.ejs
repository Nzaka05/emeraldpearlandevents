<% currentPage = 'etr'; %>

<div class="mb-6 animate-fade-up flex justify-between items-center">
  <a href="/portal/admin-staff/etr" class="text-tx-3 hover:text-emerald-400 text-sm font-bold flex items-center gap-2 transition-colors">
    <i class="fa-solid fa-arrow-left"></i> Return to Ledger
  </a>
  <div class="flex gap-2">
    <button onclick="resendETR('<%= etr.event_id && etr.event_id._id ? etr.event_id._id : etr.event_id %>')" class="btn btn-outline border-blue-500/30 text-blue-400 hover:bg-blue-500/20"><i class="fa-solid fa-paper-plane mr-2"></i> Resend to Client</button>
    <a href="/portal/admin-staff/etr/<%= etr.event_id && etr.event_id._id ? etr.event_id._id : etr.event_id %>/download" target="_blank" class="btn btn-primary shadow-glow-emerald"><i class="fa-solid fa-download mr-2"></i> Download PDF</a>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 animate-fade-up delay-2">
  <div class="glass-card p-6 lg:col-span-2">
    <h2 class="text-xl font-display font-bold text-tx-1 flex items-center gap-3 mb-6">
      <i class="fa-solid fa-file-invoice text-emerald-400"></i> Event Transaction Report 
      <span class="font-mono text-sm text-emerald-300 ml-auto bg-emerald-500/10 px-3 py-1 rounded"><%= etr.summary.etrNumber %> v<%= etr.version %></span>
    </h2>
    
    <div class="grid grid-cols-2 gap-4 mb-8">
      <div>
        <div class="text-[0.65rem] text-tx-3 uppercase tracking-wider mb-1">Event Designation</div>
        <div class="font-bold text-tx-1"><%= etr.summary.eventName %></div>
      </div>
      <div>
        <div class="text-[0.65rem] text-tx-3 uppercase tracking-wider mb-1">Client Contact</div>
        <div class="font-bold text-tx-1"><%= etr.summary.clientName %></div>
      </div>
      <div>
        <div class="text-[0.65rem] text-tx-3 uppercase tracking-wider mb-1">Operational Timeline</div>
        <div class="text-sm text-tx-2"><%= new Date(etr.summary.eventDate).toLocaleDateString() %> | <%= etr.summary.eventDuration %></div>
      </div>
      <div>
        <div class="text-[0.65rem] text-tx-3 uppercase tracking-wider mb-1">Status Tracking</div>
        <div class="font-bold"><span class="text-emerald-400 capitalize"><%= etr.summary.serviceDelivery.deliveryStatus %></span></div>
      </div>
    </div>
    
    <div class="border-t border-white/5 pt-6">
      <h3 class="font-bold text-tx-1 mb-4">Financial Ledger</h3>
      <table class="w-full text-sm">
        <tr class="border-b border-white/5"><td class="py-2 text-tx-2">Total Quoted</td><td class="text-right font-bold">KSh <%= (etr.summary.financialSummary.totalQuoted || 0).toLocaleString() %></td></tr>
        <tr class="border-b border-white/5"><td class="py-2 text-tx-2">Total Paid</td><td class="text-right font-bold text-emerald-400">KSh <%= (etr.summary.financialSummary.totalPaid || 0).toLocaleString() %></td></tr>
        <tr class="border-b border-white/5"><td class="py-2 text-tx-2">Outstanding Balance</td><td class="text-right font-bold text-red-400">KSh <%= (etr.summary.financialSummary.outstandingBalance || 0).toLocaleString() %></td></tr>
      </table>
    </div>
    
    <div class="border-t border-white/5 pt-6 mt-6">
      <h3 class="font-bold text-tx-1 mb-4">Cost Distribution</h3>
      <table class="w-full text-sm">
        <tr class="border-b border-white/5"><td class="py-2 text-tx-2">Staff Operations</td><td class="text-right font-bold">KSh <%= (etr.summary.costBreakdown.staffCost || 0).toLocaleString() %></td></tr>
        <tr class="border-b border-white/5"><td class="py-2 text-tx-2">Logistics & Support</td><td class="text-right font-bold">KSh <%= (etr.summary.costBreakdown.logisticsCost || 0).toLocaleString() %></td></tr>
        <tr class="border-b border-white/5"><td class="py-2 text-tx-2">Equipment</td><td class="text-right font-bold">KSh <%= (etr.summary.costBreakdown.equipmentCost || 0).toLocaleString() %></td></tr>
        <tr class="border-b border-white/5"><td class="py-2 text-tx-2">Emergency Funds</td><td class="text-right font-bold text-gold-400">KSh <%= (etr.summary.costBreakdown.emergencyFundsUsed || 0).toLocaleString() %></td></tr>
      </table>
      <div class="flex justify-between items-center bg-white/5 rounded p-3 mt-4">
        <div class="font-bold text-tx-1">Total Net Cost</div>
        <div class="font-bold text-emerald-400">KSh <%= (etr.summary.costBreakdown.totalCost || 0).toLocaleString() %></div>
      </div>
    </div>
  </div>
  
  <div class="space-y-6">
    <div class="glass-card p-5">
      <h3 class="font-bold text-tx-1 mb-4 border-b border-white/5 pb-2">Transmission Data</h3>
      <ul class="space-y-4 text-sm">
        <li>
          <div class="text-[0.65rem] text-tx-3 uppercase tracking-wider mb-1">Generated By System</div>
          <div class="font-medium"><%= new Date(etr.generated_at).toLocaleString() %></div>
        </li>
        <li>
          <div class="text-[0.65rem] text-tx-3 uppercase tracking-wider mb-1">Client Pipeline</div>
          <div>
            <% if (etr.delivery_status === 'sent') { %>
              <span class="badge-blue px-2 py-0.5 rounded-full inline-block">Sent <%= new Date(etr.sent_at).toLocaleString() %></span>
            <% } else if (etr.delivery_status === 'delivered') { %>
              <span class="badge-emerald px-2 py-0.5 rounded-full inline-block">Opened <%- etr.opened_at ? new Date(etr.opened_at).toLocaleString() : '' %></span>
            <% } else if (etr.delivery_status === 'failed') { %>
              <span class="badge-red px-2 py-0.5 rounded-full inline-block">Transmission Failed</span>
            <% } else { %>
              <span class="badge-gray px-2 py-0.5 rounded-full inline-block">Pending Transmission</span>
            <% } %>
          </div>
        </li>
      </ul>
    </div>
    
    <% if (etr.summary.aiPredictionComparison) { %>
    <div class="glass-card p-5 border-l-4 border-blue-500">
      <h3 class="font-bold text-blue-400 mb-4 border-b border-white/5 pb-2 flex items-center justify-between">
        AI Evaluation 
        <i class="fa-solid fa-brain"></i>
      </h3>
      <div class="space-y-3">
        <div class="flex justify-between text-sm">
          <span class="text-tx-2">Estimated Cost</span>
          <span class="font-mono">KSh <%= (etr.summary.aiPredictionComparison.predictedCost || 0).toLocaleString() %></span>
        </div>
        <div class="flex justify-between text-sm">
          <span class="text-tx-2">Actual Cost</span>
          <span class="font-mono">KSh <%= (etr.summary.aiPredictionComparison.actualCost || 0).toLocaleString() %></span>
        </div>
        <div class="flex justify-between items-center mt-4">
          <span class="text-tx-2 text-xs font-bold uppercase">Accuracy Vector</span>
          <span class="badge-blue text-xs"><%= etr.summary.aiPredictionComparison.predictionAccuracy || 'N/A' %></span>
        </div>
      </div>
    </div>
    <% } %>
  </div>
</div>

<script>
async function resendETR(eventId) {
    try {
        const btn = event.currentTarget;
        const oHtml = btn.innerHTML;
        btn.innerHTML = '<i class="fa-solid fa-circle-notch animate-spin mr-2"></i> Transmitting...';
        const r = await fetch(`/portal/admin-staff/etr/${eventId}/resend`, {
            method: 'POST',
            headers: { 'CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '' }
        });
        const data = await r.json();
        if (data.success) {
            showToast('ETR Resent to Client', 'success');
            setTimeout(() => location.reload(), 1000);
        } else {
            btn.innerHTML = oHtml;
            showToast(data.error || 'Failed to resend', 'error');
        }
    } catch (err) {
        showToast('Network fault', 'error');
    }
}
</script>
