  <div class="modal-content max-w-2xl">
    <div class="modal-header">
      <h3 class="text-base font-bold text-tx-1"><i class="fa-solid fa-chart-line text-emerald-400 mr-2"></i>Event Report</h3>
      <button onclick="closeModal('reportModal')" class="text-tx-3 hover:text-tx-1"><i class="fa-solid fa-xmark text-lg"></i></button>
    </div>
    <div class="modal-body">
      <div id="reportContent" class="text-sm text-tx-2">Loading report data...</div>
      <div id="reportExportBtns" class="hidden mt-6 flex gap-2 justify-end">
        <a id="exportPdfBtn" href="#" class="btn btn-primary btn-sm"><i class="fa-solid fa-file-pdf"></i> PDF</a>
        <a id="exportCsvBtn" href="#" class="btn btn-outline btn-sm"><i class="fa-solid fa-file-csv"></i> CSV</a>
      </div>
    </div>
  </div>
</div>

<!-- Modal: Edit Staff -->
<div class="modal-overlay" id="editStaffModal">
  <div class="modal-content max-w-lg">
    <div class="modal-header">
      <h3 class="text-base font-bold text-tx-1"><i class="fa-solid fa-user-pen text-gold-500 mr-2"></i>Edit Staff</h3>
      <button onclick="closeModal('editStaffModal')" class="text-tx-3 hover:text-tx-1"><i class="fa-solid fa-xmark text-lg"></i></button>
    </div>
    <div class="modal-body">
      <form onsubmit="submitEditStaff(event)" enctype="multipart/form-data" class="space-y-4">
        <input type="hidden" id="editStaffId">
        <div class="grid grid-cols-2 gap-4">
          <div><label class="form-label">Full Name</label><input type="text" id="editStaffName" class="form-input" required></div>
          <div><label class="form-label">Email</label><input type="email" id="editStaffEmail" class="form-input" required></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="form-label">Phone</label><input type="tel" id="editStaffPhone" class="form-input"></div>
          <div><label class="form-label">Role</label>
            <select id="editStaffRole" class="form-input form-select"><option>Staff</option><option>Supervisor</option><option>Admin</option></select>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="form-label">Department</label><input type="text" id="editStaffDept" class="form-input"></div>
          <div><label class="form-label">Skills</label><input type="text" id="editStaffSkills" class="form-input"></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="form-label">Shift Start</label><input type="time" id="editStaffShiftStart" class="form-input"></div>
          <div><label class="form-label">Shift End</label><input type="time" id="editStaffShiftEnd" class="form-input"></div>
