<% currentPage = 'dashboard'; %>

<!-- Staffing Alert Toast Container -->
<div id="staffingAlertContainer" class="fixed top-16 right-4 z-[300] max-w-[400px] space-y-3"></div>

<!-- ══ Page Header ══ -->
<div class="flex items-center justify-between mb-6 animate-fade-up">
  <div>
    <h1 class="font-display text-2xl font-extrabold text-tx-1 tracking-tight flex items-center gap-3">
      <span class="text-gradient-emerald">Command Center</span>
      <span class="status-dot status-dot-active animate-pulse-dot"></span>
    </h1>
    <p class="text-sm text-tx-3 mt-1">Real-time workforce monitoring & operations</p>
  </div>
  <button class="btn btn-primary" onclick="openModal('newAssignModal')">
    <i class="fa-solid fa-plus"></i> New Assignment
  </button>
</div>

<!-- ══ Metric Cards ══ -->
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-7">
  <%- include('../components/metric-card', { value: metrics.totalStaff, label: 'Total Staff', icon: 'fa-users', color: 'emerald', delay: 1 }) %>
  <%- include('../components/metric-card', { value: metrics.availableStaff, label: 'Available Now', icon: 'fa-circle-check', color: 'emerald', delay: 2 }) %>
  <%- include('../components/metric-card', { value: metrics.busyStaff, label: 'On Shift', icon: 'fa-user-clock', color: 'gold', delay: 3 }) %>
  <%- include('../components/metric-card', { value: metrics.activeAssignments, label: 'Active Events', icon: 'fa-calendar-days', color: 'blue', delay: 4 }) %>
  <%- include('../components/metric-card', { value: metrics.clockedInStaff, label: 'Clocked In', icon: 'fa-fingerprint', color: 'cyan', delay: 5 }) %>
  <%- include('../components/metric-card', { value: metrics.pendingPayments, label: 'Pending Pay', icon: 'fa-money-bills', color: 'gold', delay: 6 }) %>
</div>

<!-- ══ Main Grid: Events + Live Feed ══ -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-5 mb-6">

  <!-- Events Table (spans 2 cols) -->
  <div class="lg:col-span-2 glass-card overflow-hidden animate-fade-up delay-3">
    <div class="flex items-center justify-between px-5 py-3 border-b border-white/5">
      <h3 class="text-sm font-bold text-tx-1 flex items-center gap-2">
        <i class="fa-solid fa-calendar-days text-emerald-400"></i> Active Assignments
      </h3>
      <span class="text-[0.65rem] text-tx-3 font-semibold"><%= (assignments || []).length %> events</span>
    </div>
    <div class="overflow-x-auto">
      <table class="data-table">
        <thead>
          <tr>
            <th>Event</th>
            <th>Date</th>
            <th>Location</th>
            <th>Pay</th>
            <th>Status</th>
            <th>Payment</th>
            <th class="text-center">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (assignments && assignments.length > 0) { %>
            <% assignments.forEach(function(assignment) { %>
              <tr>
                <td>
                  <div class="flex items-center gap-2">
                    <span class="font-semibold text-tx-1"><%= assignment.title %></span>
                    <% if (assignment.vip_flag) { %>
                      <span class="badge-gold text-[0.6rem] font-bold px-1.5 py-0.5 rounded-full"><i class="fa-solid fa-crown text-[0.5rem]"></i></span>
                    <% } %>
                  </div>
                </td>
                <td><%= new Date(assignment.date).toLocaleDateString('en-KE', {month:'short', day:'numeric'}) %></td>
                <td class="text-tx-3"><%= assignment.location %></td>
                <td class="font-semibold">KSh <%= (assignment.pay_rate || 0).toLocaleString() %></td>
                <td>
                  <span class="<%= assignment.status === 'Active' ? 'badge-emerald' : assignment.status === 'Completed' ? 'badge-blue' : 'badge-gold' %> text-[0.65rem] font-bold px-2.5 py-1 rounded-full">
                    <%= assignment.status %>
                  </span>
                </td>
                <td>
                  <select onchange="updatePaymentStatus('<%= assignment._id %>', this.value)"
                    class="form-input form-select text-xs py-1 px-2 w-28">
                    <option value="Pending"  <%= assignment.payment_status === 'Pending'  ? 'selected' : '' %>>Pending</option>
                    <option value="Sent"     <%= assignment.payment_status === 'Sent'     ? 'selected' : '' %>>Sent</option>
                    <option value="Received" <%= assignment.payment_status === 'Received' ? 'selected' : '' %>>Received</option>
                    <option value="Disputed" <%= assignment.payment_status === 'Disputed' ? 'selected' : '' %>>Disputed</option>
                  </select>
                </td>
                <td class="text-center">
                  <div class="flex gap-1.5 justify-center">
                    <button class="btn btn-ghost btn-xs" onclick="openEditAssignment('<%= assignment._id %>','<%= assignment.title %>','<%= assignment.location %>','<%= new Date(assignment.date).toISOString().split('T')[0] %>','<%= assignment.start_time %>','<%= assignment.end_time %>','<%= assignment.pay_rate %>','<%= assignment.vip_flag %>','<%= (assignment.special_instructions||'').replace(/'/g,'') %>','<%= (assignment.dress_code||'').replace(/'/g,'') %>')">
                      <i class="fa-solid fa-pen-to-square"></i>
                    </button>
                    <button class="btn btn-ghost btn-xs" onclick="viewEventReport('<%= assignment._id %>')">
                      <i class="fa-solid fa-chart-line"></i>
                    </button>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="7" class="text-center py-8 text-tx-3">No assignments yet.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Live Activity Feed -->
  <div class="animate-fade-up delay-4">
    <%- include('../components/live-feed', {
      items: metrics.recentAuditLogs || [],
      title: 'Live Activity',
      feedId: 'liveFeed'
    }) %>
  </div>

</div>

<!-- ══ Second Row: Arrivals + Replacement Requests ══ -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-6">

  <!-- Live Arrivals -->
  <div class="glass-card overflow-hidden animate-fade-up delay-5">
    <div class="flex items-center justify-between px-5 py-3 border-b border-white/5">
      <h3 class="text-sm font-bold text-tx-1 flex items-center gap-2">
        <i class="fa-solid fa-location-crosshairs text-blue-400"></i>
        Live Arrivals
        <span class="status-dot status-dot-active animate-pulse-dot"></span>
      </h3>
    </div>
    <div id="liveArrivalsPanel" class="flex flex-wrap gap-3 p-4 min-h-[120px]">
      <div class="w-full text-center py-8 text-tx-3 text-sm">
        <i class="fa-solid fa-satellite-dish text-2xl block mb-2 opacity-30"></i>
        Waiting for staff clock-ins...
      </div>
    </div>
  </div>

  <!-- Replacement Requests -->
  <div class="glass-card overflow-hidden animate-fade-up delay-6">
    <div class="flex items-center justify-between px-5 py-3 border-b border-white/5">
      <h3 class="text-sm font-bold text-tx-1 flex items-center gap-2">
        <i class="fa-solid fa-user-minus text-red-400"></i> Replacement Requests
      </h3>
      <% if (pendingReplacements && pendingReplacements.length) { %>
        <span class="badge-red text-[0.6rem] font-bold px-2 py-0.5 rounded-full"><%= pendingReplacements.length %></span>
      <% } %>
    </div>
    <div class="overflow-x-auto">
      <table class="data-table">
        <thead><tr><th>Event</th><th>By</th><th>Remove</th><th>Replace</th><th class="text-center">Actions</th></tr></thead>
        <tbody>
          <% if (pendingReplacements && pendingReplacements.length > 0) { %>
            <% pendingReplacements.forEach(function(req) { %>
              <tr>
                <td class="font-semibold text-tx-1"><%= req.event_id ? req.event_id.title : 'Unknown' %></td>
                <td><%= req.submitted_by ? req.submitted_by.name : 'Unknown' %></td>
                <td class="text-red-400"><%= req.member_to_remove ? req.member_to_remove.name : '' %></td>
                <td class="text-emerald-400"><%= req.suggested_replacement ? req.suggested_replacement.name : 'None' %></td>
                <td class="text-center">
                  <div class="flex gap-2 justify-center">
                    <button class="btn btn-primary btn-xs" onclick="processReplacement('<%= req._id %>','approve')">Approve</button>
                    <button class="btn btn-outline btn-xs text-red-400 border-red-400/30" onclick="processReplacement('<%= req._id %>','reject')">Reject</button>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="5" class="text-center py-6 text-tx-3 text-sm">No pending requests</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<!-- ══ Quick Actions ══ -->
<div class="glass-card p-5 animate-fade-up delay-7 mb-6">
  <h3 class="text-sm font-bold text-tx-1 mb-3 flex items-center gap-2">
    <i class="fa-solid fa-bolt text-gold-500"></i> Quick Actions
  </h3>
  <div class="flex flex-wrap gap-3">
    <button class="btn btn-outline" onclick="openModal('addStaffModal')">
      <i class="fa-solid fa-user-plus text-emerald-400"></i> Provision Staff
    </button>
    <a href="/portal/admin-staff/export/payments" class="btn btn-outline">
      <i class="fa-solid fa-file-csv text-blue-400"></i> Export Payments
    </a>
    <a href="/portal/admin-staff/reports" class="btn btn-outline">
      <i class="fa-solid fa-chart-bar text-purple-400"></i> View Reports
    </a>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════════
     MODALS
     ══════════════════════════════════════════════════════════ -->

<!-- Modal: Add Staff -->
<div class="modal-overlay" id="addStaffModal">
  <div class="modal-content max-w-lg">
    <div class="modal-header">
      <h3 class="text-base font-bold text-tx-1"><i class="fa-solid fa-user-plus text-emerald-400 mr-2"></i>Provision Staff Account</h3>
      <button onclick="closeModal('addStaffModal')" class="text-tx-3 hover:text-tx-1 transition-colors"><i class="fa-solid fa-xmark text-lg"></i></button>
    </div>
    <div class="modal-body">
      <form id="addStaffForm" onsubmit="submitStaff(event)" enctype="multipart/form-data" class="space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div><label class="form-label">Full Name *</label><input type="text" name="name" class="form-input" required></div>
          <div><label class="form-label">Email *</label><input type="email" name="email" class="form-input" required></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="form-label">Phone</label><input type="tel" name="phone" class="form-input" placeholder="+254 722 446 937"></div>
          <div><label class="form-label">Role</label>
            <select name="role" class="form-input form-select"><option>Staff</option><option>Supervisor</option><option>Admin</option></select>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="form-label">Department</label><input type="text" name="department" class="form-input" placeholder="Events, Security..."></div>
          <div><label class="form-label">Skills</label><input type="text" name="skills" class="form-input" placeholder="bartending, hosting..."></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="form-label">Shift Start</label><input type="time" name="shift_start" class="form-input"></div>
          <div><label class="form-label">Shift End</label><input type="time" name="shift_end" class="form-input"></div>
        </div>
        <div><label class="form-label">Profile Photo</label><input type="file" name="photo" accept="image/jpeg,image/png,image/webp" class="form-input text-sm"></div>
        <button type="submit" class="btn btn-primary w-full">Create Account & Send Credentials</button>
      </form>
      <div id="staffCreds" class="hidden mt-4 p-4 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-sm text-emerald-300"></div>
    </div>
  </div>
</div>

<!-- Modal: Create Assignment -->
<div class="modal-overlay" id="newAssignModal">
  <div class="modal-content max-w-lg">
    <div class="modal-header">
      <h3 class="text-base font-bold text-tx-1"><i class="fa-solid fa-calendar-plus text-emerald-400 mr-2"></i>Create Event Assignment</h3>
      <button onclick="closeModal('newAssignModal')" class="text-tx-3 hover:text-tx-1 transition-colors"><i class="fa-solid fa-xmark text-lg"></i></button>
    </div>
    <div class="modal-body">
      <form id="assignForm" onsubmit="submitAssignment(event)" class="space-y-4">
        <div><label class="form-label">Event Title *</label><input type="text" name="title" class="form-input" required></div>
        <div><label class="form-label">Location *</label><input type="text" name="location" class="form-input" required></div>
        <div class="grid grid-cols-3 gap-4">
          <div><label class="form-label">Date *</label><input type="date" name="date" class="form-input" required></div>
          <div><label class="form-label">Start *</label><input type="time" name="start_time" class="form-input" required></div>
          <div><label class="form-label">End *</label><input type="time" name="end_time" class="form-input" required></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="form-label">Pay Rate (KSh) *</label><input type="number" name="pay_rate" class="form-input" step="0.01" required></div>
          <div><label class="form-label">Dress Code</label><input type="text" name="dress_code" class="form-input" placeholder="Black Tie..."></div>
        </div>
        <div><label class="form-label">Description</label><textarea name="description" rows="2" class="form-input"></textarea></div>
        <div><label class="form-label">Special Instructions</label><textarea name="special_instructions" rows="2" class="form-input" placeholder="VIP styling details..."></textarea></div>
        <div class="p-3 rounded-xl bg-gold-500/8 border border-gold-500/15">
          <label class="flex items-center gap-2 text-sm font-medium text-gold-400 cursor-pointer">
            <input type="checkbox" name="vip_flag" class="w-4 h-4 accent-gold-500"> Mark as VIP Event
          </label>
        </div>
        <div><label class="form-label">Assign To</label>
          <select name="assign_to_role" class="form-input form-select">
            <option value="">All Staff</option><option value="Staff">Regular Staff</option><option value="Supervisor">Supervisors</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary w-full mt-2">Push Assignment Live</button>
      </form>
    </div>
  </div>
</div>

<!-- Modal: Edit Assignment -->
<div class="modal-overlay" id="editAssignModal">
  <div class="modal-content max-w-lg">
    <div class="modal-header">
      <h3 class="text-base font-bold text-tx-1"><i class="fa-solid fa-pen text-gold-500 mr-2"></i>Edit Assignment</h3>
      <button onclick="closeModal('editAssignModal')" class="text-tx-3 hover:text-tx-1"><i class="fa-solid fa-xmark text-lg"></i></button>
    </div>
    <div class="modal-body">
      <form id="editAssignForm" onsubmit="submitEditAssignment(event)" class="space-y-4">
        <input type="hidden" id="editAssignId">
        <div><label class="form-label">Event Title</label><input type="text" id="editAssignTitle" class="form-input" required></div>
        <div><label class="form-label">Location</label><input type="text" id="editAssignLocation" class="form-input" required></div>
        <div class="grid grid-cols-3 gap-4">
          <div><label class="form-label">Date</label><input type="date" id="editAssignDate" class="form-input" required></div>
          <div><label class="form-label">Start</label><input type="time" id="editAssignStart" class="form-input" required></div>
          <div><label class="form-label">End</label><input type="time" id="editAssignEnd" class="form-input" required></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="form-label">Pay Rate (KSh)</label><input type="number" id="editAssignPay" class="form-input" step="0.01" required></div>
          <div><label class="form-label">Dress Code</label><input type="text" id="editAssignDress" class="form-input"></div>
