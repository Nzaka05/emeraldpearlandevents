<% currentPage = 'ai' %>
<div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="mb-6">
        <h1 class="font-display text-2xl font-bold text-tx-1">PEARL</h1>
        <p class="text-sm text-tx-3 mt-1">Personal Emerald Assistant for Real-time Leadership � ask about staff, events, analytics</p>
    </div>

    <!-- Chat Container -->
    <div class="glass-card rounded-2xl overflow-hidden" style="height:65vh;display:flex;flex-direction:column;">
        <!-- Messages -->
        <div id="chatMessages" class="flex-1 overflow-y-auto p-4 space-y-4">
            <div class="flex gap-3">
                <div class="w-8 h-8 rounded-xl flex-shrink-0 overflow-hidden">
                    <img src="/images/pearl-logo.png" class="w-8 h-8 rounded-xl object-cover" alt="PEARL" onerror="this.style.display='none';this.nextSibling.style.display='block'"><span style="display:none;color:white;font-size:10px;font-weight:bold;">P</span>
                </div>
                <div class="glass-card rounded-xl rounded-tl-none p-3 max-w-lg">
                    <p class="text-sm text-tx-1">Hello! I am PEARL, your Personal Emerald Assistant. I am here to help you manage staff, track events, and keep Emerald Pearland Events running smoothly. How may I assist you today?</p>
                </div>
            </div>
        </div>

        <!-- Input -->
        <div class="border-t border-white/8 p-4">
            <div class="flex gap-3">
                <input type="text" id="aiInput" placeholder="Good day! How can I assist you?"
                    class="flex-1 form-input rounded-xl bg-cosmos-600 border border-white/10 text-tx-1 px-4 py-3 text-sm focus:outline-none focus:border-emerald-500"
                    onkeypress="if(event.key==='Enter') sendMessage()">
                <button onclick="sendMessage()"
                    class="w-12 h-12 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white flex items-center justify-center transition-colors">
                    <i class="fa-solid fa-paper-plane"></i>
                </button>
            </div>
            <div class="flex gap-2 mt-3 flex-wrap">
                <button onclick="quickAsk('How many staff are available today?')" class="text-xs px-3 py-1.5 rounded-lg bg-cosmos-600 border border-white/10 text-tx-3 hover:text-tx-1 hover:border-emerald-500 transition-colors">Staff availability</button>
                <button onclick="quickAsk('What events are coming up this week?')" class="text-xs px-3 py-1.5 rounded-lg bg-cosmos-600 border border-white/10 text-tx-3 hover:text-tx-1 hover:border-emerald-500 transition-colors">Upcoming events</button>
                <button onclick="quickAsk('Show me performance analytics')" class="text-xs px-3 py-1.5 rounded-lg bg-cosmos-600 border border-white/10 text-tx-3 hover:text-tx-1 hover:border-emerald-500 transition-colors">Analytics</button>
                <button onclick="quickAsk('Any alerts or issues I should know about?')" class="text-xs px-3 py-1.5 rounded-lg bg-cosmos-600 border border-white/10 text-tx-3 hover:text-tx-1 hover:border-emerald-500 transition-colors">Alerts</button>
            </div>
        </div>
    </div>
</div>

<script>
const csrf = document.querySelector('meta[name="csrf-token"]')?.content || '';
const conversationHistory = [];
const conversationHistory = [];

function quickAsk(q) {
    document.getElementById('aiInput').value = q;
    sendMessage();
}

async function sendMessage() {
    const input = document.getElementById('aiInput');
    const query = input.value.trim();
    if (!query) return;
    input.value = '';

    addMessage(query, 'user');
    const typing = addTyping();

    try {
        const res = await fetch('/portal/admin-staff/ai/assistant', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrf },
            body: JSON.stringify({ 
                query, 
                eventContext: {
                    userName: '<%= user && user.name ? user.name : "Team Member" %>',
                    title: '<%= user && user.title ? user.title : "" %>',
                    role: '<%= user && user.role ? user.role : "Admin" %>',
                    email: '<%= user && user.email ? user.email : "" %>'
                },
                history: conversationHistory
            })
        });
        const data = await res.json();
        typing.remove();
        if (data.success && data.data) {
            const reply = data.data.response || data.data.summary || JSON.stringify(data.data);
            addMessage(reply, 'ai');
            conversationHistory.push({ query: query, response: reply });
        } else {
            addMessage('Error: ' + (data.error || data.message || 'Could not process request'), 'ai');
        }
    } catch (err) {
        typing.remove();
        addMessage('Connection error: ' + err.message, 'ai');
    }
}

function addMessage(text, from) {
    const div = document.createElement('div');
    div.className = 'flex gap-3' + (from === 'user' ? ' flex-row-reverse' : '');
    div.innerHTML = from === 'user'
        ? '<div class="glass-card rounded-xl rounded-tr-none p-3 max-w-lg bg-emerald-900/30 border-emerald-500/20"><p class="text-sm text-tx-1">' + text + '</p></div>'
        : '<div class="w-8 h-8 rounded-xl flex-shrink-0 overflow-hidden"><img src="/images/pearl-logo.png" class="w-8 h-8 rounded-xl object-cover" alt="PEARL" onerror="this.style.display='none';this.nextSibling.style.display='block'"><span style="display:none;color:white;font-size:10px;font-weight:bold;">P</span></div><div class="glass-card rounded-xl rounded-tl-none p-3 max-w-lg"><p class="text-sm text-tx-1">' + text + '</p></div>';
    document.getElementById('chatMessages').appendChild(div);
    document.getElementById('chatMessages').scrollTop = 999999;
    return div;
}

function addTyping() {
    return addMessage('<span class="animate-pulse">Thinking...</span>', 'ai');
}
</script>
