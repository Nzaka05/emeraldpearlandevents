<% currentPage = 'surveys'; %>

<div class="flex items-center justify-between mb-5 animate-fade-up">
    <div>
        <h1 class="font-display text-2xl font-extrabold text-tx-1 tracking-tight flex items-center gap-3">
            <i class="fa-solid fa-chart-pie text-pink-400"></i>
            <span>Survey Analytics</span>
        </h1>
        <p class="text-[0.7rem] text-tx-3 mt-1 uppercase tracking-widest font-mono">Post-Event Feedback & Ratings</p>
    </div>
</div>

<!-- Rating Summary Cards -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4 animate-fade-up">
    <% [['Staff', 'fa-users', '#10b981'], ['Supervisor', 'fa-user-shield', '#f59e0b'], ['Client', 'fa-star', '#ec4899']].forEach(function(type) { 
        var r = ratingsByType[type[0]];
    %>
    <div class="glass-card p-4 text-center border-t-2" style="border-color: <%= type[2] %>44">
        <i class="fa-solid <%= type[1] %> text-2xl mb-3 block" style="color: <%= type[2] %>"></i>
        <div class="text-[0.65rem] text-tx-3 uppercase tracking-widest mb-2"><%= type[0] %> Survey Avg</div>
        <% if(r) { %>
            <div class="text-3xl font-black font-mono mb-1" style="color: <%= type[2] %>"><%= r %></div>
            <div class="flex justify-center gap-1">
                <% for(var i=1;i<=5;i++) { %><i class="fa-solid fa-star text-[0.7rem] <%= i <= Math.round(parseFloat(r)) ? '' : 'opacity-10' %>" style="color:<%= i <= Math.round(parseFloat(r)) ? type[2] : '#ffffff' %>"></i><% } %>
            </div>
        <% } else { %>
            <div class="text-lg font-mono text-tx-3 opacity-40">—</div>
            <div class="text-[0.6rem] text-tx-3 opacity-40">No responses yet</div>
        <% } %>
    </div>
    <% }); %>
</div>

<!-- Filters -->
<div class="glass-card p-3 mb-4 animate-fade-up delay-1">
    <form method="GET" class="flex items-center gap-3 flex-wrap">
        <select name="type" class="bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-xs text-tx-2 focus:outline-none">
            <option value="">All Types</option>
            <% ['Staff','Supervisor','Client'].forEach(t => { %><option value="<%= t %>" <%= query.type===t?'selected':'' %>><%= t %></option><% }); %>
        </select>
        <select name="assignment_id" class="bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-xs text-tx-2 focus:outline-none">
            <option value="">All Events</option>
            <% (assignments||[]).forEach(a => { %><option value="<%= a._id %>" <%= query.assignment_id===String(a._id)?'selected':'' %>><%= a.title %></option><% }); %>
        </select>
        <button type="submit" class="btn btn-outline text-xs border-white/20 hover:border-pink-400/40">Filter</button>
    </form>
</div>

<!-- Survey Results Table -->
<div class="glass-card mb-[80px] animate-fade-up delay-2">
    <div class="px-5 py-4 border-b border-white/5">
        <h3 class="text-xs font-bold text-tx-1 uppercase tracking-widest">Survey Responses (<%= surveys.length %>)</h3>
    </div>
    <% if (!surveys.length) { %>
        <div class="p-16 text-center text-tx-3 opacity-60">
            <i class="fa-solid fa-chart-bar text-4xl mb-4 block opacity-20"></i>
            <h4 class="text-sm font-bold text-tx-1 mb-1">No survey responses yet</h4>
            <p class="text-xs">Surveys are automatically created when events complete. Staff and supervisors click their unique survey links to respond.</p>
        </div>
    <% } else { %>
        <div class="divide-y divide-white/5">
            <% surveys.forEach(function(sv) { 
                var typeColors = { Staff: 'text-emerald-400 border-emerald-500/30 bg-emerald-500/10', Supervisor: 'text-gold-400 border-gold-500/30 bg-gold-500/10', Client: 'text-pink-400 border-pink-500/30 bg-pink-500/10' };
            %>
            <div class="px-5 py-4 hover:bg-white/[0.02] transition-colors cursor-pointer" onclick="toggleSurveyDetail(this)">
                <div class="flex items-start justify-between gap-4 mb-3">
                    <div class="flex items-center gap-3">
                        <span class="text-[0.6rem] font-bold uppercase tracking-wider border px-2 py-0.5 rounded <%= typeColors[sv.type] || '' %>"><%= sv.type %></span>
                        <div>
                            <div class="text-sm font-bold text-tx-1"><%= sv.respondent_name || 'Anonymous' %></div>
                            <div class="text-[0.65rem] text-tx-3 font-mono">
                                <i class="fa-solid fa-calendar-day text-[0.5rem] mr-1 opacity-60"></i>
                                <%= sv.assignment_id ? sv.assignment_id.title : '—' %>
                                · <%= sv.submitted_at ? new Date(sv.submitted_at).toLocaleDateString('en-KE') : '—' %>
                            </div>
                        </div>
                    </div>
                    <% if(sv.overall_rating) { %>
                        <div class="flex items-center gap-1 shrink-0">
                            <span class="text-base font-black font-mono text-gold-400"><%= sv.overall_rating %></span>
                            <i class="fa-solid fa-star text-gold-400 text-xs"></i>
                        </div>
                    <% } %>
                </div>
                <% if(sv.responses && sv.responses.length) { %>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                        <% sv.responses.slice(0,4).forEach(function(r) { %>
                            <div class="bg-white/[0.02] border border-white/5 rounded-xl px-3 py-2">
                                <div class="text-[0.6rem] text-tx-3 mb-1 leading-relaxed"><%= r.question %></div>
                                <% if(r.answer_type === 'rating') { %>
                                    <div class="flex gap-0.5">
                                        <% for(var i=1;i<=5;i++) { %><i class="fa-solid fa-star text-[0.6rem] <%= i <= (r.answer||0) ? 'text-gold-400' : 'text-white/10' %>"></i><% } %>
                                    </div>
                                <% } else if(r.answer_type === 'boolean') { %>
                                    <span class="text-xs font-bold <%= r.answer === true || r.answer === 'true' ? 'text-emerald-400' : 'text-red-400' %>">
                                        <%= r.answer === true || r.answer === 'true' ? '✓ Yes' : '✗ No' %>
                                    </span>
                                <% } else { %>
                                    <p class="text-xs text-tx-2 italic"><%= r.answer || '—' %></p>
                                <% } %>
                            </div>
                        <% }); %>
                    </div>
                    <% if(sv.responses.length > 4) { %>
                    <div class="survey-full hidden mt-3 grid grid-cols-1 sm:grid-cols-2 gap-2">
                        <% sv.responses.slice(4).forEach(function(r) { %>
                            <div class="bg-white/[0.02] border border-white/5 rounded-xl px-3 py-2">
                                <div class="text-[0.6rem] text-tx-3 mb-1 leading-relaxed"><%= r.question %></div>
                                <% if(r.answer_type === 'rating') { %>
                                    <div class="flex gap-0.5">
                                        <% for(var i=1;i<=5;i++) { %><i class="fa-solid fa-star text-[0.6rem] <%= i <= (r.answer||0) ? 'text-gold-400' : 'text-white/10' %>"></i><% } %>
                                    </div>
                                <% } else if(r.answer_type === 'boolean') { %>
                                    <span class="text-xs font-bold <%= r.answer === true || r.answer === 'true' ? 'text-emerald-400' : 'text-red-400' %>">
                                        <%= r.answer === true || r.answer === 'true' ? '✓ Yes' : '✗ No' %>
                                    </span>
                                    <% if(r.followup) { %>
                                        <p class="text-xs text-tx-3 mt-1 italic">↳ <%= r.followup %></p>
                                    <% } %>
                                <% } else { %>
                                    <p class="text-xs text-tx-2 italic"><%= r.answer || '—' %></p>
                                <% } %>
                            </div>
                        <% }); %>
                    </div>
                    <% } %>
                    <button class="text-[0.65rem] text-emerald-400 hover:text-emerald-300 mt-2 font-semibold" onclick="event.stopPropagation();toggleSurveyDetail(this.closest('.px-5'))">
                        <i class="fa-solid fa-chevron-down mr-1"></i> View full response
                    </button>
                <% } %>
            </div>
            <% }); %>
        </div>
    <% } %>
</div>

<script>
function toggleSurveyDetail(card) {
    const full = card.querySelector('.survey-full');
    const btn = card.querySelector('button i.fa-chevron-down, button i.fa-chevron-up');
    if (!full) return;
    full.classList.toggle('hidden');
    if (btn) {
        btn.classList.toggle('fa-chevron-down');
        btn.classList.toggle('fa-chevron-up');
    }
}
</script>
