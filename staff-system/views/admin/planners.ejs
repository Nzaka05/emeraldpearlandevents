<% currentPage = 'planners'; %>

<div class="flex items-center justify-between mb-5 animate-fade-up">
    <div>
        <h1 class="font-display text-2xl font-extrabold text-tx-1 tracking-tight flex items-center gap-3">
            <i class="fa-solid fa-address-book text-purple-400"></i>
            <span>Event Planners Directory</span>
        </h1>
        <p class="text-[0.7rem] text-tx-3 mt-1 uppercase tracking-widest font-mono">External Contacts & Organiser Network</p>
    </div>
    <button onclick="openPlannerModal()" class="btn btn-primary text-xs font-bold shadow-glow-emerald">
        <i class="fa-solid fa-plus mr-1.5"></i> Add Planner
    </button>
</div>

<!-- Filter Bar -->
<div class="glass-card p-3 mb-4 animate-fade-up">
    <form method="GET" class="flex items-center gap-3 flex-wrap">
        <div class="relative flex-1 min-w-[200px]">
            <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-tx-3 text-xs"></i>
            <input type="text" name="search" value="<%= query.search || '' %>" placeholder="Search by name, company, email…"
                class="w-full bg-black/40 border border-white/10 rounded-xl pl-8 pr-4 py-2 text-sm text-tx-1 placeholder-tx-3/50 focus:border-purple-500/40 focus:outline-none">
        </div>
        <select name="event_type" class="bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-xs text-tx-2 focus:outline-none">
            <option value="">All Types</option>
            <% eventTypes.forEach(t => { %><option value="<%= t %>" <%= query.event_type===t?'selected':'' %>><%= t %></option><% }); %>
        </select>
        <select name="status" class="bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-xs text-tx-2 focus:outline-none">
            <option value="">All Status</option>
            <option value="Active" <%= query.status==='Active'?'selected':'' %>>Active</option>
            <option value="Inactive" <%= query.status==='Inactive'?'selected':'' %>>Inactive</option>
        </select>
        <button type="submit" class="btn btn-outline text-xs border-white/20 hover:border-purple-400/40">Filter</button>
    </form>
</div>

<!-- Planner Cards Grid -->
<% if (!planners.length) { %>
    <div class="glass-card p-16 text-center text-tx-3 opacity-60 animate-fade-up">
        <i class="fa-solid fa-address-book text-4xl mb-4 block opacity-30"></i>
        <h4 class="text-sm font-bold text-tx-1 mb-1">No planners found</h4>
        <p class="text-xs">Add your first external contact to build the directory.</p>
    </div>
<% } else { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4 mb-[80px] animate-fade-up">
        <% planners.forEach(function(p) { %>
        <div class="glass-card hover:border-purple-500/20 transition-colors border border-transparent">
            <div class="px-4 pt-4 pb-3 border-b border-white/5 flex items-start gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-purple-700 to-purple-500 flex items-center justify-center text-sm font-bold text-white shrink-0">
                    <%= p.name.split(' ').map(n=>n[0]).join('').toUpperCase().slice(0,2) %>
                </div>
                <div class="flex-1 min-w-0">
                    <div class="text-sm font-bold text-tx-1 truncate"><%= p.name %></div>
                    <div class="text-xs text-tx-3 truncate"><%= p.company || 'Independent' %></div>
                </div>
                <% var stBadge = p.status === 'Active' ? 'text-emerald-400 border-emerald-500/30 bg-emerald-500/10' : 'text-tx-3 border-white/10 bg-white/5'; %>
                <span class="text-[0.55rem] font-bold tracking-widest uppercase border px-1.5 py-0.5 rounded shrink-0 <%= stBadge %>"><%= p.status %></span>
            </div>
            <div class="px-4 py-3 space-y-2">
                <% if(p.phone) { %>
                    <div class="flex items-center gap-2 text-xs">
                        <i class="fa-solid fa-phone text-tx-3 text-[0.65rem] w-4"></i>
                        <a href="tel:<%= p.phone %>" class="text-tx-2 hover:text-emerald-400 transition-colors"><%= p.phone %></a>
                    </div>
                <% } %>
                <% if(p.email) { %>
                    <div class="flex items-center gap-2 text-xs">
                        <i class="fa-solid fa-envelope text-tx-3 text-[0.65rem] w-4"></i>
                        <a href="mailto:<%= p.email %>" class="text-tx-2 hover:text-blue-400 transition-colors truncate"><%= p.email %></a>
                    </div>
                <% } %>
                <% if(p.event_types && p.event_types.length) { %>
                    <div class="flex flex-wrap gap-1 pt-1">
                        <% p.event_types.forEach(t => { %>
                            <span class="text-[0.55rem] font-bold uppercase tracking-wider border border-purple-500/20 bg-purple-500/10 text-purple-400 px-1.5 py-0.5 rounded"><%= t %></span>
                        <% }); %>
                    </div>
                <% } %>
                <% if(p.notes) { %>
                    <p class="text-[0.65rem] text-tx-3 leading-relaxed italic border-t border-white/5 pt-2"><%= p.notes.slice(0,80) %><%= p.notes.length > 80 ? '…' : '' %></p>
                <% } %>
                <% if(p.linked_assignments && p.linked_assignments.length) { %>
                    <div class="text-[0.6rem] text-tx-3 border-t border-white/5 pt-2 font-mono">
                        <i class="fa-solid fa-link text-[0.5rem] mr-1 opacity-60"></i><%= p.linked_assignments.length %> linked event<%= p.linked_assignments.length > 1 ? 's' : '' %>
                    </div>
                <% } %>
            </div>
            <div class="px-4 pb-3 flex items-center gap-2">
                <% if(p.phone) { %>
                    <a href="tel:<%= p.phone %>" class="flex-1 btn btn-outline text-[0.65rem] font-bold border-emerald-500/20 text-emerald-400 hover:bg-emerald-500/10 py-1.5 text-center">
                        <i class="fa-solid fa-phone mr-1"></i> Call
                    </a>
                <% } %>
                <% if(p.email) { %>
                    <a href="mailto:<%= p.email %>" class="flex-1 btn btn-outline text-[0.65rem] font-bold border-blue-500/20 text-blue-400 hover:bg-blue-500/10 py-1.5 text-center">
                        <i class="fa-solid fa-envelope mr-1"></i> Email
                    </a>
                <% } %>
                <button onclick="editPlanner('<%= p._id %>', <%= JSON.stringify(p) %>)" class="btn btn-outline text-[0.65rem] border-white/10 text-tx-3 hover:text-tx-1 py-1.5 px-2">
                    <i class="fa-solid fa-pen"></i>
                </button>
                <button onclick="deletePlanner('<%= p._id %>', '<%= p.name %>')" class="btn btn-outline text-[0.65rem] border-red-500/20 text-red-400 hover:bg-red-500/10 py-1.5 px-2">
                    <i class="fa-solid fa-trash"></i>
                </button>
            </div>
        </div>
        <% }); %>
    </div>
<% } %>

<!-- Add/Edit Modal -->
<div id="plannerModal" class="hidden fixed inset-0 bg-black/80 backdrop-blur-md z-[9999] flex items-center justify-center p-4">
    <div class="bg-dark-card border border-purple-500/30 rounded-2xl shadow-[0_0_40px_rgba(139,92,246,0.1)] max-w-lg w-full max-h-[90vh] overflow-y-auto">
        <div class="px-5 py-4 border-b border-purple-500/20 flex items-center justify-between sticky top-0 bg-dark-card">
            <h3 class="text-sm font-bold text-tx-1 flex items-center gap-2">
                <i class="fa-solid fa-address-card text-purple-400"></i>
                <span id="plannerModalTitle">Add Planner</span>
            </h3>
            <button onclick="closePlannerModal()" class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center text-tx-3 hover:text-tx-1 transition-colors">
                <i class="fa-solid fa-xmark text-xs"></i>
            </button>
        </div>
        <form id="plannerForm" class="p-5 space-y-4">
            <input type="hidden" id="plannerId">
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-[0.65rem] font-bold uppercase tracking-widest text-tx-3 mb-1.5">Name *</label>
                    <input type="text" id="pName" required class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-2.5 text-sm text-tx-1 focus:border-purple-500/40 focus:outline-none">
                </div>
                <div>
                    <label class="block text-[0.65rem] font-bold uppercase tracking-widest text-tx-3 mb-1.5">Company</label>
                    <input type="text" id="pCompany" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-2.5 text-sm text-tx-1 focus:border-purple-500/40 focus:outline-none">
                </div>
                <div>
                    <label class="block text-[0.65rem] font-bold uppercase tracking-widest text-tx-3 mb-1.5">Phone *</label>
                    <input type="tel" id="pPhone" required class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-2.5 text-sm text-tx-1 focus:border-purple-500/40 focus:outline-none">
                </div>
                <div>
                    <label class="block text-[0.65rem] font-bold uppercase tracking-widest text-tx-3 mb-1.5">Email</label>
                    <input type="email" id="pEmail" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-2.5 text-sm text-tx-1 focus:border-purple-500/40 focus:outline-none">
                </div>
            </div>
            <div>
                <label class="block text-[0.65rem] font-bold uppercase tracking-widest text-tx-3 mb-2">Event Types</label>
                <div class="flex flex-wrap gap-2" id="eventTypeCheckboxes">
                    <% eventTypes.forEach(t => { %>
                        <label class="flex items-center gap-1.5 cursor-pointer text-xs">
                            <input type="checkbox" name="event_types" value="<%= t %>" class="event-type-cb rounded">
                            <span class="text-tx-2"><%= t %></span>
                        </label>
                    <% }); %>
                </div>
            </div>
            <div>
                <label class="block text-[0.65rem] font-bold uppercase tracking-widest text-tx-3 mb-1.5">Notes</label>
                <textarea id="pNotes" rows="2" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-2.5 text-sm text-tx-1 focus:border-purple-500/40 focus:outline-none resize-none"></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-full font-bold bg-gradient-to-r from-purple-700 to-purple-500 border-none shadow-[0_0_20px_rgba(139,92,246,0.2)]">
                <i class="fa-solid fa-floppy-disk mr-2"></i> Save Planner
            </button>
        </form>
    </div>
</div>

<script>
function openPlannerModal(data = null) {
    document.getElementById('plannerId').value = data?._id || '';
    document.getElementById('pName').value    = data?.name || '';
    document.getElementById('pCompany').value = data?.company || '';
    document.getElementById('pPhone').value   = data?.phone || '';
    document.getElementById('pEmail').value   = data?.email || '';
    document.getElementById('pNotes').value   = data?.notes || '';
    document.getElementById('plannerModalTitle').textContent = data ? 'Edit Planner' : 'Add Planner';
    // Reset checkboxes
    document.querySelectorAll('.event-type-cb').forEach(cb => {
        cb.checked = data?.event_types?.includes(cb.value) || false;
    });
    document.getElementById('plannerModal').classList.remove('hidden');
    document.getElementById('plannerModal').classList.add('flex');
}
function closePlannerModal() {
    document.getElementById('plannerModal').classList.add('hidden');
    document.getElementById('plannerModal').classList.remove('flex');
}
function editPlanner(id, data) { openPlannerModal(data); }

document.getElementById('plannerForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const id     = document.getElementById('plannerId').value;
    const types  = [...document.querySelectorAll('.event-type-cb:checked')].map(cb => cb.value);
    const body   = {
        name:        document.getElementById('pName').value,
        company:     document.getElementById('pCompany').value,
        phone:       document.getElementById('pPhone').value,
        email:       document.getElementById('pEmail').value,
        notes:       document.getElementById('pNotes').value,
        event_types: types
    };
    const url    = id ? `/portal/admin/planners/${id}` : '/portal/admin/planners';
    const method = id ? 'PUT' : 'POST';
    const res    = await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
    const data   = await res.json();
    if (data.success) { showToast(id ? 'Planner updated' : 'Planner added', 'success'); closePlannerModal(); location.reload(); }
    else showToast(data.error, 'error');
});

async function deletePlanner(id, name) {
    if (!confirm(`Delete ${name}?`)) return;
    const res = await fetch(`/portal/admin/planners/${id}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) { showToast('Planner deleted', 'success'); location.reload(); }
    else showToast(data.error, 'error');
}
</script>
