<% currentPage = 'events'; %>

<!-- ══ Page Header ══ -->
<div class="flex items-center justify-between mb-6 animate-fade-up">
  <div>
    <h1 class="font-display text-2xl font-extrabold text-tx-1 tracking-tight flex items-center gap-3">
      <span class="text-gradient-emerald">Events Architecture</span>
      <span class="status-dot status-dot-active animate-pulse-dot"></span>
    </h1>
    <p class="text-sm text-tx-3 mt-1">Design, construct, and oversee event deployments</p>
  </div>
  <button class="btn btn-primary shadow-glow-emerald" onclick="openModal('addEventModal')">
    <i class="fa-solid fa-plus relative top-[1px]"></i> Launch Event
  </button>
</div>

<!-- ══ Metric Cards ══ -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-7">
  <%- include('../components/metric-card', { value: stats.active || 0, label: 'Active Deployments', icon: 'fa-calendar-check', color: 'emerald', delay: 1 }) %>
  <%- include('../components/metric-card', { value: stats.vip || 0, label: 'VIP Events', icon: 'fa-crown', color: 'gold', delay: 2 }) %>
  <%- include('../components/metric-card', { value: stats.completed || 0, label: 'Successfully Completed', icon: 'fa-clipboard-check', color: 'blue', delay: 3 }) %>
  <%- include('../components/metric-card', { value: stats.totalStaffAssigned || 0, label: 'Total Placements', icon: 'fa-users', color: 'purple', delay: 4 }) %>
</div>

<!-- ══ Filters ══ -->
<div class="glass-card p-4 mb-6 animate-fade-up delay-4">
  <form method="GET" class="flex flex-col md:flex-row gap-3">
    <!-- Search -->
    <div class="relative flex-1">
      <i class="fa-solid fa-search absolute left-3.5 top-1/2 -translate-y-1/2 text-tx-3 text-sm"></i>
      <input type="text" name="search" placeholder="Search event matrix..." 
        value="<%= (filters && filters.search) || '' %>"
        class="form-input pl-10 w-full">
    </div>
    
    <select name="status" class="form-input form-select min-w-[150px]">
      <option value="">All Statuses</option>
      <option value="Active" <%= (filters && filters.status === 'Active') ? 'selected' : '' %>>Active</option>
      <option value="Completed" <%= (filters && filters.status === 'Completed') ? 'selected' : '' %>>Completed</option>
      <option value="Cancelled" <%= (filters && filters.status === 'Cancelled') ? 'selected' : '' %>>Cancelled</option>
    </select>
    
    <select name="vip" class="form-input form-select min-w-[150px]">
      <option value="">All Types</option>
      <option value="true" <%= (filters && filters.vip === 'true') ? 'selected' : '' %>>VIP Only</option>
    </select>
    
    <div class="flex gap-2">
      <button class="btn btn-primary shadow-glow-emerald flex-1 md:w-auto" type="submit">Filter Matrix</button>
      <a href="/portal/admin-staff/events" class="btn btn-outline flex-1 md:w-auto mt-0">Reset</a>
    </div>
  </form>
</div>

<!-- ══ Events Data Table ══ -->
<div class="glass-card overflow-hidden animate-fade-up delay-5">
  <div class="px-5 py-4 border-b border-white/5 flex items-center justify-between">
    <h3 class="text-sm font-bold text-tx-1 flex items-center gap-2">
      <i class="fa-solid fa-list-check text-emerald-400"></i> Event Registry
    </h3>
    <span class="badge-blue text-[0.65rem] font-bold px-2 py-0.5 rounded-full"><%= assignments.length %> Events</span>
  </div>
  
  <div class="overflow-x-auto">
    <table class="data-table">
      <thead>
        <tr>
          <th>Designation</th>
          <th>Chronology</th>
          <th>Location Matrix</th>
          <th>Compensation</th>
          <th>Unit Capacity</th>
          <th>Treasury</th>
          <th>Supervisor</th>
          <th>ETR Status</th>
          <th>Status</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (assignments.length > 0) { %>
          <% assignments.forEach(function(a) { 
              const psMap = { Pending: 'badge-gold', Sent: 'badge-blue', Received: 'badge-emerald', Disputed: 'badge-red' };
          %>
            <tr onclick="openEditEventModal(this.dataset.event)" data-event="<%- JSON.stringify(a).replace(/"/g, '&quot;') %>" class="cursor-pointer hover:bg-white/5 transition-colors group">
              
              <td>
                <div class="font-bold text-tx-1 text-sm group-hover:text-emerald-300 transition-colors flex items-center gap-2">
                  <%= a.title %>
                  <% if(a.vip_flag) { %>
                    <span class="badge-gold text-[0.6rem] font-bold px-1.5 py-0.5 rounded-full" title="VIP Event"><i class="fa-solid fa-crown text-[0.5rem]"></i></span>
                  <% } %>
                  <% if(a.open_for_applications) { %>
                    <span class="badge-emerald text-[0.6rem] font-bold px-1.5 py-0.5 rounded-full" title="Accepting Recruits">OPEN</span>
                  <% } %>
                  <% if(a.booking_ref) { %>
                    <span class="text-[0.6rem] font-bold px-1.5 py-0.5 rounded-full bg-blue-500/20 text-blue-400 border border-blue-500/30" title="Synced from booking"><i class="fa-solid fa-link mr-0.5 text-[0.5rem]"></i>BOOKING</span>
                  <% } %>
                  <% var ageHours = (Date.now() - new Date(a.createdAt)) / 3600000; %>
                  <% if(ageHours < 24) { %>
                    <span class="text-[0.6rem] font-bold px-1.5 py-0.5 rounded-full bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 animate-pulse">NEW</span>
                  <% } %>
                </div>
                <% if(a.dress_code) { %>
                  <div class="text-[0.65rem] text-tx-3 mt-1 font-medium"><i class="fa-solid fa-shirt mr-1"></i> <%= a.dress_code %></div>
                <% } %>
              </td>
              
              <td>
                <div class="font-bold text-tx-1 text-[0.8rem]"><%= new Date(a.date).toLocaleDateString('en-KE', { day: 'numeric', month: 'short', year: 'numeric' }) %></div>
                <div class="text-[0.65rem] text-emerald-400 font-medium font-mono tracking-wider"><%= a.start_time %> – <%= a.end_time || '?' %></div>
              </td>
              
              <td class="text-xs text-tx-2 font-medium max-w-[140px] truncate"><%= a.location || '—' %></td>
              
              <td>
                <div class="font-bold text-sm text-tx-1">KSh <%= (a.pay_rate || 0).toLocaleString() %></div>
              </td>
              
              <td>
                <button class="btn btn-ghost !p-0 h-auto font-mono text-xs flex items-center gap-1.5" onclick="viewStaffStatus('<%= a._id %>', '<%= a.title %>'); event.stopPropagation();">
                  <span class="text-emerald-400 font-bold text-sm"><%= (a.accepted_staff_ids || []).length %></span>
                  <span class="text-tx-3">/ <%= (a.required_staff_count || 1) %></span>
                  
                  <% if ((a.accepted_staff_ids || []).length >= (a.required_staff_count || 1)) { %>
                    <span class="w-2 h-2 rounded-full bg-emerald-500 shadow-glow-emerald ml-1" title="Capacity Reached"></span>
                  <% } else { %>
                    <span class="w-2 h-2 rounded-full bg-gold-500 shadow-glow-gold ml-1 animate-pulse" title="Recruiting"></span>
                  <% } %>
                </button>
              </td>
              
              <td>
                <span class="<%= psMap[a.payment_status || 'Pending'] || 'badge-gray' %> text-[0.65rem] font-bold px-2 py-0.5 rounded-full inline-block">
                  <%= a.payment_status || 'Pending' %>
                </span>
              </td>
              
              <td class="text-xs text-tx-2 font-medium">
                <%= a.supervisor_id ? a.supervisor_id.name : '—' %>
              </td>
              
              <td class="text-xs font-medium">
                <% if (!a.etr) { %>
                  <span class="badge-gray px-2 py-0.5 rounded-full inline-block">Not Generated</span>
                <% } else if (a.etr.delivery_status === 'sent') { %>
                  <span class="badge-blue px-2 py-0.5 rounded-full inline-block">Sent <%= new Date(a.etr.sent_at || a.etr.createdAt).toLocaleDateString() %></span>
                <% } else if (a.etr.delivery_status === 'delivered') { %>
                  <span class="badge-emerald px-2 py-0.5 rounded-full inline-block">Opened <%- a.etr.opened_at ? new Date(a.etr.opened_at).toLocaleDateString() : '' %></span>
                <% } else if (a.etr.delivery_status === 'failed') { %>
                  <span class="badge-red px-2 py-0.5 rounded-full inline-block">Failed 
                    <button type="button" class="ml-1 text-red-500 underline text-[0.6rem] hover:text-red-300" onclick="retryEtr(event, '<%= a._id %>')">Retry</button>
                  </span>
                <% } else { %>
                  <span class="badge-gold px-2 py-0.5 rounded-full inline-block">Processing</span>
                <% } %>
              </td>
              
              <td>
                <span class="<%= a.status === 'Active' ? 'badge-emerald text-emerald-300' : a.status === 'Completed' ? 'badge-blue text-blue-300' : 'badge-red text-red-300' %> text-xs font-bold flex items-center gap-2 bg-transparent border-none p-0 inline-flex">
                  <span class="w-1.5 h-1.5 rounded-full <%= a.status === 'Active' ? 'bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.8)]' : a.status === 'Completed' ? 'bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.8)]' : 'bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.8)]' %>"></span>
                  <%= a.status %>
                </span>
              </td>
              
              <td class="text-right whitespace-nowrap" onclick="event.stopPropagation()">
                <div class="flex items-center gap-1 justify-end opacity-70 group-hover:opacity-100 transition-opacity">
                  
                  <button class="btn btn-ghost btn-xs w-7 h-7 p-0 flex items-center justify-center hover:bg-emerald-500/20 hover:text-emerald-400" title="Edit Parameters" onclick="openEditEventModal(this.parentElement.parentElement.parentElement.dataset.event)">
                    <i class="fa-solid fa-pen"></i>
                  </button>
                  
                  <div class="relative inline-block">
                    <button class="btn btn-ghost btn-xs w-7 h-7 p-0 flex items-center justify-center hover:bg-blue-500/20 hover:text-blue-400" title="Review Recruits" onclick="openApplicantsModal('<%= a._id %>', '<%= a.title %>')">
                      <i class="fa-solid fa-user-clock"></i>
                    </button>
                    <% if((a.applicant_ids || []).length > 0) { %>
                      <div class="absolute -top-1 -right-1 w-3.5 h-3.5 rounded-full bg-red-500 text-white flex items-center justify-center text-[0.55rem] font-bold shadow-glow-red border border-dark-bg pointer-events-none">
                        <%= a.applicant_ids.length %>
                      </div>
                    <% } %>
                  </div>
                  
                  <button class="btn btn-ghost btn-xs w-7 h-7 p-0 flex items-center justify-center hover:bg-gold-500/20 hover:text-gold-400" title="Assign Supervisor" onclick="openAssignSupervisorModal('<%= a._id %>', '<%= a.title %>')">
                    <i class="fa-solid fa-user-tie"></i>
                  </button>
                  
                  <button class="btn btn-ghost btn-xs w-7 h-7 p-0 flex items-center justify-center hover:bg-purple-500/20 hover:text-purple-400" title="Deploy Units" onclick="openAssignStaffModal('<%= a._id %>', '<%= a.title %>')">
                    <i class="fa-solid fa-users-viewfinder"></i>
                  </button>
                  
                  <button class="btn btn-xs <%= a.open_for_applications ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/30 hover:bg-emerald-500/20' : 'bg-white/5 text-tx-3 border border-border hover:bg-white/10 hover:text-tx-1' %> px-2 ml-1 transition-colors" title="<%= a.open_for_applications ? 'Seal Event' : 'Open Recruitment' %>" onclick="toggleApplications('<%= a._id %>')">
                    <i class="fa-solid <%= a.open_for_applications ? 'fa-door-open' : 'fa-door-closed' %> text-[0.65rem] mr-1"></i>
                    <%= a.open_for_applications ? 'Open' : 'Closed' %>
                  </button>
                  
                  <button class="btn btn-ghost btn-xs w-7 h-7 ml-1 p-0 flex items-center justify-center text-tx-3 hover:bg-red-500/20 hover:text-red-400" title="Terminate Event" onclick="deleteEvent('<%- a._id %>', '<%- a.title %>')">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                  
                </div>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr>
            <td colspan="9" class="text-center py-12">
              <div class="flex flex-col items-center justify-center text-tx-3">
                <i class="fa-solid fa-calendar-xmark text-4xl mb-3 opacity-20"></i>
                <p class="text-sm">No operational events located. Construct a new deployment.</p>
              </div>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════════
     MODALS
     ══════════════════════════════════════════════════════════ -->

<!-- Add Event Modal -->
<div class="modal-overlay" id="addEventModal">
  <div class="modal-content max-w-2xl">
    <div class="modal-header border-b border-emerald-500/20 pb-4">
      <h3 class="text-base font-bold text-tx-1 flex items-center gap-2">
        <div class="w-8 h-8 rounded-lg bg-emerald-500/20 text-emerald-400 flex items-center justify-center shadow-glow-emerald"><i class="fa-solid fa-calendar-plus"></i></div>
        Event Initialization Protocol
      </h3>
      <button class="text-tx-3 hover:text-tx-1" onclick="closeModal('addEventModal')"><i class="fa-solid fa-xmark text-lg"></i></button>
    </div>
    <div class="modal-body pt-5">
      <form action="/portal/admin-staff/assignments" method="POST" id="addEventForm" class="space-y-4">
        <div>
          <label class="form-label">Event Designation</label>
          <input type="text" name="title" class="form-input text-lg font-bold" required placeholder="OPERATION: GALAXY PRIME">
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div><label class="form-label">Launch Date</label><input type="date" name="date" class="form-input font-mono" required></div>
          <div><label class="form-label">Location Matrix</label><input type="text" name="location" class="form-input" placeholder="Origin Coordinates..."></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 bg-white/5 p-3 rounded-xl border border-white/5">
          <div>
            <label class="form-label text-emerald-400"><i class="fa-solid fa-satellite mr-1"></i> GPS Latitude</label>
            <input type="number" step="any" name="gps_lat" id="addGpsLat" class="form-input bg-black/40 font-mono text-xs" placeholder="-1.2921">
          </div>
          <div>
            <label class="form-label text-emerald-400"><i class="fa-solid fa-satellite-dish mr-1"></i> GPS Longitude</label>
            <div class="flex gap-2">
              <input type="number" step="any" name="gps_lng" id="addGpsLng" class="form-input flex-1 bg-black/40 font-mono text-xs" placeholder="36.8219">
              <button type="button" class="btn btn-outline border-emerald-500/30 text-emerald-400 hover:bg-emerald-500/20 px-3" onclick="getGPSLocation('add')" title="Lock Current Coords">
                <i class="fa-solid fa-crosshairs"></i>
              </button>
            </div>
          </div>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div><label class="form-label">Deployment Time</label><input type="time" name="start_time" class="form-input font-mono" value="09:00"></div>
          <div><label class="form-label">Extraction Time</label><input type="time" name="end_time" class="form-input font-mono" value="17:00"></div>
          <div><label class="form-label">Treasury (KSh)</label><input type="number" name="pay_rate" class="form-input font-mono text-gold-400" value="1000" min="0" step="50"></div>
          <div><label class="form-label">Unit Quota</label><input type="number" name="required_staff_count" id="addStaffCount" class="form-input font-mono text-blue-400" min="1" value="1"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div><label class="form-label">Uniform Specs</label><input type="text" name="dress_code" class="form-input" placeholder="Tactical Black..."></div>
          <div>
            <label class="form-label text-gold-400">Classified Status</label>
            <label class="flex items-center gap-3 p-2.5 rounded-lg border border-gold-500/30 bg-gold-500/10 cursor-pointer hover:bg-gold-500/20 transition-colors">
              <input type="checkbox" name="vip_flag" value="true" class="w-4 h-4 rounded border-gold-500/50 bg-dark-card accent-gold-500">
              <span class="text-sm font-bold text-gold-400 flex items-center gap-2"><i class="fa-solid fa-crown"></i> VIP Protocol Event</span>
            </label>
          </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 p-3 rounded-xl border border-blue-500/20 bg-blue-500/5">
          <div><label class="form-label text-blue-400"><i class="fa-solid fa-user-tie mr-1"></i> Client Name</label><input type="text" name="client_name" class="form-input" placeholder="John Kamau..."></div>
          <div><label class="form-label text-blue-400"><i class="fa-solid fa-envelope mr-1"></i> Client Email</label><input type="email" name="client_email" class="form-input" placeholder="client@example.com"></div>
        </div>
        <div><label class="form-label">Operational Briefing</label><textarea name="description" rows="2" class="form-input placeholder:opacity-50" placeholder="Mission parameters and objectives..."></textarea></div>
        <div><label class="form-label">Special Directives</label><textarea name="special_instructions" rows="2" class="form-input placeholder:opacity-50" placeholder="Critical restrictions or mandatory protocols..."></textarea></div>
        
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-primary w-full shadow-glow-emerald bg-emerald-600 hover:bg-emerald-500 border-none font-display font-bold text-lg py-3 mt-4">
          <i class="fa-solid fa-rocket mr-2"></i> INITIALIZE DEPLOYMENT
        </button>
      </form>
    </div>
  </div>
</div>

<!-- Edit Event Modal -->
<div class="modal-overlay" id="editEventModal">
  <div class="modal-content max-w-2xl">
    <div class="modal-header border-b border-gold-500/20 pb-4">
      <h3 class="text-base font-bold text-tx-1 flex items-center gap-2">
        <div class="w-8 h-8 rounded-lg bg-gold-500/20 text-gold-400 flex items-center justify-center shadow-glow-gold"><i class="fa-solid fa-calendar-pen"></i></div>
        Recalibrate Event Parameters
      </h3>
      <button class="text-tx-3 hover:text-tx-1" onclick="closeModal('editEventModal')"><i class="fa-solid fa-xmark text-lg"></i></button>
    </div>
    <div class="modal-body pt-5">
      <form id="editEventForm" method="POST" class="space-y-4">
        <input type="hidden" name="_method" value="PUT">
        
        <div>
          <label class="form-label">Designation</label>
          <input type="text" name="title" id="ev_title" class="form-input text-lg font-bold" required>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div><label class="form-label">Date</label><input type="date" name="date" id="ev_date" class="form-input font-mono"></div>
          <div><label class="form-label">Location Matrix</label><input type="text" name="location" id="ev_location" class="form-input"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 bg-white/5 p-3 rounded-xl border border-white/5">
          <div><label class="form-label text-gold-400 text-xs">Lat</label><input type="number" step="any" name="gps_lat" id="editGpsLat" class="form-input bg-black/40 font-mono text-xs py-1.5 h-auto"></div>
          <div>
            <label class="form-label text-gold-400 text-xs">Lng</label>
            <div class="flex gap-2">
              <input type="number" step="any" name="gps_lng" id="editGpsLng" class="form-input flex-1 bg-black/40 font-mono text-xs py-1.5 h-auto">
              <button type="button" class="btn btn-outline border-gold-500/30 text-gold-400 py-1.5 h-auto px-2" onclick="getGPSLocation('edit')"><i class="fa-solid fa-crosshairs"></i></button>
            </div>
          </div>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div><label class="form-label">Deployment</label><input type="time" name="start_time" id="ev_start" class="form-input font-mono h-9"></div>
          <div><label class="form-label">Extraction</label><input type="time" name="end_time" id="ev_end" class="form-input font-mono h-9"></div>
          <div><label class="form-label">Treasury</label><input type="number" name="pay_rate" id="ev_rate" class="form-input font-mono text-gold-400 h-9" min="0" step="50"></div>
          <div><label class="form-label">Quota</label><input type="number" name="required_staff_count" id="editStaffCount" class="form-input font-mono text-blue-400 h-9" min="1"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 p-3 rounded-xl border border-blue-500/20 bg-blue-500/5">
          <div><label class="form-label text-blue-400"><i class="fa-solid fa-user-tie mr-1"></i> Client Name</label><input type="text" name="client_name" id="ev_client_name" class="form-input" placeholder="John Kamau..."></div>
          <div><label class="form-label text-blue-400"><i class="fa-solid fa-envelope mr-1"></i> Client Email</label><input type="email" name="client_email" id="ev_client_email" class="form-input" placeholder="client@example.com"></div>
        </div>
        <div>
          <label class="form-label text-emerald-400">Operational Status</label>
          <select name="status" id="ev_status" class="form-input form-select font-bold">
            <option value="Active" class="text-emerald-400">Active</option>
            <option value="Completed" class="text-blue-400">Completed</option>
            <option value="Cancelled" class="text-red-400">Cancelled</option>
          </select>
        </div>
        
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-primary w-full mt-4 shadow-glow-gold bg-gradient-to-r from-gold-600 to-amber-500 border-none font-bold text-dark-bg transition-all hover:scale-[1.01]">
          Commence Recalibration
        </button>
      </form>
    </div>
  </div>
</div>

<!-- Assign Supervisor Modal -->
<div class="modal-overlay" id="assignEventSupervisorModal">
  <div class="modal-content max-w-sm">
    <div class="modal-header border-b border-gold-500/20 pb-3">
      <h3 class="text-base font-bold text-tx-1 flex items-center gap-2"><div class="w-7 h-7 rounded bg-gold-500/20 text-gold-400 flex items-center justify-center text-xs"><i class="fa-solid fa-user-tie"></i></div>Assign Supervisor</h3>
      <button class="text-tx-3 hover:text-tx-1" onclick="closeModal('assignEventSupervisorModal')"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body pt-4">
      <p id="assignSupervisorEventName" class="text-sm font-bold text-emerald-400 mb-4 pb-2 border-b border-white/5 truncate"></p>
      <input type="hidden" id="assignSupervisorEventId">
      <div class="space-y-4">
        <div>
          <label class="form-label text-tx-2">Select Command Authority</label>
          <select id="supervisorSelect" class="form-input form-select text-sm rounded-xl border-white/10 focus:border-gold-500/50 focus:ring-1 focus:ring-gold-500/50">
            <option value="">Querying network...</option>
          </select>
        </div>
        <button class="btn btn-primary w-full bg-gold-600 hover:bg-gold-500 text-dark-bg font-bold shadow-glow-gold border-none" onclick="submitAssignSupervisor()">Assign Supervisor</button>
      </div>
    </div>
  </div>
</div>

