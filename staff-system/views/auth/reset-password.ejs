<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <i class="fa-solid fa-unlock" style="font-size: 2.5rem; color: var(--emerald); margin-bottom: 1rem;"></i>
            <h2>Reset Password</h2>
            <p>Enter your new password.</p>
        </div>

        <div class="auth-body">
            <% if (typeof error !=='undefined' && error) { %>
                <div class="alert alert-danger" style="color: #dc3545; text-align: center; margin-bottom: 1rem;">
                    <%= error %>
                </div>
                <% } %>

                    <form action="/portal/auth/reset-password/<%= token %>" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="form-group">
                            <label>New Password</label>
                            <input type="password" name="password" required minlength="8">
                        </div>

                        <div class="form-group">
                            <label>Confirm Password</label>
                            <input type="password" name="confirm_password" required minlength="8">
                        </div>

                        <button type="submit" class="btn btn-primary" style="width: 100%;">Save Password &
                            Login</button>
                    </form>
        </div>
    </div>
</div>