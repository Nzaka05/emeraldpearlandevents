<%- layout = false %>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Login - Staff Portal | Emerald Events</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
            /* Gem/Lightning fallback if video doesn't load */
            background-color: #050b14;
            background-image: url('/images/bg-gem.jpg');
            background-size: cover;
            background-position: center;
        }

        /* ── Video Background ── */
        .video-bg {
            position: fixed;
            inset: 0;
            z-index: 0;
            overflow: hidden;
        }

        .video-bg video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: brightness(0.45) saturate(1.2);
        }

        /* ── Dark gradient overlay matching lightning tones ── */
        .video-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(0, 15, 25, 0.7) 0%, rgba(5, 10, 20, 0.85) 100%);
        }

        /* Static lightning/gem overlay (shows when video is absent / behind video) */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background:
                radial-gradient(ellipse 800px 500px at 20% 30%, rgba(0, 200, 255, 0.07) 0%, transparent 70%),
                radial-gradient(ellipse 600px 400px at 80% 70%, rgba(0, 150, 200, 0.06) 0%, transparent 70%),
                linear-gradient(135deg, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0.4) 100%);
            pointer-events: none;
            z-index: 0;
        }

        /* ── Login card ── */
        .login-wrap {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 420px;
            padding: 24px;
        }

        .login-header {
            text-align: center;
            color: white;
            margin-bottom: 28px;
        }

        .login-header .brand-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 72px;
            height: 72px;
            background: rgba(255, 255, 255, 0.12);
            border: 2px solid rgba(212, 175, 55, 0.6);
            border-radius: 20px;
            font-size: 2rem;
            color: #d4af37;
            margin-bottom: 16px;
            backdrop-filter: blur(8px);
            box-shadow: 0 4px 24px rgba(212, 175, 55, 0.25);
        }

        .login-header h1 {
            font-size: 1.8rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #ffffff;
        }

        .login-header p {
            color: rgba(255, 255, 255, 0.65);
            font-size: 0.9rem;
            margin-top: 6px;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            font-size: 0.75rem;
        }

        /* ── Glass card ── */
        .login-card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.18);
            border-radius: 20px;
            padding: 36px 28px;
            box-shadow:
                0 8px 32px rgba(0, 0, 0, 0.45),
                inset 0 1px 0 rgba(255, 255, 255, 0.12);
        }

        /* Alert messages */
        .error-msg {
            background: rgba(239, 68, 68, 0.18);
            border: 1px solid rgba(239, 68, 68, 0.4);
            color: #fca5a5;
            padding: 12px 14px;
            border-radius: 10px;
            font-size: 0.875rem;
            margin-bottom: 18px;
        }

        .success-msg {
            background: rgba(16, 185, 129, 0.18);
            border: 1px solid rgba(16, 185, 129, 0.4);
            color: #6ee7b7;
            padding: 12px 14px;
            border-radius: 10px;
            font-size: 0.875rem;
            margin-bottom: 18px;
        }

        /* Form elements */
        .field-group {
            margin-bottom: 18px;
        }

        .field-group label {
            display: block;
            font-size: 0.8rem;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.75);
            margin-bottom: 8px;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .field-group input {
            width: 100%;
            padding: 12px 14px;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 10px;
            color: #fff;
            font-size: 0.95rem;
            font-family: 'Inter', sans-serif;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
        }

        .field-group input::placeholder {
            color: rgba(255, 255, 255, 0.35);
        }

        .field-group input:focus {
            border-color: #d4af37;
            background: rgba(255, 255, 255, 0.15);
            box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.2);
        }

        /* Forgot link */
        .forgot-link {
            display: block;
            text-align: right;
            font-size: 0.8rem;
            color: rgba(212, 175, 55, 0.85);
            text-decoration: none;
            margin-top: 6px;
            margin-bottom: 22px;
            transition: color 0.2s;
        }

        .forgot-link:hover {
            color: #d4af37;
        }

        /* Submit button */
        .btn-login {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #d4af37, #b8963a);
            color: #0a2f1c;
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 700;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            letter-spacing: 0.03em;
            transition: transform 0.15s, box-shadow 0.15s, filter 0.15s;
            box-shadow: 0 4px 20px rgba(212, 175, 55, 0.4);
        }

        .btn-login:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 28px rgba(212, 175, 55, 0.5);
            filter: brightness(1.05);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        /* Divider */
        .card-footer {
            text-align: center;
            margin-top: 20px;
            font-size: 0.78rem;
            color: rgba(255, 255, 255, 0.35);
            letter-spacing: 0.03em;
        }
    </style>
</head>

<body>

    <!-- Full-screen video background -->
    <div class="video-bg">
        <video autoplay muted loop playsinline>
            <source src="/logo.mp4" type="video/mp4">
        </video>
    </div>

    <div class="login-wrap">
        <!-- Header -->
        <div class="login-header">
            <div class="brand-icon">
                <i class="fa-solid fa-users"></i>
            </div>
            <h1>Staff Portal</h1>
            <p>Emerald Events Workforce</p>
        </div>

        <!-- Glass card -->
        <div class="login-card">

            <% if (typeof error !=='undefined' && error) { %>
                <div class="error-msg">
                    <i class="fa-solid fa-circle-exclamation" style="margin-right:6px;"></i>
                    <%= error %>
                </div>
                <% } %>
                    <% if (typeof message !=='undefined' && message) { %>
                        <div class="success-msg">
                            <i class="fa-solid fa-circle-check" style="margin-right:6px;"></i>
                            <%= message %>
                        </div>
                        <% } %>

                            <form action="/portal/auth/login" method="POST">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                                <div class="field-group">
                                    <label>Email Address</label>
                                    <input type="email" name="email" placeholder="name@emeraldevents.com" required
                                        autocomplete="email">
                                </div>

                                <div class="field-group" style="position:relative;">
                                    <label>Password</label>
                                    <input type="password" id="passwordInput" name="password" placeholder="••••••••" required
                                        autocomplete="current-password">
                                    <button type="button" onclick="togglePwd('passwordInput',this)"
                                        style="position:absolute;right:12px;top:38px;background:none;border:none;cursor:pointer;color:var(--text3);">
                                        <i class="fa-regular fa-eye"></i>
                                    </button>
                                </div>

                                <div
                                    style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 22px;">
                                    <label
                                        style="display:flex; align-items:center; gap:8px; font-size:0.8rem; color:rgba(255,255,255,0.8); cursor:pointer;">
                                        <input type="checkbox" name="remember"
                                            style="accent-color:var(--emerald); width:16px; height:16px; cursor:pointer;"
                                            checked>
                                        Remember me
                                    </label>
                                    <a href="/portal/auth/forgot-password" class="forgot-link" style="margin:0;">Forgot
                                        Password?</a>
                                </div>

                                <button type="submit" class="btn-login">
                                    Log In &nbsp;<i class="fa-solid fa-arrow-right"></i>
                                </button>
                            </form>
        </div>

        <div class="card-footer">Emerald Pearland Events &mdash; Staff Management System</div>
    </div>

<script>
function togglePwd(id, btn) {
    const input = document.getElementById(id);
    const isHidden = input.type === 'password';
    input.type = isHidden ? 'text' : 'password';
    btn.querySelector('i').className = isHidden
        ? 'fa-regular fa-eye-slash'
        : 'fa-regular fa-eye';
}
</script>
</body>

</html>
