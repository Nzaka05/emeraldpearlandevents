
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Choose Portal - Emerald Pearland Events</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --bg1: #0f1117;
            --bg2: #181c24;
            --bg3: #1e2330;
            --tx1: #ffffff;
            --tx3: #8b93a5;
            --border: rgba(255,255,255,0.08);
            --gold: #d4af37;
            --emerald: #1a6b3c;
        }
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg1);
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 24px;
        }
        .choice-card {
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 40px 36px;
            max-width: 420px;
            width: 100%;
            text-align: center;
            box-shadow: 0 8px 40px rgba(0,0,0,0.4);
        }
        .choice-logo {
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--gold);
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 6px;
        }
        .choice-welcome {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--tx1);
            margin-bottom: 6px;
        }
        .choice-sub {
            font-size: 0.85rem;
            color: var(--tx3);
            margin-bottom: 32px;
        }
        .choice-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
            margin-bottom: 24px;
        }
        .choice-btn {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 24px 16px;
            border-radius: 14px;
            border: 1.5px solid var(--border);
            background: var(--bg3);
            color: var(--tx1);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: border-color 0.18s, background 0.18s, transform 0.15s;
        }
        .choice-btn:hover {
            border-color: var(--gold);
            background: rgba(212,175,55,0.07);
            transform: translateY(-2px);
            color: #fff;
            text-decoration: none;
        }
        .choice-btn .choice-icon {
            font-size: 2rem;
        }
        .choice-btn.admin-btn .choice-icon { color: var(--gold); }
        .choice-btn.staff-btn .choice-icon { color: var(--emerald); }
        .choice-divider {
            font-size: 0.75rem;
            color: #666;
            margin-bottom: 16px;
        }
        .choice-logout {
            font-size: 0.8rem;
            color: var(--tx3);
            text-decoration: none;
        }
        .choice-logout:hover { color: #e74c3c; }
    </style>
</head>
<body>
    <div class="choice-card">
        <div class="choice-logo">Emerald Pearland Events</div>
        <div class="choice-welcome">Welcome, <%= user && user.name ? user.name.split(' ')[0] : 'Admin' %>!</div>
        <div class="choice-sub">How would you like to log in today?</div>

        <div class="choice-grid">
            <a href="/portal/admin-staff/dashboard" class="choice-btn admin-btn">
                <span class="choice-icon"><i class="fa-solid fa-crown"></i></span>
                <span>Admin Panel</span>
                <span style="font-size:0.72rem;color:var(--tx3);font-weight:400;">Full access</span>
            </a>
            <a href="/portal/staff/dashboard" class="choice-btn staff-btn">
                <span class="choice-icon"><i class="fa-solid fa-user"></i></span>
                <span>Staff Portal</span>
                <span style="font-size:0.72rem;color:var(--tx3);font-weight:400;">My assignments</span>
            </a>
        </div>

        <div class="choice-divider">Logged in as <%= user && user.email ? user.email : '' %></div>
        <a href="/portal/auth/logout" class="choice-logout">
            <i class="fa-solid fa-right-from-bracket"></i> Log out
        </a>
    </div>
</body>
</html>
