
<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <i class="fa-solid fa-users" style="font-size: 2.5rem; color: var(--emerald); margin-bottom: 1rem;"></i>
            <h2>Forgot Password</h2>
            <p>Enter your email address to receive a reset link.</p>
        </div>

        <div class="auth-body">
            <% if (typeof error !=='undefined' && error) { %>
                <div class="alert alert-danger" style="color: #dc3545; text-align: center; margin-bottom: 1rem;">
                    <%= error %>
                </div>
                <% } %>
                    <% if (typeof message !=='undefined' && message) { %>
                        <div class="alert alert-success"
                            style="color: #28a745; text-align: center; margin-bottom: 1rem;">
                            <%= message %>
                        </div>
                        <% } %>

                            <form action="/portal/auth/forgot-password" method="POST">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <div class="form-group">
                                    <label>Email Address</label>
                                    <input type="email" name="email" required>
                                </div>

                                <button type="submit" class="btn btn-primary" style="width: 100%;">Send Reset
                                    Link</button>
                            </form>

                            <div style="text-align: center; margin-top: 1.5rem;">
                                <a href="/portal/auth/login" style="color: var(--emerald); text-decoration: none;">Back
                                    to
                                    Login</a>
                            </div>
        </div>
    </div>
</div>
