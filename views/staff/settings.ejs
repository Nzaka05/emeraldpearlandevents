<%- /* layout:layout */ '' %>
    <div class="settings-container">
        <div class="settings-header">
            <h1><i class="fa-solid fa-gear"></i> My Settings</h1>
            <p>Manage your profile and security settings</p>
        </div>

        <% if (typeof error !=='undefined' && error) { %>
            <div class="alert alert-error"><i class="fa-solid fa-circle-exclamation"></i>
                <%= error %>
            </div>
            <% } %>
                <% if (typeof message !=='undefined' && message) { %>
                    <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i>
                        <%= message %>
                    </div>
                    <% } %>

                        <div class="settings-grid">

                            <!-- SECTION: Update Profile -->
                            <div class="settings-card">
                                <div class="card-header">
                                    <i class="fa-solid fa-user-pen"></i>
                                    <h2>Update Profile</h2>
                                </div>
                                <form id="profileForm" action="/portal/staff/profile" method="POST">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                                    <div class="form-group">
                                        <label for="name">Full Name</label>
                                        <input type="text" id="name" name="name" value="<%= user.name %>" required
                                            minlength="2" maxlength="100">
                                    </div>

                                    <div class="form-group">
                                        <label for="phone">Phone Number</label>
                                        <input type="tel" id="phone" name="phone" value="<%= user.phone || '' %>"
                                            placeholder="+254 700 000 000">
                                    </div>

                                    <button type="submit" class="btn btn-primary">
                                        <i class="fa-solid fa-floppy-disk"></i> Save Profile
                                    </button>
                                </form>
                            </div>

                            <!-- SECTION: Change Password -->
                            <div class="settings-card">
                                <div class="card-header">
                                    <i class="fa-solid fa-lock"></i>
                                    <h2>Change Password</h2>
                                </div>
                                <form id="passwordForm">
                                    <input type="hidden" name="_csrf" id="staff_csrf" value="<%= csrfToken %>">

                                    <div class="form-group">
                                        <label for="current_password">Current Password</label>
                                        <div class="input-icon-wrap">
                                            <input type="password" id="current_password" name="current_password"
                                                required autocomplete="current-password">
                                            <button type="button" class="toggle-pw" data-target="current_password"
                                                aria-label="Toggle password visibility">
                                                <i class="fa-solid fa-eye"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label for="password">New Password</label>
                                        <div class="input-icon-wrap">
                                            <input type="password" id="password" name="password" required minlength="8"
                                                autocomplete="new-password" oninput="checkStrength(this.value)">
                                            <button type="button" class="toggle-pw" data-target="password"
                                                aria-label="Toggle password visibility">
                                                <i class="fa-solid fa-eye"></i>
                                            </button>
                                        </div>
                                        <!-- Password strength indicator -->
                                        <div class="strength-bar-wrap" id="strengthWrap" style="display:none;">
                                            <div class="strength-bar" id="strengthBar"></div>
                                        </div>
                                        <small class="strength-label" id="strengthLabel"></small>
                                    </div>

                                    <div class="form-group">
                                        <label for="confirm_password">Confirm New Password</label>
                                        <div class="input-icon-wrap">
                                            <input type="password" id="confirm_password" name="confirm_password"
                                                required minlength="8" autocomplete="new-password">
                                            <button type="button" class="toggle-pw" data-target="confirm_password"
                                                aria-label="Toggle password visibility">
                                                <i class="fa-solid fa-eye"></i>
                                            </button>
                                        </div>
                                        <small class="match-hint" id="matchHint"></small>
                                    </div>

                                    <button type="button" class="btn btn-primary" id="pwSubmitBtn" onclick="requestPasswordChangeOTP()">
                                        <i class="fa-solid fa-paper-plane"></i> Send OTP
                                    </button>
                                </form>
                            </div>

                        </div><!-- .settings-grid -->
    </div><!-- .settings-container -->

    <style>
        .settings-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
        }

        .settings-header {
            margin-bottom: 2rem;
        }

        .settings-header h1 {
            font-size: 1.6rem;
            color: #0a2f1c;
            margin: 0 0 0.3rem;
        }

        .settings-header p {
            color: #666;
            margin: 0;
        }

        .alert {
            padding: 0.85rem 1.2rem;
            border-radius: 8px;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .alert-error {
            background: #fff0f0;
            border: 1px solid #fcc;
            color: #c0392b;
        }

        .alert-success {
            background: #f0fff4;
            border: 1px solid #9ee;
            color: #1a7a4b;
        }

        .settings-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
            gap: 1.5rem;
        }

        .settings-card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
            padding: 1.8rem;
        }

        .card-header {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            margin-bottom: 1.5rem;
            border-bottom: 2px solid #f0f0f0;
            padding-bottom: 1rem;
        }

        .card-header i {
            font-size: 1.2rem;
            color: #2d8a5e;
        }

        .card-header h2 {
            font-size: 1.1rem;
            margin: 0;
            color: #0a2f1c;
        }

        .form-group {
            margin-bottom: 1.2rem;
        }

        .form-group label {
            display: block;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #555;
            margin-bottom: 0.4rem;
        }

        .form-group input {
            width: 100%;
            padding: 0.65rem 0.9rem;
            border: 1.5px solid #ddd;
            border-radius: 8px;
            font-size: 0.95rem;
            transition: border-color 0.2s;
            box-sizing: border-box;
        }

        .form-group input:focus {
            outline: none;
            border-color: #2d8a5e;
            box-shadow: 0 0 0 3px rgba(45, 138, 94, 0.1);
        }

        .input-icon-wrap {
            position: relative;
        }

        .input-icon-wrap input {
            padding-right: 2.6rem;
        }

        .toggle-pw {
            position: absolute;
            right: 0.7rem;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: #888;
            padding: 0;
            font-size: 0.9rem;
        }

        .toggle-pw:hover {
            color: #2d8a5e;
        }

        .strength-bar-wrap {
            height: 5px;
            background: #eee;
            border-radius: 4px;
            margin-top: 0.5rem;
            overflow: hidden;
        }

        .strength-bar {
            height: 100%;
            width: 0;
            border-radius: 4px;
            transition: width 0.3s, background 0.3s;
        }

        .strength-label {
            font-size: 0.75rem;
            color: #888;
            display: block;
            margin-top: 0.25rem;
        }

        .match-hint {
            font-size: 0.75rem;
            display: block;
            margin-top: 0.25rem;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.7rem 1.4rem;
            border: none;
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.15s;
            margin-top: 0.5rem;
        }

        .btn:hover {
            opacity: 0.88;
            transform: translateY(-1px);
        }

        .btn:active {
            transform: translateY(0);
        }

        .btn-primary {
            background: linear-gradient(135deg, #0a2f1c 0%, #2d8a5e 100%);
            color: #fff;
        }

        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* ── OTP Verification Modal ── */
        .otp-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(5px);
            z-index: 10000;
            justify-content: center;
            align-items: center;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        .otp-modal.active {
            display: flex;
            opacity: 1;
        }
        .otp-modal-content {
            background: #fff;
            border: 1px solid #2d8a5e;
            border-radius: 12px;
            width: 90%;
            max-width: 420px;
            padding: 32px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
            transform: scale(0.9);
            transition: transform 0.3s ease;
            text-align: center;
        }
        .otp-modal.active .otp-modal-content {
            transform: scale(1);
        }
        .otp-modal-header {
            margin-bottom: 20px;
        }
        .otp-modal-icon {
            font-size: 40px;
            color: #2d8a5e;
            margin-bottom: 12px;
        }
        .otp-modal-title {
            font-size: 20px;
            font-weight: 700;
            color: #0a2f1c;
            margin: 0;
        }
        .otp-modal-desc {
            font-size: 14px;
            color: #666;
            line-height: 1.5;
            margin-top: 8px;
        }
        .otp-input-wrap {
            display: flex;
            justify-content: space-between;
            gap: 8px;
            margin: 24px 0;
        }
        .otp-input-field {
            width: 48px;
            height: 48px;
            border: 2.5px solid #ddd;
            border-radius: 8px;
            font-size: 20px;
            font-weight: 700;
            text-align: center;
            font-family: monospace;
            background: #f9f9f9;
            color: #333;
            transition: all 0.2s;
        }
        .otp-input-field:focus {
            outline: none;
            border-color: #2d8a5e;
            box-shadow: 0 0 0 3px rgba(45, 138, 94, 0.15);
        }
        .otp-modal-buttons {
            display: flex;
            gap: 12px;
            margin-top: 24px;
        }
        .otp-btn-submit {
            flex: 1;
            padding: 12px;
            background: linear-gradient(135deg, #0a2f1c 0%, #2d8a5e 100%);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }
        .otp-btn-submit:hover {
            opacity: 0.9;
        }
        .otp-btn-cancel {
            flex: 1;
            padding: 12px;
            background: transparent;
            color: #666;
            border: 1.5px solid #ddd;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }
        .otp-btn-cancel:hover {
            border-color: #999;
            color: #333;
        }
        .error-message {
            background: #fff0f0;
            border: 1px solid #fcc;
            color: #c0392b;
            padding: 0.85rem 1.2rem;
            border-radius: 8px;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
            text-align: left;
        }
    </style>

    <!-- OTP Verification Modal -->
    <div id="otpModal" class="otp-modal">
        <div class="otp-modal-content">
            <div class="otp-modal-header">
                <div class="otp-modal-icon"><i class="fa-solid fa-key"></i></div>
                <h3 class="otp-modal-title">Enter Verification Code</h3>
                <p class="otp-modal-desc">We've sent a 6-digit OTP code to your email to verify this password change request.</p>
            </div>
            <div id="otpModalErrorMessage" class="error-message" style="margin-bottom: 16px; display: none;"></div>
            <div class="otp-input-wrap">
                <input type="text" class="otp-input-field" maxlength="1" pattern="[0-9]" inputmode="numeric" required>
                <input type="text" class="otp-input-field" maxlength="1" pattern="[0-9]" inputmode="numeric" required>
                <input type="text" class="otp-input-field" maxlength="1" pattern="[0-9]" inputmode="numeric" required>
                <input type="text" class="otp-input-field" maxlength="1" pattern="[0-9]" inputmode="numeric" required>
                <input type="text" class="otp-input-field" maxlength="1" pattern="[0-9]" inputmode="numeric" required>
                <input type="text" class="otp-input-field" maxlength="1" pattern="[0-9]" inputmode="numeric" required>
            </div>
            <div class="otp-modal-buttons">
                <button type="button" class="otp-btn-cancel" onclick="closeOtpModal()">Cancel</button>
                <button type="button" class="otp-btn-submit" onclick="submitOtpAndChangePassword()" id="otpSubmitBtn">Verify & Change</button>
            </div>
        </div>
    </div>

    <script>
        // Password strength checker
        function checkStrength(val) {
            const wrap = document.getElementById('strengthWrap');
            const bar = document.getElementById('strengthBar');
            const lbl = document.getElementById('strengthLabel');
            if (!val) { wrap.style.display = 'none'; return; }
            wrap.style.display = 'block';

            let score = 0;
            if (val.length >= 8) score++;
            if (val.length >= 12) score++;
            if (/[A-Z]/.test(val)) score++;
            if (/[0-9]/.test(val)) score++;
            if (/[^A-Za-z0-9]/.test(val)) score++;

            const levels = [
                { pct: '20%', color: '#e74c3c', text: 'Very Weak' },
                { pct: '40%', color: '#e67e22', text: 'Weak' },
                { pct: '60%', color: '#f1c40f', text: 'Fair' },
                { pct: '80%', color: '#2ecc71', text: 'Strong' },
                { pct: '100%', color: '#27ae60', text: 'Very Strong' }
            ];
            const lvl = levels[Math.min(score - 1, 4)] || levels[0];
            bar.style.width = lvl.pct;
            bar.style.background = lvl.color;
            lbl.textContent = lvl.text;
            lbl.style.color = lvl.color;
        }

        // Password match checker
        document.getElementById('confirm_password').addEventListener('input', function () {
            const pw = document.getElementById('password').value;
            const hint = document.getElementById('matchHint');
            if (!this.value) { hint.textContent = ''; return; }
            if (this.value === pw) {
                hint.textContent = '✓ Passwords match';
                hint.style.color = '#2ecc71';
            } else {
                hint.textContent = '✗ Passwords do not match';
                hint.style.color = '#e74c3c';
            }
        });

        // Toggle password visibility
        document.querySelectorAll('.toggle-pw').forEach(btn => {
            btn.addEventListener('click', function () {
                const inp = document.getElementById(this.dataset.target);
                const icon = this.querySelector('i');
                if (inp.type === 'password') {
                    inp.type = 'text';
                    icon.classList.replace('fa-eye', 'fa-eye-slash');
                } else {
                    inp.type = 'password';
                    icon.classList.replace('fa-eye-slash', 'fa-eye');
                }
            });
        });

        async function requestPasswordChangeOTP() {
            const currentPassword = document.getElementById('current_password').value.trim();
            const newPassword = document.getElementById('password').value.trim();
            const confirmPassword = document.getElementById('confirm_password').value.trim();
            const btn = document.getElementById('pwSubmitBtn');

            // Validation
            if (!currentPassword) {
                showFlash('Please enter your current password', 'error');
                return;
            }

            if (!newPassword) {
                showFlash('Please enter a new password', 'error');
                return;
            }

            if (newPassword.length < 8) {
                showFlash('Password must be at least 8 characters long', 'error');
                return;
            }

            if (newPassword !== confirmPassword) {
                showFlash('Passwords do not match', 'error');
                return;
            }

            if (currentPassword === newPassword) {
                showFlash('New password must be different from current password', 'error');
                return;
            }

            try {
                btn.disabled = true;
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Sending...';

                const csrfToken = document.getElementById('staff_csrf').value;
                const response = await fetch('/api/auth/password/request-otp', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': csrfToken || ''
                    },
                    credentials: 'include',
                    body: JSON.stringify({ currentPassword, newPassword })
                });

                const data = await response.json();

                if (!response.ok || !data.success) {
                    showFlash(data.message || 'Failed to send OTP code', 'error');
                    return;
                }

                // Open Modal
                openOtpModal();
            } catch (error) {
                showFlash('Network error. Please try again.', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Send OTP';
            }
        }

        function openOtpModal() {
            const modal = document.getElementById('otpModal');
            modal.style.display = 'flex';
            setTimeout(() => modal.classList.add('active'), 10);
            
            // Focus on first input
            const firstInput = document.querySelector('.otp-input-field');
            if (firstInput) {
                firstInput.focus();
            }

            // Clear any old values and errors
            document.querySelectorAll('.otp-input-field').forEach(inp => inp.value = '');
            document.getElementById('otpModalErrorMessage').style.display = 'none';
        }

        function closeOtpModal() {
            const modal = document.getElementById('otpModal');
            modal.classList.remove('active');
            setTimeout(() => modal.style.display = 'none', 300);
        }

        async function submitOtpAndChangePassword() {
            const currentPassword = document.getElementById('current_password').value.trim();
            const newPassword = document.getElementById('password').value.trim();
            const modalErrorMsg = document.getElementById('otpModalErrorMessage');
            const submitBtn = document.getElementById('otpSubmitBtn');

            modalErrorMsg.style.display = 'none';

            const otpFields = document.querySelectorAll('.otp-input-field');
            const otp = Array.from(otpFields).map(inp => inp.value).join('');

            if (otp.length < 6) {
                modalErrorMsg.textContent = '❌ Please enter the full 6-digit code';
                modalErrorMsg.style.display = 'block';
                return;
            }

            try {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Verifying...';

                const csrfToken = document.getElementById('staff_csrf').value;
                const response = await fetch('/api/auth/password/verify-and-change', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': csrfToken || ''
                    },
                    credentials: 'include',
                    body: JSON.stringify({ currentPassword, newPassword, otp })
                });

                const data = await response.json();

                if (!response.ok || !data.success) {
                    modalErrorMsg.textContent = '❌ ' + (data.message || 'Verification failed');
                    modalErrorMsg.style.display = 'block';
                    return;
                }

                // Success
                closeOtpModal();
                showFlash(data.message || 'Password changed successfully!', 'success');

                // Reset form
                document.getElementById('current_password').value = '';
                document.getElementById('password').value = '';
                document.getElementById('confirm_password').value = '';
                document.getElementById('strengthWrap').style.display = 'none';
                document.getElementById('strengthLabel').textContent = '';
                document.getElementById('matchHint').textContent = '';

            } catch (error) {
                modalErrorMsg.textContent = '❌ Network error. Please try again.';
                modalErrorMsg.style.display = 'block';
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Verify & Change';
            }
        }

        // Setup OTP inputs auto-focus behavior
        document.addEventListener('DOMContentLoaded', () => {
            const otpInputs = document.querySelectorAll('.otp-input-field');
            otpInputs.forEach((input, index) => {
                input.addEventListener('input', (e) => {
                    const val = e.target.value;
                    e.target.value = val.replace(/[^0-9]/g, '');
                    if (e.target.value && index < otpInputs.length - 1) {
                        otpInputs[index + 1].focus();
                    }
                });

                input.addEventListener('keydown', (e) => {
                    if (e.key === 'Backspace' && !e.target.value && index > 0) {
                        otpInputs[index - 1].focus();
                    }
                });
            });
        });

        // CSRF-aware fetch (already in layout.ejs global interceptor)
        // Profile form — POST via fetch for smooth UX
        document.getElementById('profileForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const btn = this.querySelector('button[type="submit"]');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';

            const formData = new FormData(this);
            const body = Object.fromEntries(formData.entries());

            try {
                const res = await fetch('/portal/staff/profile', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                const data = await res.json();
                if (data.success) {
                    showFlash('Profile updated successfully!', 'success');
                } else {
                    showFlash(data.message || 'Failed to update profile.', 'error');
                }
            } catch (err) {
                showFlash('Network error. Please try again.', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Save Profile';
            }
        });

        function showFlash(msg, type) {
            let el = document.querySelector('.alert');
            if (!el) {
                el = document.createElement('div');
                document.querySelector('.settings-container').prepend(el);
            }
            el.className = `alert alert-${type}`;
            el.innerHTML = `<i class="fa-solid fa-${type === 'success' ? 'circle-check' : 'circle-exclamation'}"></i> ${msg}`;
            el.scrollIntoView({ behavior: 'smooth', block: 'center' });
            setTimeout(() => { el.style.opacity = '0'; el.style.transition = 'opacity 0.5s'; setTimeout(() => el.remove(), 500); }, 4000);
        }
    </script>