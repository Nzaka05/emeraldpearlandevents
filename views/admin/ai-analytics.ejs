<!-- AI Analytics Dashboard -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<style>
    :root {
        --aa-bg: #f8fafb;
        --aa-card: #ffffff;
        --aa-text: #1e293b;
        --aa-muted: #64748b;
        --aa-border: #e2e8f0;
        --aa-emerald: #0a2f1c;
        --aa-emerald-light: #10b981;
        --aa-gold: #d4af37;
        --aa-green: #22c55e;
        --aa-amber: #f59e0b;
        --aa-red: #ef4444;
    }

    .aa-page { padding: 24px; background: var(--aa-bg); min-height: 100vh; font-family: 'Inter', sans-serif; }
    .aa-page h1 { font-size: 1.8rem; color: var(--aa-emerald); margin: 0 0 4px 0; }
    .aa-page .subtitle { color: var(--aa-muted); margin: 0 0 24px 0; font-size: 0.9rem; }

    .aa-card {
        background: var(--aa-card); border: 1px solid var(--aa-border); border-radius: 16px;
        padding: 24px; margin-bottom: 24px; box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    }
    .aa-card h3 { margin: 0 0 16px 0; font-size: 1.1rem; color: var(--aa-emerald); display: flex; align-items: center; gap: 8px; }
    .aa-card h3 i { color: var(--aa-gold); }

    .aa-stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin-bottom: 24px; }
    .aa-stat {
        background: var(--aa-card); border: 1px solid var(--aa-border); border-radius: 12px;
        padding: 20px; text-align: center;
    }
    .aa-stat .num { font-size: 2rem; font-weight: 800; color: var(--aa-emerald); }
    .aa-stat .lbl { font-size: 0.8rem; color: var(--aa-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px; }

    .aa-chart-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    @media (max-width: 1024px) { .aa-chart-grid { grid-template-columns: 1fr; } }

    .aa-chart-container { position: relative; height: 300px; }

    .aa-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .aa-table th { text-align: left; padding: 10px 12px; border-bottom: 2px solid var(--aa-border); color: var(--aa-muted); font-size: 0.75rem; text-transform: uppercase; }
    .aa-table td { padding: 10px 12px; border-bottom: 1px solid var(--aa-border); }
    .aa-table tr:hover { background: #f0fdf4; }

    .badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 0.7rem; font-weight: 700; }
    .badge-green { background: #d1fae5; color: #065f46; }
    .badge-red { background: #fee2e2; color: #991b1b; }
    .badge-amber { background: #fef3c7; color: #92400e; }

    .loading-block { text-align: center; padding: 40px; color: var(--aa-muted); }
</style>

<div class="aa-page">
    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
        <div>
            <h1><i class="fa-solid fa-chart-line" style="color: var(--aa-gold);"></i> AI Analytics</h1>
            <p class="subtitle">Track how the AI learning system evolves over time</p>
        </div>
        <a href="/portal/admin-staff/ai/command-center" style="text-decoration:none; padding: 10px 20px; background: var(--aa-emerald); color: white; border-radius: 12px; font-weight: 600; font-size: 0.9rem;">
            <i class="fa-solid fa-brain"></i> Command Center
        </a>
    </div>

    <!-- Summary Stats (populated dynamically) -->
    <div class="aa-stats-grid" id="statsGrid">
        <div class="aa-stat"><div class="num" id="stat-processed">—</div><div class="lbl">Events Processed</div></div>
        <div class="aa-stat"><div class="num" id="stat-insights">—</div><div class="lbl">Total Insights</div></div>
        <div class="aa-stat"><div class="num" id="stat-confidence">—</div><div class="lbl">Avg Confidence</div></div>
        <div class="aa-stat"><div class="num" id="stat-samples">—</div><div class="lbl">Total Samples</div></div>
        <div class="aa-stat"><div class="num" id="stat-accurate">—</div><div class="lbl">Accurate Feedback</div></div>
        <div class="aa-stat"><div class="num" id="stat-inaccurate">—</div><div class="lbl">Inaccurate Feedback</div></div>
    </div>

    <!-- Charts -->
    <div class="aa-chart-grid">
        <div class="aa-card">
            <h3><i class="fa-solid fa-chart-bar"></i> Predicted vs Actual (by Event Type)</h3>
            <div class="aa-chart-container"><canvas id="predVsActualChart"></canvas></div>
        </div>
        <div class="aa-card">
            <h3><i class="fa-solid fa-wave-square"></i> Confidence by Insight</h3>
            <div class="aa-chart-container"><canvas id="confidenceChart"></canvas></div>
        </div>
        <div class="aa-card">
            <h3><i class="fa-solid fa-chart-pie"></i> Insights by Type</h3>
            <div class="aa-chart-container"><canvas id="insightTypePie"></canvas></div>
        </div>
        <div class="aa-card">
            <h3><i class="fa-solid fa-timeline"></i> Learning Growth (Sample Size)</h3>
            <div class="aa-chart-container"><canvas id="growthChart"></canvas></div>
        </div>
    </div>

    <!-- Recent Training Logs -->
    <div class="aa-card">
        <h3><i class="fa-solid fa-list-check"></i> Recent Training Logs</h3>
        <div id="trainingLogsTable">
            <div class="loading-block"><span class="loading-spinner" style="display:inline-block;width:24px;height:24px;border:3px solid #e5e7eb;border-top-color:#0a2f1c;border-radius:50%;animation:spin .6s linear infinite;"></span><p>Loading analytics data...</p></div>
        </div>
    </div>
</div>

<script>
    let analyticsData = null;

    async function loadAnalytics() {
        try {
            const res = await fetch('/portal/admin-staff/ai/analytics');
            const json = await res.json();
            if (!json.success) throw new Error(json.message);
            analyticsData = json.data;
            renderStats();
            renderCharts();
            renderTrainingLogs();
        } catch (e) {
            console.error('Failed to load analytics:', e);
            document.getElementById('trainingLogsTable').innerHTML = `<p style="color:var(--aa-red); text-align:center;">Failed to load analytics: ${e.message}</p>`;
        }
    }

    function renderStats() {
        const s = analyticsData.summary;
        document.getElementById('stat-processed').textContent = s.eventsProcessed;
        document.getElementById('stat-insights').textContent = s.totalInsights;
        document.getElementById('stat-confidence').textContent = s.avgConfidence + '%';
        document.getElementById('stat-samples').textContent = s.totalSampleSize;
        document.getElementById('stat-accurate').textContent = s.feedbackAccurate;
        document.getElementById('stat-inaccurate').textContent = s.feedbackInaccurate;
    }

    function renderCharts() {
        // 1. Predicted vs Actual Bar Chart
        const pva = analyticsData.predVsActual || [];
        new Chart(document.getElementById('predVsActualChart'), {
            type: 'bar',
            data: {
                labels: pva.map(d => d.eventType),
                datasets: [
                    { label: 'Avg Staff', data: pva.map(d => Math.round(d.avgStaffCount * 10) / 10), backgroundColor: '#10b981' },
                    { label: 'Avg Cost (K)', data: pva.map(d => Math.round(d.avgCost / 1000)), backgroundColor: '#d4af37' },
                    { label: 'Avg Profit (K)', data: pva.map(d => Math.round(d.avgProfit / 1000)), backgroundColor: '#0a2f1c' }
                ]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
        });

        // 2. Confidence Chart
        const ct = analyticsData.confidenceTrend || [];
        new Chart(document.getElementById('confidenceChart'), {
            type: 'bar',
            data: {
                labels: ct.map(d => `${d.type}: ${d.reference_id}`.substring(0, 20)),
                datasets: [{
                    label: 'Confidence %',
                    data: ct.map(d => d.confidence),
                    backgroundColor: ct.map(d => d.confidence > 60 ? '#22c55e' : (d.confidence > 30 ? '#f59e0b' : '#ef4444'))
                }]
            },
            options: { responsive: true, maintainAspectRatio: false, indexAxis: 'y', plugins: { legend: { display: false } } }
        });

        // 3. Insights by Type Pie
        const types = analyticsData.insightsByType || {};
        const typeLabels = Object.keys(types);
        const typeCounts = typeLabels.map(t => types[t].length);
        new Chart(document.getElementById('insightTypePie'), {
            type: 'doughnut',
            data: {
                labels: typeLabels,
                datasets: [{
                    data: typeCounts,
                    backgroundColor: ['#0a2f1c', '#10b981', '#d4af37', '#f59e0b', '#ef4444']
                }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
        });

        // 4. Growth Chart (sample sizes)
        new Chart(document.getElementById('growthChart'), {
            type: 'line',
            data: {
                labels: ct.map(d => `${d.reference_id}`.substring(0, 15)),
                datasets: [{
                    label: 'Sample Size',
                    data: ct.map(d => d.sample_size),
                    borderColor: '#0a2f1c',
                    backgroundColor: 'rgba(10, 47, 28, 0.1)',
                    fill: true,
                    tension: 0.4
                }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
        });
    }

    function renderTrainingLogs() {
        const logs = analyticsData.recentTrainingLogs || [];
        if (logs.length === 0) {
            document.getElementById('trainingLogsTable').innerHTML = '<p style="color:var(--aa-muted); text-align:center;">No training logs yet. Events need to complete first.</p>';
            return;
        }
        let html = `<table class="aa-table"><thead><tr><th>Event ID</th><th>Status</th><th>Processed At</th></tr></thead><tbody>`;
        logs.forEach(l => {
            const badge = l.status === 'Success' ? 'badge-green' : (l.status === 'Failed' ? 'badge-red' : 'badge-amber');
            html += `<tr><td style="font-family:monospace; font-size:0.8rem;">${l.event_id}</td><td><span class="badge ${badge}">${l.status}</span></td><td>${l.processed_at ? new Date(l.processed_at).toLocaleString() : '—'}</td></tr>`;
        });
        html += '</tbody></table>';
        document.getElementById('trainingLogsTable').innerHTML = html;
    }

    // Load on page ready
    loadAnalytics();
</script>

<style>
    @keyframes spin { to { transform: rotate(360deg); } }
    .loading-spinner { display: inline-block; width: 18px; height: 18px; border: 3px solid #e5e7eb; border-top-color: #0a2f1c; border-radius: 50%; animation: spin 0.6s linear infinite; }
</style>
