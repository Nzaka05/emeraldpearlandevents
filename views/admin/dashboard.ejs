<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <h2>Admin Overview</h2>
    <button class="btn btn-primary" style="width: auto; padding: 8px 16px; font-size: 0.9rem;"
        onclick="document.getElementById('newAssignModal').style.display='block'">
        <i class="fa-solid fa-plus"></i> Assignment
    </button>
</div>

<!-- Staffing Alert Toast Container -->
<div id="staffingAlertContainer" style="position:fixed;top:16px;right:16px;z-index:300;max-width:380px;"></div>

<div class="metrics-grid">
    <div class="metric-card">
        <div class="metric-value" id="val-total-staff"><%= metrics.totalStaff %></div>
        <div class="metric-label">Total Staff</div>
    </div>
    <div class="metric-card" style="border-bottom: 4px solid var(--success);">
        <div class="metric-value" id="val-avail-staff" style="color: var(--success);"><%= metrics.availableStaff %></div>
        <div class="metric-label">Available Now</div>
    </div>
    <div class="metric-card" style="border-bottom: 4px solid var(--vip-color);">
        <div class="metric-value" id="val-busy-staff" style="color: var(--vip-color);"><%= metrics.busyStaff %></div>
        <div class="metric-label">Busy / Shift</div>
    </div>
    <div class="metric-card">
        <div class="metric-value" id="val-active-assign"><%= metrics.activeAssignments %></div>
        <div class="metric-label">Active Events</div>
    </div>
</div>

<div class="card" style="margin-bottom: 24px;">
    <div class="card-title">All Assignments & Payment Status</div>
    <div style="overflow-x: auto;">
        <table style="width: 100%; text-align: left; border-collapse: collapse; font-size: 0.9rem;">
            <thead>
                <tr style="border-bottom: 2px solid #e2e8f0;">
                    <th style="padding: 12px 8px;">Title</th>
                    <th style="padding: 12px 8px;">Date</th>
                    <th style="padding: 12px 8px;">Location</th>
                    <th style="padding: 12px 8px;">Pay</th>
                    <th style="padding: 12px 8px;">Status</th>
                    <th style="padding: 12px 8px;">Payment</th>
                    <th style="padding: 12px 8px; text-align: center;">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if(assignments && assignments.length > 0) { %>
                    <% assignments.forEach(function(assignment) { %>
                        <tr style="border-bottom: 1px solid #f1f5f9;">
                            <td style="padding: 12px 8px; font-weight: 500;"><%= assignment.title %> <%= assignment.vip_flag ? '⭐' : '' %></td>
                            <td style="padding: 12px 8px;"><%= new Date(assignment.date).toLocaleDateString() %></td>
                            <td style="padding: 12px 8px;"><%= assignment.location %></td>
                            <td style="padding: 12px 8px;">$<%= assignment.pay_rate %></td>
                            <td style="padding: 12px 8px;">
                                <span class="badge <%= assignment.status === 'Active' ? 'badge-success' : 'badge-warning' %>"><%= assignment.status %></span>
                            </td>
                            <td style="padding: 12px 8px;">
                                <select onchange="updatePaymentStatus('<%= assignment._id %>', this.value)" style="padding: 4px; border-radius: 4px; border: 1px solid #cbd5e1; font-size: 0.85rem;">
                                    <option value="Pending" <%=assignment.payment_status==='Pending' ? 'selected' : '' %>>Pending</option>
                                    <option value="Sent" <%=assignment.payment_status==='Sent' ? 'selected' : '' %>>Sent</option>
                                    <option value="Received" <%=assignment.payment_status==='Received' ? 'selected' : '' %>>Received</option>
                                    <option value="Disputed" <%=assignment.payment_status==='Disputed' ? 'selected' : '' %> style="color:red;">Disputed</option>
                                </select>
                            </td>
                            <td style="padding: 12px 8px; text-align: center;">
                                <div style="display:flex;gap:4px;justify-content:center;">
                                    <button class="btn btn-outline" style="padding:4px 8px;font-size:0.75rem;width:auto;" onclick="openEditAssignment('<%= assignment._id %>','<%= assignment.title %>','<%= assignment.location %>','<%= new Date(assignment.date).toISOString().split('T')[0] %>','<%= assignment.start_time %>','<%= assignment.end_time %>','<%= assignment.pay_rate %>','<%= assignment.vip_flag %>','<%= (assignment.special_instructions||'').replace(/'/g,'') %>','<%= (assignment.dress_code||'').replace(/'/g,'') %>')"><i class="fa-solid fa-pencil"></i></button>
                                    <button class="btn btn-outline" style="padding:4px 8px;font-size:0.75rem;width:auto;" onclick="viewEventReport('<%= assignment._id %>')"><i class="fa-solid fa-file-invoice"></i></button>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="7" style="padding: 16px; text-align: center; color: var(--text-secondary);">No assignments yet.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Payment History Section -->
<div class="card" style="margin-bottom:24px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
        <div class="card-title" style="margin-bottom:0;"><i class="fa-solid fa-sack-dollar" style="color:#10b981;"></i> Payment Log</div>
        <div style="display:flex;gap:8px;">
            <a href="/admin/export/payments?format=csv" class="btn btn-outline" style="width:auto;padding:4px 12px;font-size:0.8rem;text-decoration:none;"><i class="fa-solid fa-file-csv"></i> Export CSV</a>
            <button class="btn btn-outline" style="width:auto;padding:4px 12px;font-size:0.8rem;" onclick="loadPaymentLog()"><i class="fa-solid fa-rotate"></i> Load</button>
        </div>
    </div>
    <div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;">
        <select id="payFilterStatus" style="padding:6px;border-radius:6px;border:1px solid #cbd5e1;font-size:0.85rem;">
            <option value="">All Statuses</option>
            <option value="Pending">Pending</option>
            <option value="Sent">Sent</option>
            <option value="Received">Received</option>
            <option value="Disputed">Disputed</option>
        </select>
        <input type="date" id="payFilterStart" style="padding:6px;border-radius:6px;border:1px solid #cbd5e1;font-size:0.85rem;" placeholder="Start Date">
        <input type="date" id="payFilterEnd" style="padding:6px;border-radius:6px;border:1px solid #cbd5e1;font-size:0.85rem;" placeholder="End Date">
    </div>
    <div id="paymentLogPanel" style="max-height:300px;overflow-y:auto;font-size:0.85rem;">
        <p style="color:var(--text-secondary);text-align:center;padding:16px;">Click Load to view payment records.</p>
    </div>
</div>

<div class="card">
    <div class="card-title">Live Updates Board <div class="pulse" style="width: 10px; height: 10px; background: var(--success); border-radius: 50%; display: inline-block;"></div></div>
    <div id="liveFeed" style="max-height: 250px; overflow-y: auto; font-size: 0.9rem;">
        <p style="color: var(--text-secondary); padding: 8px;">Waiting for real-time updates...</p>
    </div>
</div>

<!-- Live Arrivals Verification Panel -->
<div class="card" style="margin-top:16px;border-left:4px solid #2563eb;">
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
        <div class="card-title" style="margin-bottom:0;"><i class="fa-solid fa-location-crosshairs" style="color:#2563eb;"></i> Live Arrivals Verification</div>
        <div class="pulse" style="width:10px;height:10px;background:#22c55e;border-radius:50%;display:inline-block;"></div>
    </div>
    <div id="liveArrivalsPanel" style="display:flex;flex-wrap:wrap;gap:12px;">
        <p style="color:var(--text-secondary);width:100%;text-align:center;padding:16px;">
            <i class="fa-solid fa-satellite-dish" style="font-size:1.5rem;color:#cbd5e1;"></i><br>
            Waiting for staff clock-ins...
        </p>
    </div>
</div>

</div>

<!-- Staff Management Panel -->
<div class="card" style="margin-bottom: 24px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
        <div class="card-title" style="margin-bottom:0;">Staff Management</div>
        <button class="btn btn-outline" style="width:auto;padding:6px 14px;font-size:0.9rem;" onclick="loadStaffPanel()">
            <i class="fa-solid fa-rotate"></i> Refresh
        </button>
    </div>
    <div id="staffPanel">
        <p style="color:var(--text-secondary);text-align:center;padding:16px;">Click Refresh to load staff list.</p>
    </div>
</div>

<!-- Audit Logs -->
<div class="card" style="margin-bottom:24px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
        <div class="card-title" style="margin-bottom:0;"><i class="fa-solid fa-shield-halved" style="color:var(--primary-color);"></i> Security & Audit Logs</div>
        <button class="btn btn-outline" style="width:auto;padding:6px 14px;font-size:0.9rem;" onclick="loadAuditLogs()">
            <i class="fa-solid fa-rotate"></i> Load Logs
        </button>
    </div>
    <div id="auditLogsPanel" style="max-height:300px;overflow-y:auto;font-size:0.85rem;">
        <p style="color:var(--text-secondary);padding:8px;">Click Load Logs to view security & audit trail.</p>
    </div>
</div>

<div class="card">
    <div class="card-title">Quick Actions</div>
    <button class="btn btn-outline" style="margin-bottom: 12px; justify-content: flex-start;" onclick="document.getElementById('addStaffModal').style.display='block'">
        <i class="fa-solid fa-user-plus" style="color: var(--primary-color);"></i> Provision New Staff Account
    </button>
</div>

<div class="card" style="margin-bottom: 24px;">
    <div class="card-title" style="color: var(--danger);">Pending Replacement Requests</div>
    <div style="overflow-x: auto;">
        <table style="width: 100%; text-align: left; border-collapse: collapse; font-size: 0.9rem;">
            <thead>
                <tr style="border-bottom: 2px solid #e2e8f0;">
                    <th style="padding: 12px 8px;">Event</th>
                    <th style="padding: 12px 8px;">By</th>
                    <th style="padding: 12px 8px;">Remove</th>
                    <th style="padding: 12px 8px;">Replace</th>
                    <th style="padding: 12px 8px;">Reason</th>
                    <th style="padding: 12px 8px; text-align: center;">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if(pendingReplacements && pendingReplacements.length > 0) { %>
                    <% pendingReplacements.forEach(function(req) { %>
                        <tr style="border-bottom: 1px solid #f1f5f9;">
                            <td style="padding:12px 8px;font-weight:500;"><%= req.event_id ? req.event_id.title : 'Unknown' %></td>
                            <td style="padding:12px 8px;"><%= req.submitted_by ? req.submitted_by.name : 'Unknown' %></td>
                            <td style="padding:12px 8px;color:var(--danger);"><%= req.member_to_remove ? req.member_to_remove.name : '' %></td>
                            <td style="padding:12px 8px;color:var(--success);"><%= req.suggested_replacement ? req.suggested_replacement.name : 'None' %></td>
                            <td style="padding:12px 8px;font-style:italic;max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= req.reason %></td>
                            <td style="padding:12px 8px;text-align:center;">
                                <div style="display:flex;gap:8px;justify-content:center;">
                                    <button class="btn btn-primary" style="padding:4px 12px;font-size:0.8rem;width:auto;" onclick="processReplacement('<%= req._id %>','approve')">Approve</button>
                                    <button class="btn btn-outline" style="padding:4px 12px;font-size:0.8rem;width:auto;border-color:var(--danger);color:var(--danger);" onclick="processReplacement('<%= req._id %>','reject')">Reject</button>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="6" style="padding:16px;text-align:center;color:var(--text-secondary);">No pending requests.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal: Add Staff -->
<div id="addStaffModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:100;overflow-y:auto;padding:20px 0;">
    <div style="background:white;max-width:500px;margin:0 auto;padding:24px;border-radius:12px;position:relative;">
        <button onclick="document.getElementById('addStaffModal').style.display='none'" style="position:absolute;right:16px;top:16px;background:none;border:none;font-size:1.5rem;cursor:pointer;">&times;</button>
        <h3 style="margin-bottom:16px;">Provision Staff Account</h3>
        <form id="addStaffForm" onsubmit="submitStaff(event)" enctype="multipart/form-data">
            <div class="form-group"><label>Full Name *</label><input type="text" name="name" required></div>
            <div class="form-group"><label>Email *</label><input type="email" name="email" required></div>
            <div class="form-group"><label>Phone</label><input type="tel" name="phone" placeholder="+254 722 446 937"></div>
            <div class="form-group"><label>Role</label>
                <select name="role"><option>Staff</option><option>Supervisor</option><option>Admin</option></select>
            </div>
            <div class="form-group"><label>Department</label><input type="text" name="department" placeholder="Events, Security, Catering..."></div>
            <div class="form-group"><label>Skills (comma-separated)</label><input type="text" name="skills" placeholder="bartending, setup, hosting, VIP care"></div>
            <div style="display:flex;gap:12px;">
                <div class="form-group" style="flex:1;"><label>Shift Start</label><input type="time" name="shift_start"></div>
                <div class="form-group" style="flex:1;"><label>Shift End</label><input type="time" name="shift_end"></div>
            </div>
            <div class="form-group"><label>Profile Photo</label><input type="file" name="photo" accept="image/jpeg,image/png,image/webp" style="padding:8px;"></div>
            <button type="submit" class="btn btn-primary">Create Account & Send Credentials</button>
        </form>
        <div id="staffCreds" style="display:none;margin-top:16px;padding:12px;background:#d1fae5;border-radius:8px;"></div>
    </div>
</div>

<!-- Modal: Create Assignment -->
<div id="newAssignModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:100;overflow-y:auto;padding:20px 0;">
    <div style="background:white;max-width:500px;margin:0 auto;padding:24px;border-radius:12px;position:relative;">
        <button onclick="document.getElementById('newAssignModal').style.display='none'" style="position:absolute;right:16px;top:16px;background:none;border:none;font-size:1.5rem;cursor:pointer;">&times;</button>
        <h3 style="margin-bottom:16px;">Create Event Assignment</h3>
        <form id="assignForm" onsubmit="submitAssignment(event)">
            <div class="form-group"><label>Event Title *</label><input type="text" name="title" required></div>
            <div class="form-group"><label>Location *</label><input type="text" name="location" required></div>
            <div class="form-group"><label>Date *</label><input type="date" name="date" required></div>
            <div style="display:flex;gap:12px;">
                <div class="form-group" style="flex:1;"><label>Start Time *</label><input type="time" name="start_time" required></div>
                <div class="form-group" style="flex:1;"><label>End Time *</label><input type="time" name="end_time" required></div>
            </div>
            <div class="form-group"><label>Pay Rate ($) *</label><input type="number" name="pay_rate" step="0.01" required></div>
            <div class="form-group"><label>Dress Code</label><input type="text" name="dress_code" placeholder="Black Tie, Smart Casual..."></div>
            <div class="form-group"><label>Description / Instructions</label><textarea name="description" rows="3"></textarea></div>
            <div class="form-group"><label>Special Instructions</label><textarea name="special_instructions" rows="2" placeholder="VIP styling details, specific requirements..."></textarea></div>
            <div class="form-group" style="background:#fef3c7;padding:12px;border-radius:8px;">
                <label style="display:flex;align-items:center;gap:8px;margin:0;cursor:pointer;color:#92400e;">
                    <input type="checkbox" name="vip_flag" style="width:auto;transform:scale(1.2);"> Mark as VIP Event
                </label>
            </div>
            <div class="form-group"><label>Assign To</label>
                <select name="assign_to_role">
                    <option value="">All Staff</option>
                    <option value="Staff">Regular Staff Only</option>
                    <option value="Supervisor">Supervisors Only</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary" style="margin-top:16px;">Push Assignment Live</button>
        </form>
    </div>
</div>

<!-- Modal: Edit Assignment -->
<div id="editAssignModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:100;overflow-y:auto;padding:20px 0;">
    <div style="background:white;max-width:500px;margin:0 auto;padding:24px;border-radius:12px;position:relative;">
        <button onclick="document.getElementById('editAssignModal').style.display='none'" style="position:absolute;right:16px;top:16px;background:none;border:none;font-size:1.5rem;cursor:pointer;">&times;</button>
        <h3 style="margin-bottom:16px;">Edit Assignment</h3>
        <form id="editAssignForm" onsubmit="submitEditAssignment(event)">
            <input type="hidden" id="editAssignId">
            <div class="form-group"><label>Event Title</label><input type="text" id="editAssignTitle" required></div>
            <div class="form-group"><label>Location</label><input type="text" id="editAssignLocation" required></div>
            <div class="form-group"><label>Date</label><input type="date" id="editAssignDate" required></div>
            <div style="display:flex;gap:12px;">
                <div class="form-group" style="flex:1;"><label>Start</label><input type="time" id="editAssignStart" required></div>
                <div class="form-group" style="flex:1;"><label>End</label><input type="time" id="editAssignEnd" required></div>
            </div>
            <div class="form-group"><label>Pay Rate ($)</label><input type="number" id="editAssignPay" step="0.01" required></div>
            <div class="form-group"><label>Dress Code</label><input type="text" id="editAssignDress" placeholder="Black Tie, Smart Casual..."></div>
            <div class="form-group"><label>Special Instructions</label><textarea id="editAssignInstructions" rows="2"></textarea></div>
            <div class="form-group" style="background:#fef3c7;padding:12px;border-radius:8px;">
