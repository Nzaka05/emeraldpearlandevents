<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; margin: 0; padding: 0; -webkit-font-smoothing: antialiased; background-color: #f3f4f6; }
        table { border-collapse: separate; mso-table-lspace: 0pt; mso-table-rspace: 0pt; width: 100%; }
        .wrapper { padding: 20px; box-sizing: border-box; }
        .main { background: #ffffff; border-radius: 8px; width: 100%; max-width: 600px; margin: 0 auto; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); }
        .header { background-color: #00c896; border-radius: 8px 8px 0 0; padding: 30px 20px; text-align: center; }
        .header h1 { color: #ffffff; margin: 0; font-size: 24px; font-weight: 600; }
        .content { padding: 30px 20px; }
        .footer { text-align: center; padding: 20px; color: #9ca3af; font-size: 13px; }
        .footer a { color: #00c896; text-decoration: none; }
        .btn { display: inline-block; padding: 12px 24px; background-color: #00c896; color: #ffffff !important; text-decoration: none; border-radius: 6px; font-weight: 500; font-size: 15px; margin-top: 15px; }
        p { color: #374151; line-height: 1.6; font-size: 15px; margin-bottom: 15px; }
    </style>
</head>
<body>
    <table role="presentation" border="0" cellpadding="0" cellspacing="0" class="body">
        <tr>
            <td class="wrapper">
                <table role="presentation" class="main">
                    <tr>
                        <td class="header">
                            <h1>Emerald Pearland Events</h1>
                        </td>
                    </tr>
                    <tr>
                        <td class="content">
                            <%- body %>
                        </td>
                    </tr>
                </table>
                <div class="footer">
                    <p>Emerald Pearland Events</p>
                    <p><a href="https://emeraldpearlandevents.netlify.app">Visit our website</a> | <a href="<%= process.env.CLIENT_PORTAL_URL %>/client/login">Client Portal</a></p>
                </div>
            </td>
        </tr>
    </table>
</body>
</html>
