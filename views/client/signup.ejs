<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account | Emerald Pearland Events</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --forest:   #0d2318;
            --deep:     #081510;
            --gold:     #c9a84c;
            --gold-lt:  #e2c47a;
            --gold-dim: rgba(201,168,76,0.18);
            --cream:    #f5f0e8;
            --mist:     rgba(245,240,232,0.55);
            --error:    #e07070;
        }

        html, body {
            height: 100%;
            background: var(--deep);
            color: var(--cream);
            font-family: 'Jost', sans-serif;
            font-weight: 300;
            overflow-x: hidden;
        }

        /* ── CINEMATIC BACKGROUND ── */
        .bg {
            position: fixed; inset: 0; z-index: 0;
            background:
                radial-gradient(ellipse 80% 60% at 70% 40%, rgba(13,35,24,0.95) 0%, transparent 70%),
                radial-gradient(ellipse 60% 80% at 20% 80%, rgba(201,168,76,0.06) 0%, transparent 60%),
                linear-gradient(160deg, #0a1c12 0%, #061009 50%, #020806 100%);
        }

        .bg::before {
            content: '';
            position: absolute; inset: 0;
            background-image:
                repeating-linear-gradient(0deg, transparent, transparent 80px, rgba(201,168,76,0.015) 80px, rgba(201,168,76,0.015) 81px),
                repeating-linear-gradient(90deg, transparent, transparent 80px, rgba(201,168,76,0.015) 80px, rgba(201,168,76,0.015) 81px);
        }

        /* ── LAYOUT ── */
        .stage {
            position: relative; z-index: 1;
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 520px 1fr;
            grid-template-rows: 1fr auto 1fr;
            align-items: center;
            padding: 40px 0;
        }

        /* ── CARD ── */
        .card {
            grid-column: 2;
            grid-row: 2;
            background: rgba(13,35,24,0.6);
            border: 1px solid rgba(201,168,76,0.2);
            border-radius: 2px;
            padding: 48px 48px 40px;
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            box-shadow:
                0 40px 80px rgba(0,0,0,0.6),
                inset 0 1px 0 rgba(201,168,76,0.12);
            animation: rise 0.9s cubic-bezier(0.16,1,0.3,1) both;
        }

        @keyframes rise {
            from { opacity: 0; transform: translateY(28px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .brand {
            text-align: center;
            margin-bottom: 32px;
        }
        .brand-name {
            font-family: 'Cormorant Garamond', serif;
            font-size: 24px;
            font-weight: 300;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--cream);
        }
        .brand-sub {
            font-size: 9px;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: var(--gold);
            margin-top: 6px;
        }

        /* ── FORM ── */
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 24px;
        }
        .form-group {
            display: flex;
            flex-direction: column;
        }
        .form-group.full { grid-column: span 2; }

        label {
            display: block;
            font-size: 9px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 8px;
            opacity: 0.8;
        }

        input {
            width: 100%;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(201,168,76,0.2);
            border-radius: 2px;
            padding: 12px 16px;
            color: var(--cream);
            font-family: 'Jost', sans-serif;
            font-size: 14px;
            font-weight: 300;
            outline: none;
            transition: all 0.3s;
        }
        input:focus {
            border-color: rgba(201,168,76,0.55);
            background: rgba(201,168,76,0.06);
        }

        .submit-btn {
            width: 100%;
            padding: 14px;
            background: transparent;
            border: 1px solid var(--gold);
            color: var(--gold);
            font-size: 10px;
            letter-spacing: 3px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.4s;
            margin-top: 12px;
        }
        .submit-btn:hover {
            background: var(--gold);
            color: var(--deep);
            box-shadow: 0 0 30px rgba(201,168,76,0.2);
        }
        .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }

        .error-box {
            display: none;
            margin-bottom: 20px;
            padding: 10px 14px;
            border: 1px solid rgba(224,112,112,0.3);
            background: rgba(224,112,112,0.05);
            color: var(--error);
            font-size: 12px;
            text-align: center;
        }
        .error-box.visible { display: block; }

        .footer-links {
            margin-top: 28px;
            text-align: center;
            font-size: 10px;
            letter-spacing: 1px;
            color: rgba(245,240,232,0.4);
        }
        .footer-links a {
            color: var(--gold);
            text-decoration: none;
            margin-left: 4px;
        }

        @media (max-width: 600px) {
            .stage { grid-template-columns: 20px 1fr 20px; }
            .card { padding: 36px 24px; }
            .form-grid { grid-template-columns: 1fr; }
            .form-group.full { grid-column: span 1; }
        }
    </style>
</head>
<body>
    <div class="bg"></div>

    <div class="stage">
        <div class="card">
            <div class="brand">
                <div class="brand-name">Emerald Pearland</div>
                <div class="brand-sub">Client Account Registration</div>
            </div>

            <div class="error-box" id="error-alert"></div>

            <form id="signup-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                
                <div class="form-grid">
                    <div class="form-group full">
                        <label>Full Name</label>
                        <input type="text" id="name" required placeholder="John Doe">
                    </div>
                    
                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" id="email" required placeholder="john@example.com">
                    </div>
                    
                    <div class="form-group">
                        <label>Phone Number (Required)</label>
                        <input type="tel" id="phone" required placeholder="+1 234 567 890">
                    </div>
                    
                    <div class="form-group full">
                        <label>Password</label>
                        <input type="password" id="password" required placeholder="Min. 8 characters with upper, number, symbol">
                    </div>
                </div>

                <button type="submit" class="submit-btn" id="submit-btn">Create Secure Account</button>
            </form>

            <div class="footer-links">
                Already have an account? <a href="/client/login">Sign In</a>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('signup-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('submit-btn');
            const errBox = document.getElementById('error-alert');
            
            btn.disabled = true;
            btn.textContent = 'Creating Account...';
            errBox.classList.remove('visible');

            const payload = {
                name: document.getElementById('name').value,
                email: document.getElementById('email').value,
                phone: document.getElementById('phone').value,
                password: document.getElementById('password').value
            };

            try {
                const res = await fetch('/client/api/signup', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();

                if (res.ok && data.success) {
                    if (data.data.refreshToken) {
                        localStorage.setItem('portal_refresh_token', data.data.refreshToken);
                    }
                    window.location.href = '/client/dashboard';
                } else {
                    btn.disabled = false;
                    btn.textContent = 'Create Secure Account';
                    errBox.textContent = data.data?.message || data.error || 'Registration failed';
                    errBox.classList.add('visible');
                }
            } catch (err) {
                btn.disabled = false;
                btn.textContent = 'Create Secure Account';
                errBox.textContent = 'Network error. Please try again.';
                errBox.classList.add('visible');
            }
        });
    </script>
</body>
</html>
