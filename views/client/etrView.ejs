<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Electronic Tax Receipt | Emerald Pearland Events</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { theme: { extend: { colors: { emerald: { 500: '#00c896', 600: '#00a87e' }, blue: { 600: '#2563eb' } } } } }
    </script>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen font-sans">
    
    <nav class="bg-white shadow-sm border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center h-16">
            <a href="/client/dashboard" class="text-sm font-medium text-emerald-600 hover:text-emerald-700">&larr; Back to Dashboard</a>
        </div>
    </nav>

    <main class="flex-grow max-w-3xl mx-auto px-4 py-8 w-full">
        <div class="bg-white shadow-lg rounded-xl border border-gray-200 overflow-hidden">
            <div class="h-2 bg-emerald-500"></div>
            <div class="p-8 md:p-12">
                <div class="flex justify-between items-start mb-10">
                    <div>
                        <h1 class="text-3xl font-bold text-gray-900">Event Report</h1>
                        <p class="text-sm text-gray-500 mt-1 uppercase tracking-widest font-semibold">Emerald Pearland Events</p>
                    </div>
                    <div class="text-right">
                        <p class="text-sm font-bold text-gray-900">ETR #<span id="etr-number">...</span></p>
                        <p class="text-sm text-gray-500">Issued: <span id="etr-date">...</span></p>
                    </div>
                </div>

                <div class="border-t border-b py-6 mb-8 grid grid-cols-2 gap-8">
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wider mb-2 font-semibold">Service Log</p>
                        <p class="text-sm text-gray-900 font-medium">Event Delivery Concluded Successfully.</p>
                        <p class="text-sm text-emerald-600 mt-2">✓ Verified via field supervisors</p>
                        <p class="text-sm text-emerald-600">✓ Financials reconciled</p>
                    </div>
                    <div class="text-right">
                        <p class="text-xs text-gray-500 uppercase tracking-wider mb-2 font-semibold">Summary Values</p>
                        <p class="text-sm text-gray-900">Final Cost Breakdown is available within the attached PDF file which acts as the official tax document.</p>
                    </div>
                </div>

                <div class="flex justify-center mt-12">
                    <a href="/client/etr/<%= eventId %>/download" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                        Download Official ETR PDF
                    </a>
                </div>
                <p class="text-xs text-center text-gray-400 mt-6">
                    This document validates the successful deployment of Emerald Resources. Electronic signatures preserved on file.
                </p>
            </div>
        </div>
    </main>
</body>
</html>
