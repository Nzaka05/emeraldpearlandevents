<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password | Emerald Pearland Events</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { theme: { extend: { colors: { emerald: { 500: '#00c896', 600: '#00a87e' } } } } }
    </script>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen font-sans">
    <div class="flex-grow flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
        <div class="max-w-md w-full space-y-8 bg-white p-8 rounded-xl shadow-lg">
            <div>
                <h2 class="mt-2 text-center text-3xl font-extrabold text-gray-900">
                    Reset Password
                </h2>
                <p class="mt-4 text-center text-sm text-gray-600">
                    Enter your email to receive a recovery link.
                </p>
            </div>
            
            <div id="status-alert" class="hidden rounded-md p-4 border">
                <div class="flex"><div class="ml-3"><h3 class="text-sm font-medium" id="status-message"></h3></div></div>
            </div>

            <form class="mt-8 space-y-6" id="reset-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div>
                    <label for="email" class="block text-sm font-medium text-gray-700">Email Address</label>
                    <input id="email" name="email" type="email" required class="appearance-none rounded-md relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-emerald-500 focus:border-emerald-500 sm:text-sm mt-1">
                </div>
                <div>
                    <button type="submit" id="submit-btn" class="w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-emerald-600 hover:bg-emerald-500 focus:outline-none">
                        Send Recovery Link
                    </button>
                </div>
            </form>
            <div class="text-center mt-4">
                <a href="/client/login" class="text-sm text-emerald-600 hover:text-emerald-500 font-medium">&larr; Back to Login</a>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('reset-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('submit-btn');
            const alertBox = document.getElementById('status-alert');
            const alertMsg = document.getElementById('status-message');
            
            btn.disabled = true;
            btn.innerHTML = 'Sending...';
            alertBox.classList.add('hidden');

            const email = document.getElementById('email').value;
            const _csrf = document.querySelector('input[name="_csrf"]').value;

            try {
                const res = await fetch('/client/api/password-reset/request', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, _csrf })
                });
                
                // We show success message regardless for security
                alertBox.className = 'rounded-md p-4 border border-green-200 bg-green-50';
                alertMsg.className = 'text-sm font-medium text-green-800';
                alertMsg.textContent = 'If the email exists, a password reset link has been sent.';
                alertBox.classList.remove('hidden');
                
            } catch (err) { }
            
            btn.innerHTML = 'Link Sent';
        });
    </script>
</body>
</html>
