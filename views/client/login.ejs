<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Client Portal | Emerald Pearland Events</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --forest:   #0d2318;
            --deep:     #081510;
            --gold:     #c9a84c;
            --gold-lt:  #e2c47a;
            --gold-dim: rgba(201,168,76,0.18);
            --cream:    #f5f0e8;
            --mist:     rgba(245,240,232,0.55);
            --error:    #e07070;
        }

        html, body {
            height: 100%;
            background: var(--deep);
            color: var(--cream);
            font-family: 'Jost', sans-serif;
            font-weight: 300;
            overflow: hidden;
        }

        /* ── CINEMATIC BACKGROUND ── */
        .bg {
            position: fixed; inset: 0; z-index: 0;
            background:
                radial-gradient(ellipse 80% 60% at 70% 40%, rgba(13,35,24,0.95) 0%, transparent 70%),
                radial-gradient(ellipse 60% 80% at 20% 80%, rgba(201,168,76,0.06) 0%, transparent 60%),
                linear-gradient(160deg, #0a1c12 0%, #061009 50%, #020806 100%);
        }

        .bg::before {
            content: '';
            position: absolute; inset: 0;
            background-image:
                repeating-linear-gradient(0deg, transparent, transparent 80px, rgba(201,168,76,0.015) 80px, rgba(201,168,76,0.015) 81px),
                repeating-linear-gradient(90deg, transparent, transparent 80px, rgba(201,168,76,0.015) 80px, rgba(201,168,76,0.015) 81px);
        }

        .bg::after {
            content: '';
            position: absolute; inset: 0;
            background: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
            opacity: 0.4;
            pointer-events: none;
        }

        /* ── GOLD ORB GLOW ── */
        .orb {
            position: fixed;
            border-radius: 50%;
            filter: blur(90px);
            pointer-events: none;
            z-index: 0;
        }
        .orb-1 {
            width: 500px; height: 500px;
            background: radial-gradient(circle, rgba(201,168,76,0.07) 0%, transparent 70%);
            top: -100px; right: -100px;
            animation: drift 18s ease-in-out infinite alternate;
        }
        .orb-2 {
            width: 350px; height: 350px;
            background: radial-gradient(circle, rgba(13,100,50,0.12) 0%, transparent 70%);
            bottom: -80px; left: -80px;
            animation: drift 22s ease-in-out infinite alternate-reverse;
        }
        @keyframes drift {
            from { transform: translate(0, 0); }
            to   { transform: translate(30px, 20px); }
        }

        /* ── LAYOUT ── */
        .stage {
            position: relative; z-index: 1;
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 480px 1fr;
            grid-template-rows: 1fr auto 1fr;
            align-items: center;
        }

        /* ── CARD ── */
        .card {
            grid-column: 2;
            grid-row: 2;
            background: rgba(13,35,24,0.6);
            border: 1px solid rgba(201,168,76,0.2);
            border-radius: 2px;
            padding: 52px 48px 44px;
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            box-shadow:
                0 0 0 1px rgba(201,168,76,0.06),
                0 40px 80px rgba(0,0,0,0.6),
                inset 0 1px 0 rgba(201,168,76,0.12);
            animation: rise 0.9s cubic-bezier(0.16,1,0.3,1) both;
        }

        @keyframes rise {
            from { opacity: 0; transform: translateY(28px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── HEADER ── */
        .monogram {
            width: 52px; height: 52px;
            border: 1px solid var(--gold);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 28px;
            font-family: 'Cormorant Garamond', serif;
            font-size: 22px;
            font-weight: 600;
            color: var(--gold);
            letter-spacing: 1px;
            animation: rise 0.9s 0.1s cubic-bezier(0.16,1,0.3,1) both;
            position: relative;
        }
        .monogram::before {
            content: '';
            position: absolute; inset: -4px;
            border-radius: 50%;
            border: 1px solid rgba(201,168,76,0.15);
        }

        .brand {
            text-align: center;
            margin-bottom: 36px;
            animation: rise 0.9s 0.15s cubic-bezier(0.16,1,0.3,1) both;
        }
        .brand-name {
            font-family: 'Cormorant Garamond', serif;
            font-size: 26px;
            font-weight: 300;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--cream);
            line-height: 1.2;
        }
        .brand-sub {
            font-size: 10px;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: var(--gold);
            margin-top: 8px;
            opacity: 0.85;
        }

        /* ── DIVIDER ── */
        .divider {
            display: flex; align-items: center; gap: 12px;
            margin-bottom: 32px;
            animation: rise 0.9s 0.2s cubic-bezier(0.16,1,0.3,1) both;
        }
        .divider::before, .divider::after {
            content: ''; flex: 1;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(201,168,76,0.3), transparent);
        }
        .divider-diamond {
            width: 5px; height: 5px;
            background: var(--gold);
            transform: rotate(45deg);
            opacity: 0.6;
        }

        /* ── FORM ── */
        .form-group {
            margin-bottom: 20px;
            animation: rise 0.9s 0.25s cubic-bezier(0.16,1,0.3,1) both;
        }
        .form-group + .form-group {
            animation-delay: 0.3s;
        }

        label {
            display: block;
            font-size: 10px;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 10px;
            opacity: 0.8;
        }

        .input-wrap { position: relative; }

        input[type="email"],
        input[type="password"],
        input[type="text"] {
            width: 100%;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(201,168,76,0.2);
            border-radius: 2px;
            padding: 14px 16px;
            color: var(--cream);
            font-family: 'Jost', sans-serif;
            font-size: 14px;
            font-weight: 300;
            letter-spacing: 0.5px;
            outline: none;
            transition: border-color 0.3s, background 0.3s, box-shadow 0.3s;
        }
        input::placeholder { color: rgba(245,240,232,0.2); }
        input:focus {
            border-color: rgba(201,168,76,0.55);
            background: rgba(201,168,76,0.04);
            box-shadow: 0 0 0 3px rgba(201,168,76,0.07);
        }
        input[type="password"],
        input[type="text"] { padding-right: 56px; }

        .toggle-pw {
            position: absolute; right: 0; top: 0; bottom: 0;
            width: 52px;
            background: none; border: none; cursor: pointer;
            color: rgba(201,168,76,0.4);
            font-family: 'Jost', sans-serif;
            font-size: 10px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            transition: color 0.2s;
        }
        .toggle-pw:hover { color: var(--gold); }

        /* ── FORGOT ── */
        .forgot-wrap {
            text-align: right;
            margin-bottom: 28px;
            animation: rise 0.9s 0.35s cubic-bezier(0.16,1,0.3,1) both;
        }
        .forgot-wrap a {
            font-size: 11px;
            letter-spacing: 1px;
            color: rgba(201,168,76,0.55);
            text-decoration: none;
            transition: color 0.2s;
        }
        .forgot-wrap a:hover { color: var(--gold-lt); }

        /* ── SUBMIT ── */
        .submit-btn {
            width: 100%;
            padding: 15px;
            background: transparent;
            border: 1px solid var(--gold);
            border-radius: 2px;
            color: var(--gold);
            font-family: 'Jost', sans-serif;
            font-size: 11px;
            font-weight: 400;
            letter-spacing: 3.5px;
            text-transform: uppercase;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: color 0.35s, box-shadow 0.35s;
            animation: rise 0.9s 0.4s cubic-bezier(0.16,1,0.3,1) both;
        }
        .submit-btn::before {
            content: '';
            position: absolute; inset: 0;
            background: var(--gold);
            transform: translateX(-101%);
            transition: transform 0.35s cubic-bezier(0.16,1,0.3,1);
            z-index: 0;
        }
        .submit-btn:hover::before { transform: translateX(0); }
        .submit-btn:hover { color: var(--deep); box-shadow: 0 0 28px rgba(201,168,76,0.25); }
        .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }
        .submit-btn span { position: relative; z-index: 1; }

        /* ── ERROR ── */
        .error-box {
            display: none;
            margin-bottom: 24px;
            padding: 12px 16px;
            border: 1px solid rgba(224,112,112,0.3);
            border-radius: 2px;
            background: rgba(224,112,112,0.07);
            font-size: 12px;
            color: var(--error);
            letter-spacing: 0.3px;
            animation: rise 0.4s cubic-bezier(0.16,1,0.3,1) both;
        }
        .error-box.visible { display: block; }

        /* ── FOOTER ── */
        .card-footer {
            margin-top: 32px;
            text-align: center;
            animation: rise 0.9s 0.45s cubic-bezier(0.16,1,0.3,1) both;
        }
        .card-footer a {
            font-size: 10px;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: rgba(245,240,232,0.25);
            text-decoration: none;
            transition: color 0.2s;
        }
        .card-footer a:hover { color: rgba(201,168,76,0.6); }

        /* ── CORNER MARKS ── */
        .corners {
            position: absolute; inset: -1px;
            pointer-events: none;
        }
        .corner {
            position: absolute;
            width: 12px; height: 12px;
            border-color: var(--gold);
            border-style: solid;
            opacity: 0.4;
        }
        .corner-tl { top: -1px; left: -1px; border-width: 1px 0 0 1px; }
        .corner-tr { top: -1px; right: -1px; border-width: 1px 1px 0 0; }
        .corner-bl { bottom: -1px; left: -1px; border-width: 0 0 1px 1px; }
        .corner-br { bottom: -1px; right: -1px; border-width: 0 1px 1px 0; }

        /* ── RESPONSIVE ── */
        @media (max-width: 560px) {
            .stage { grid-template-columns: 16px 1fr 16px; }
            .card { padding: 40px 28px 36px; }
        }
    </style>
</head>
<body>
    <div class="bg"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <div class="stage">
        <div class="card">
            <div class="corners">
                <div class="corner corner-tl"></div>
                <div class="corner corner-tr"></div>
                <div class="corner corner-bl"></div>
                <div class="corner corner-br"></div>
            </div>

            <div class="monogram">EP</div>

            <div class="brand">
                <div class="brand-name">Emerald Pearland</div>
                <div class="brand-sub">Premium Client Portal</div>
            </div>

            <div class="divider"><div class="divider-diamond"></div></div>

            <div class="error-box" id="error-alert">
                <span id="error-message"></span>
            </div>

            <form id="login-form" autocomplete="on">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <div class="form-group">
                    <label for="email">Email Address</label>
                    <div class="input-wrap">
                        <input id="email" name="email" type="email" autocomplete="email" required placeholder="client@company.com">
                    </div>
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <div class="input-wrap">
                        <input id="password" name="password" type="password" autocomplete="current-password" required placeholder="••••••••">
                        <button type="button" class="toggle-pw" id="toggle-password">Show</button>
                    </div>
                </div>

                <div class="forgot-wrap">
                    <a href="/client/password-reset/request">Forgot your password?</a>
                </div>

                <button type="submit" class="submit-btn" id="submit-btn">
                    <span>Sign In Securely</span>
                </button>
            </form>

            <div class="card-footer">
                <a href="https://emeraldpearlandevents.netlify.app">&larr; Return to Main Website</a>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('toggle-password').addEventListener('click', function() {
            const passInput = document.getElementById('password');
            if (passInput.type === 'password') {
                passInput.type = 'text';
                this.textContent = 'Hide';
            } else {
                passInput.type = 'password';
                this.textContent = 'Show';
            }
        });

        document.getElementById('login-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('submit-btn');
            const errAlert = document.getElementById('error-alert');
            const errMsg = document.getElementById('error-message');

            btn.disabled = true;
            btn.querySelector('span').textContent = 'Signing in…';
            errAlert.classList.remove('visible');

            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;

            try {
                const res = await fetch('/client/api/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password })
                });

                const data = await res.json();

                if (res.ok && data.success) {
                    localStorage.setItem('portal_refresh_token', data.data.refreshToken);
                    window.location.href = '/client/dashboard';
                } else {
                    btn.disabled = false;
                    btn.querySelector('span').textContent = 'Sign In Securely';
                    errMsg.textContent = data.data?.message || data.error?.message || data.error || 'Authentication failed';
                    errAlert.classList.add('visible');
                }
            } catch (err) {
                btn.disabled = false;
                btn.querySelector('span').textContent = 'Sign In Securely';
                errMsg.textContent = 'Network error. Please try again.';
                errAlert.classList.add('visible');
            }
        });
    </script>
</body>
</html>
