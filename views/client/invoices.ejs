<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoices | Emerald Pearland Events</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { theme: { extend: { colors: { emerald: { 500: '#00c896', 600: '#00a87e' }, amber: { 500: '#f59e0b' } } } } }
    </script>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen font-sans">
    
    <nav class="bg-white shadow-sm border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between h-16">
            <div class="flex items-center">
                <span class="text-xl font-bold text-gray-900 border-l-4 border-emerald-500 pl-3">Client Portal</span>
            </div>
            <div class="flex items-center space-x-6">
                <a href="/client/dashboard" class="text-gray-500 hover:text-gray-900">Dashboard</a>
                <a href="/client/invoices" class="text-gray-900 font-medium">Invoices</a>
                <a href="/client/sessions" class="text-gray-500 hover:text-gray-900">Security</a>
            </div>
        </div>
    </nav>

    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full">
        <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 mb-8 flex justify-between items-center">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Financial Overview</h1>
                <p class="text-sm text-gray-500 mt-1">Review your invoices and track payments</p>
            </div>
            <div class="text-right">
                <p class="text-sm font-medium text-gray-500 uppercase">Total Outstanding</p>
                <p class="text-3xl font-bold text-gray-900" id="total-outstanding">$0.00</p>
            </div>
        </div>

        <div class="bg-white shadow-sm rounded-lg border border-gray-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-emerald-600 uppercase tracking-wider">Invoice #</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-emerald-600 uppercase tracking-wider">Event Name</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-emerald-600 uppercase tracking-wider">Amount</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-emerald-600 uppercase tracking-wider">Paid</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-emerald-600 uppercase tracking-wider">Balance</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-emerald-600 uppercase tracking-wider">Status</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-emerald-600 uppercase tracking-wider">Action</th>
                        </tr>
                    </thead>
                    <tbody id="invoices-list" class="bg-white divide-y divide-gray-200">
                        <tr><td colspan="7" class="px-6 py-4 text-center text-sm text-gray-500">Loading invoices...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script>
        fetch('/client/api/invoices')
            .then(r => { if (!r.ok) throw new Error(); return r.json(); })
            .then(json => {
                const data = json.data;
                const tbody = document.getElementById('invoices-list');
                tbody.innerHTML = '';
                
                if (data.invoices.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="7" class="px-6 py-8 text-center text-sm text-gray-500">No invoices generated yet.</td></tr>';
                    return;
                }

                let totalBalance = 0;
                data.invoices.forEach(inv => {
                    const balance = inv.totalAmount - (inv.amountPaid || 0);
                    totalBalance += balance;
                    
                    const statusClass = balance > 0 ? 'bg-amber-100 text-amber-800' : 'bg-emerald-100 text-emerald-800';
                    const statusText = balance > 0 ? 'Open' : 'Paid';

                    tbody.innerHTML += `
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">${inv.invoiceNumber}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${inv.event_id ? 'Event associated' : 'General'}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">$${inv.totalAmount.toFixed(2)}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-emerald-600">$${(inv.amountPaid || 0).toFixed(2)}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm ${balance > 0 ? 'text-amber-600 font-bold' : 'text-gray-500'}">$${balance.toFixed(2)}</td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${statusClass}">${statusText}</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                <a href="/client/invoices/${inv._id}/download" class="text-blue-600 hover:text-blue-900 focus:outline-none">Get PDF</a>
                            </td>
                        </tr>
                    `;
                });
                
                const balEl = document.getElementById('total-outstanding');
                balEl.textContent = '$' + totalBalance.toFixed(2);
                if (totalBalance > 0) {
                    balEl.classList.remove('text-gray-900');
                    balEl.classList.add('text-amber-500');
                }
            })
            .catch(() => window.location.href = '/client/dashboard');
    </script>
</body>
</html>
