<!-- PWA Manifest & Dark Mode Base -->
<link rel="manifest" href="/admin/manifest.json">
<!-- WebAuthn Browser Client -->
<script src="https://unpkg.com/@simplewebauthn/browser/dist/bundle/index.umd.min.js"></script>
<style>
    /* Modern Glassmorphism & Dark Mode Aesthetic */
    :root {
        --cc-bg: #f8fafc;
        --cc-card: rgba(255, 255, 255, 0.85);
        --cc-text: #1e293b;
        --cc-text-muted: #64748b;
        --cc-border: rgba(226, 232, 240, 0.8);
        --cc-accent: #d4af37; /* Emerald Pearl Gold */
        --cc-primary: #0a2f1c; /* Emerald Pearl Green */
        --cc-success: #10b981;
        --cc-danger: #ef4444;
        --cc-warning: #f59e0b;
    }
    .dark-mode {
        --cc-bg: #0f172a;
        --cc-card: rgba(30, 41, 59, 0.75);
        --cc-text: #f8fafc;
        --cc-text-muted: #94a3b8;
        --cc-border: rgba(51, 65, 85, 0.8);
    }

    body.dark-mode {
        background-color: var(--cc-bg);
        color: var(--cc-text);
    }
    
    .cc-container {
        padding: 24px;
        background: var(--cc-bg);
        color: var(--cc-text);
        min-height: 100vh;
        transition: all 0.3s ease;
    }
    
    .glass-card {
        background: var(--cc-card);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--cc-border);
        border-radius: 16px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.05);
        padding: 20px;
        margin-bottom: 24px;
        color: var(--cc-text);
    }

    .metrics-bar {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
        margin-bottom: 24px;
    }

    .metric-item {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    
    .metric-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--cc-primary);
    }
    .dark-mode .metric-value { color: var(--cc-accent); }

    .main-grid {
        display: grid;
        grid-template-columns: 3fr 2fr;
        gap: 24px;
    }

    @media (max-width: 1024px) {
        .main-grid { grid-template-columns: 1fr; }
    }

    /* Event Grid array */
    .event-item {
        padding: 16px;
        border: 1px solid var(--cc-border);
        border-radius: 12px;
        margin-bottom: 12px;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .event-item:hover {
        border-color: var(--cc-accent);
        background: rgba(212, 175, 55, 0.05);
    }

    /* Detail Panel Tabs */
    .tab-nav {
        display: flex;
        gap: 16px;
        border-bottom: 1px solid var(--cc-border);
        margin-bottom: 16px;
    }
    .tab-btn {
        background: none;
        border: none;
        padding: 8px 16px;
        color: var(--cc-text-muted);
        cursor: pointer;
        font-weight: 600;
        border-bottom: 2px solid transparent;
    }
    .tab-btn.active {
        color: var(--cc-accent);
        border-bottom-color: var(--cc-accent);
    }
    
    .tab-content { display: none; }
    .tab-content.active { display: block; }
    
    /* Toggle Switch */
    .switch { position: relative; display: inline-block; width: 44px; height: 24px; }
    .switch input { opacity: 0; width: 0; height: 0; }
    .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #cbd5e1; transition: .4s; border-radius: 24px; }
    .slider:before { position: absolute; content: ""; height: 18px; width: 18px; left: 3px; bottom: 3px; background-color: white; transition: .4s; border-radius: 50%; }
    input:checked + .slider { background-color: var(--cc-accent); }
    input:checked + .slider:before { transform: translateX(20px); }

</style>

<div class="cc-container" id="cmdCenterBase">
    <!-- Top Bar -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div>
            <h1 style="margin: 0; font-size: 1.8rem;">Live Event Command Center</h1>
            <p style="color: var(--cc-text-muted); margin: 4px 0 0 0;">Real-time operational dashboard</p>
        </div>
        <div style="display: flex; align-items: center; gap: 12px;">
            <span style="font-weight: 600; font-size: 0.9rem;">Dark Mode</span>
            <label class="switch">
                <input type="checkbox" id="darkModeToggle" onchange="toggleDarkMode()">
                <span class="slider"></span>
            </label>
        </div>
    </div>

    <div class="glass-card metrics-bar">
        <div class="metric-item">
            <span style="color: var(--cc-text-muted); font-size: 0.85rem; text-transform: uppercase;">Live / Ready Events</span>
            <div class="metric-value"><span id="m-live"><%= liveMetrics.live_events %></span> / <span id="m-ready"><%= liveMetrics.ready_events %></span></div>
        </div>
        <div class="metric-item">
            <span style="color: var(--cc-text-muted); font-size: 0.85rem; text-transform: uppercase;">Active Staff Globally</span>
            <div class="metric-value"><span id="m-staff"><%= liveMetrics.active_staff %></span></div>
        </div>
        <div class="metric-item">
            <span style="color: var(--cc-text-muted); font-size: 0.85rem; text-transform: uppercase;">Emergency Funds (Today)</span>
            <div class="metric-value" style="color: var(--cc-danger);">KES <span id="m-funds"><%= liveMetrics.emergency_funds_today.toLocaleString() %></span></div>
        </div>
        <div class="metric-item">
            <span style="color: var(--cc-text-muted); font-size: 0.85rem; text-transform: uppercase;">Active Missing Alerts</span>
            <div class="metric-value" style="color: var(--cc-warning);"><span id="m-alerts"><%= liveMetrics.active_alerts %></span></div>
        </div>
    </div>

    <!-- Pending Approvals Panel (Hidden by default, populated via JS) -->
    <div id="pendingApprovalsPanel" style="display: none; margin-bottom: 24px;">
        <h3 style="margin-top: 0; color: var(--cc-warning);"><i class="fa-solid fa-hourglass-half"></i> Pending Dual Approvals</h3>
        <div id="pendingApprovalsContainer" style="display: flex; gap: 16px; overflow-x: auto; padding-bottom: 8px;"></div>
    </div>

    <!-- Main View -->
    <div class="main-grid">
        <!-- Left 60%: Event Grid -->
        <div class="glass-card">
            <h3 style="margin-top: 0; margin-bottom: 16px; font-size: 1.2rem;">Active Event Operations</h3>
            <div id="eventGrid">
                <% if(activeEvents && activeEvents.length > 0) { %>
                    <% activeEvents.forEach(function(e) { %>
                        <div class="event-item" onclick="loadEventDetail('<%= e.id %>')">
                            <div>
                                <div style="font-weight: 700; font-size: 1.1rem;"><%= e.title %></div>
                                <div style="font-size: 0.85rem; color: var(--cc-text-muted); margin-top: 4px;">
                                    <i class="fa-solid fa-location-dot"></i> <%= e.location %> &nbsp;&bull;&nbsp; 
                                    <span style="color: <%= e.state === 'LIVE' ? 'var(--cc-success)' : 'var(--cc-accent)' %>"><i class="fa-solid fa-circle" style="font-size: 0.5rem; vertical-align: middle;"></i> <%= e.state %></span>
                                </div>
                            </div>
                            <div style="text-align: right; font-size: 0.85rem;">
                                <div><i class="fa-solid fa-users"></i> Staff: <strong><%= e.clocked_in %> / <%= e.required_staff %></strong></div>
                                <div style="margin-top: 4px; color: <%= e.supervisor_assigned ? (e.geo_anchor_set ? 'var(--cc-success)' : 'var(--cc-warning)') : 'var(--cc-danger)' %>;">
                                    <i class="fa-solid fa-anchor"></i> <%= e.supervisor_assigned ? (e.geo_anchor_set ? 'Anchor Active' : 'No Anchor') : 'No Supervisor' %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p style="color: var(--cc-text-muted); padding: 20px; text-align: center;">No LIVE or READY events right now.</p>
                <% } %>
            </div>
        </div>

        <!-- Right 40%: Detail Panel -->
        <div class="glass-card" id="detailPanel" style="display: flex; flex-direction: column; min-height: 500px;">
            <div id="detailPlaceholder" style="margin: auto; text-align: center; color: var(--cc-text-muted);">
                <i class="fa-solid fa-satellite-dish" style="font-size: 3rem; opacity: 0.5; margin-bottom: 16px;"></i>
                <p>Select an event from the grid to view operational details.</p>
            </div>
            
            <div id="detailContent" style="display: none;">
                <h3 id="detTitle" style="margin-top: 0; margin-bottom: 4px;">Event Title</h3>
                <p id="detSubtitle" style="font-size: 0.85rem; color: var(--cc-text-muted); margin-bottom: 16px;"></p>
                
                <div class="tab-nav">
                    <button class="tab-btn active" onclick="switchTab('roster')"><i class="fa-solid fa-users"></i> Staff Roster</button>
                    <button class="tab-btn" onclick="switchTab('finance')"><i class="fa-solid fa-sack-dollar"></i> Finance</button>
                    <button class="tab-btn" onclick="switchTab('alerts')"><i class="fa-solid fa-triangle-exclamation"></i> Alerts</button>
                </div>

                <div id="tab-roster" class="tab-content active" style="font-size: 0.9rem;"></div>
                <div id="tab-finance" class="tab-content" style="font-size: 0.9rem;"></div>
                <div id="tab-alerts" class="tab-content" style="font-size: 0.9rem;"></div>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleDarkMode() {
        const isDark = document.getElementById('darkModeToggle').checked;
        if(isDark) {
            document.body.classList.add('dark-mode');
            localStorage.setItem('commandCenterTheme', 'dark');
        } else {
            document.body.classList.remove('dark-mode');
            localStorage.setItem('commandCenterTheme', 'light');
        }
    }

    // Init Theme
    if (localStorage.getItem('commandCenterTheme') === 'dark') {
        document.getElementById('darkModeToggle').checked = true;
        document.body.classList.add('dark-mode');
    }

    function switchTab(tabId) {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        
        event.currentTarget.classList.add('active');
        document.getElementById('tab-' + tabId).classList.add('active');
    }

    async function loadEventDetail(eventId) {
        document.getElementById('detailPlaceholder').style.display = 'none';
        document.getElementById('detailContent').style.display = 'block';
        document.getElementById('detTitle').innerText = "Loading...";
        document.getElementById('detSubtitle').innerText = "";
        
        try {
            const res = await fetch(`/admin/command-center/api/events/${eventId}`);
            const json = await res.json();
            if (!json.success) throw new Error(json.error);
            const d = json.data;

            document.getElementById('detTitle').innerText = d.event.title;
            document.getElementById('detSubtitle').innerText = `${d.event.state} | ${d.event.location} | ${d.staffRoster.length} Assigned`;

            // Roster HTML
            let rosterHtml = `<ul style="list-style:none; padding:0; margin:0;">`;
            d.staffRoster.forEach(s => {
                let badgeColor = s.status === 'Clocked In' ? 'var(--cc-success)' : (s.status === 'Missing' ? 'var(--cc-danger)' : 'var(--cc-text-muted)');
                rosterHtml += `
                    <li style="padding: 12px 0; border-bottom: 1px solid var(--cc-border); display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <strong>${s.name}</strong> <span style="font-size:0.75rem; color: var(--cc-text-muted);">(${s.role})</span><br>
                            <span style="font-size: 0.8rem; color: ${badgeColor}; font-weight: 600;">${s.status}</span>
                        </div>
                        <div style="font-size: 0.8rem; color: var(--cc-text-muted);">
                            ${s.clockInTime ? new Date(s.clockInTime).toLocaleTimeString() : (s.minutesLate > 0 ? `${s.minutesLate}m late` : '--')}
                        </div>
                    </li>
                `;
            });
            rosterHtml += `</ul>`;
            document.getElementById('tab-roster').innerHTML = rosterHtml;

            // Finance HTML
            let finHtml = `<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 12px;">
                <h4 style="margin:0;">Emergency Funds</h4>
                <button onclick="openEmergencyFundModal('${eventId}')" style="background:var(--cc-danger); color:white; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-weight:bold;"><i class="fa-solid fa-bolt"></i> Request Funds</button>
            </div><ul style="list-style:none; padding:0; margin:0 0 16px 0;">`;
            if (d.financials.emergencies.length === 0) finHtml += `<li style="color:var(--cc-text-muted);">No emergency payouts</li>`;
            d.financials.emergencies.forEach(em => {
                finHtml += `<li style="padding: 8px 0; border-bottom: 1px dashed var(--cc-border);">
                    <div style="display:flex; justify-content:space-between;">
                        <span style="color: var(--cc-danger); font-weight: 700;">KES ${em.amount.toLocaleString()}</span>
                        <span style="font-size:0.8rem;">${new Date(em.timestamp).toLocaleTimeString()}</span>
                    </div>
                    <div style="font-size:0.8rem; color:var(--cc-text-muted);">${em.reason}</div>
                </li>`;
            });
            finHtml += `</ul><h4 style="margin:0 0 8px 0;">Operational Expenses</h4><ul style="list-style:none; padding:0; margin:0;">`;
            if (d.financials.expenses.length === 0) finHtml += `<li style="color:var(--cc-text-muted);">No expenses logged</li>`;
            d.financials.expenses.forEach(ex => {
                finHtml += `<li style="padding: 8px 0; border-bottom: 1px dashed var(--cc-border);">
                    <div style="display:flex; justify-content:space-between;">
                        <span style="font-weight: 700;">KES ${ex.amount.toLocaleString()}</span>
                        <span style="font-size:0.8rem;">${new Date(ex.date).toLocaleTimeString()}</span>
                    </div>
                    <div style="font-size:0.8rem; color:var(--cc-text-muted);">${ex.description}</div>
                </li>`;
            });
            finHtml += `</ul>`;
            document.getElementById('tab-finance').innerHTML = finHtml;

            // Alerts HTML
            let alertHtml = `<ul style="list-style:none; padding:0; margin:0;">`;
            if (d.alerts.length === 0) alertHtml += `<li style="color:var(--cc-text-muted);">No active operational alerts</li>`;
            d.alerts.forEach(a => {
                alertHtml += `<li style="padding: 12px; border: 1px solid var(--cc-warning); border-radius: 8px; margin-bottom: 8px; background: rgba(245, 158, 11, 0.05);">
                    <div style="color: var(--cc-warning); font-weight: bold; margin-bottom: 4px;"><i class="fa-solid fa-triangle-exclamation"></i> Missing Staff Alert</div>
                    <div style="font-size: 0.85rem;"><strong>${a.staff_name}</strong> is currently ${a.minutes_late} minutes late context relative to event start time.</div>
                </li>`;
            });
            alertHtml += `</ul>`;
            document.getElementById('tab-alerts').innerHTML = alertHtml;

        } catch (e) {
            document.getElementById('detTitle').innerText = "Failed to load event data";
            console.error(e);
        }
    }

    // Modal logic for Emergency Funds
    function openEmergencyFundModal(eventId) {
        if (!document.getElementById('emfModal')) {
            const m = document.createElement('div');
            m.id = 'emfModal';
            m.style = 'position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); display:flex; justify-content:center; align-items:center; z-index:999;';
            m.innerHTML = `
                <div class="glass-card" style="width: 400px; padding:24px;">
                    <h3 style="margin-top:0; color:var(--cc-danger);">Request Emergency Funds</h3>
                    <input type="hidden" id="emfEventId" value="">
                    
                    <label style="display:block; margin-bottom:4px; font-size:0.85rem;">Amount (KES)</label>
                    <input type="number" id="emfAmount" class="form-input" style="width:100%; padding:10px; margin-bottom:16px; border-radius:6px; border:1px solid var(--cc-border); background:transparent; color:var(--cc-text);" required>
                    
                    <label style="display:block; margin-bottom:4px; font-size:0.85rem;">Target M-Pesa Phone</label>
                    <input type="text" id="emfPhone" class="form-input" style="width:100%; padding:10px; margin-bottom:16px; border-radius:6px; border:1px solid var(--cc-border); background:transparent; color:var(--cc-text);" required>
                    
                    <label style="display:block; margin-bottom:4px; font-size:0.85rem;">Reason / Justification</label>
                    <textarea id="emfReason" style="width:100%; padding:10px; margin-bottom:16px; border-radius:6px; border:1px solid var(--cc-border); background:transparent; color:var(--cc-text);"></textarea>
                    
                    <div id="emfOtpContainer" style="display:none;">
                        <label style="display:block; margin-bottom:4px; font-size:0.85rem; color:var(--cc-warning);">High Amount - OTP Required</label>
                        <input type="text" id="emfOtpCode" placeholder="Enter 6-digit OTP from Email" style="width:100%; padding:10px; margin-bottom:16px; border-radius:6px; border:1px solid var(--cc-accent); background:transparent; color:var(--cc-text);">
                    </div>

                    <div style="display:flex; justify-content:flex-end; gap:8px;">
                        <button onclick="document.getElementById('emfModal').style.display='none'" style="padding:8px 16px; border:none; border-radius:6px; background:var(--cc-border); color:var(--cc-text); cursor:pointer;">Cancel</button>
                        <button onclick="executeWebAuthnAndSubmitFunds()" style="padding:8px 16px; border:none; border-radius:6px; background:var(--cc-danger); color:white; font-weight:bold; cursor:pointer;" id="emfSubmitBtn"><i class="fa-solid fa-fingerprint"></i> Authenticate & Submit</button>
                    </div>
                </div>
            `;
            document.body.appendChild(m);
        }
        document.getElementById('emfEventId').value = eventId;
        document.getElementById('emfModal').style.display = 'flex';
        document.getElementById('emfAmount').value = '';
        document.getElementById('emfPhone').value = '';
        document.getElementById('emfReason').value = '';
        document.getElementById('emfOtpCode').value = '';
        document.getElementById('emfOtpContainer').style.display = 'none';
        
        // Listen to amount changes to show OTP dynamically if above threshold (e.g. 10000)
        document.getElementById('emfAmount').addEventListener('input', async (e) => {
            if (parseInt(e.target.value) > 10000) {
                document.getElementById('emfOtpContainer').style.display = 'block';
                // Fire OTP request if it hasn't been fired yet
                if (!window._otpRequested) {
                    window._otpRequested = true;
                    await fetch('/portal/admin-staff/emergency-funds/request-otp', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({ event_id: eventId, device_id: 'webauthn' })
                    });
                    alert('Amount exceeds threshold. An OTP has been dispatched to your registered email.');
                }
            } else {
                document.getElementById('emfOtpContainer').style.display = 'none';
            }
        });
    }

    async function executeWebAuthnAndSubmitFunds() {
        const eventId = document.getElementById('emfEventId').value;
        const amount = document.getElementById('emfAmount').value;
        const phone = document.getElementById('emfPhone').value;
        const reason = document.getElementById('emfReason').value;
        const otpCode = document.getElementById('emfOtpCode').value;
        const btn = document.getElementById('emfSubmitBtn');

        if (!amount || !phone) return alert('Amount and Phone are required.');

        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Verifying...';

        try {
            // 1. Get Authentication Options
            const optRes = await fetch('/portal/admin-staff/webauthn/authenticate/options', { method: 'POST' });
            const optData = await optRes.json();
            if (!optData.success) throw new Error(optData.error || 'Failed to get WebAuthn options');

            // 2. Browser WebAuthn Prompt
            const { startAuthentication } = SimpleWebAuthnBrowser;
            let assertion;
            try {
                assertion = await startAuthentication(optData.options);
            } catch (err) {
                throw new Error('Biometric verification cancelled or failed.');
            }

            // 3. Verify Authentication
            const verRes = await fetch('/portal/admin-staff/webauthn/authenticate/verify', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ authenticationResponse: assertion })
            });
            const verData = await verRes.json();
            if (!verData.success) throw new Error(verData.error || 'Cryptographic verification failed');

            // 4. Submit Emergency Fund Request
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Submitting...';
            
            // Collect coordinates
            navigator.geolocation.getCurrentPosition(async (pos) => {
                const submitRes = await fetch('/portal/admin-staff/emergency-funds/send', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        event_id: eventId,
                        amount: parseInt(amount),
                        phone: phone,
                        reason: reason,
                        otpCode: otpCode,
                        adminLat: pos.coords.latitude,
                        adminLng: pos.coords.longitude,
                        deviceId: assertion.id
                    })
                });
                const submitData = await submitRes.json();
                if (submitData.success) {
                    alert(submitData.message || 'Action successful!');
                    document.getElementById('emfModal').style.display = 'none';
                    window.location.reload();
                } else {
                    alert('Error: ' + submitData.error);
                }
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-fingerprint"></i> Authenticate & Submit';
            }, (err) => {
                alert('GPS coordinates are logically required for emergency payouts. Please enable location.');
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-fingerprint"></i> Authenticate & Submit';
            });

        } catch (e) {
            alert(e.message);
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-fingerprint"></i> Authenticate & Submit';
        }
    }

    // Pending Approvals Polling
    async function loadPendingApprovals() {
        try {
            const res = await fetch('/portal/admin-staff/emergency-funds/pending-approvals');
            const data = await res.json();
            
            if (data.success && data.data.length > 0) {
                document.getElementById('pendingApprovalsPanel').style.display = 'block';
                let html = '';
                data.data.forEach(a => {
                    html += `
                        <div class="glass-card" style="min-width: 300px; border: 1px solid var(--cc-warning); margin-bottom: 0;">
                            <div style="font-size: 0.8rem; color: var(--cc-text-muted);">${a.event_name}</div>
                            <div style="font-size: 1.2rem; font-weight: 700; color: var(--cc-danger);">KES ${a.amount.toLocaleString()}</div>
                            <div style="font-size: 0.85rem; margin-top: 4px;">Requested by: <strong>${a.first_admin_name}</strong></div>
                            <div style="font-size: 0.8rem; margin-top: 4px; color: var(--cc-text-muted);">${a.reason}</div>
                            
                            <div style="display: flex; gap: 8px; margin-top: 12px;">
                                <button onclick="handleDualApproval('${a.audit_id}', true)" style="flex:1; background:var(--cc-success); color:white; border:none; padding:8px; border-radius:6px; cursor:pointer;"><i class="fa-solid fa-check"></i> Approve</button>
                                <button onclick="handleDualApproval('${a.audit_id}', false)" style="flex:1; background:var(--cc-danger); color:white; border:none; padding:8px; border-radius:6px; cursor:pointer;"><i class="fa-solid fa-xmark"></i> Reject</button>
                            </div>
                        </div>
                    `;
                });
                document.getElementById('pendingApprovalsContainer').innerHTML = html;
            } else {
                document.getElementById('pendingApprovalsPanel').style.display = 'none';
            }
        } catch (e) {
            console.error('Failed to load pending approvals:', e);
        }
    }

    async function handleDualApproval(auditId, isApprove) {
        if (!isApprove) {
            const reason = prompt("Enter reason for rejection:");
            if (!reason) return;
            
            const res = await fetch('/portal/admin-staff/emergency-funds/reject', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ audit_id: auditId, reason })
            });
            const data = await res.json();
            if (data.success) {
                alert('Request rejected safely.');
                loadPendingApprovals();
            } else {
                alert(data.error);
            }
            return;
        }

        // WebAuthn for Approval
        try {
            // 1. Get Options
            const optRes = await fetch('/portal/admin-staff/webauthn/authenticate/options', { method: 'POST' });
            const optData = await optRes.json();
            if (!optData.success) throw new Error(optData.error);

            // 2. Browser WebAuthn
            const { startAuthentication } = SimpleWebAuthnBrowser;
            const assertion = await startAuthentication(optData.options);

            // 3. Verify Session
            const verRes = await fetch('/portal/admin-staff/webauthn/authenticate/verify', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ authenticationResponse: assertion })
            });
            const verData = await verRes.json();
            if (!verData.success) throw new Error(verData.error);

            // 4. Submit GPS and Approve
            navigator.geolocation.getCurrentPosition(async (pos) => {
                const subRes = await fetch('/portal/admin-staff/emergency-funds/approve', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ audit_id: auditId, lat: pos.coords.latitude, lng: pos.coords.longitude })
                });
                const subData = await subRes.json();
                if (subData.success) {
                    alert('Dual approval secure. Payout disbursed.');
                    loadPendingApprovals();
                } else {
                    alert('Error finalizing dual approval: ' + subData.error);
                }
            }, () => { alert("Failed to secure GPS. Approval halted."); });

        } catch (e) {
            alert('Security protocol failed: ' + e.message);
        }
    }

    // Init polling for approvals
    loadPendingApprovals();
    setInterval(loadPendingApprovals, 30000);

    // Connect to global Socket.io if available
    if (typeof io !== 'undefined') {
        // Assume socket connection was initialized in layout footer
        if (typeof socket !== 'undefined') {
            socket.on('cmd:staff_clocked_in', () => window.location.reload());
            socket.on('cmd:emergency_fund_approved', () => window.location.reload());
            socket.on('cmd:staff_missing_alert', () => window.location.reload());
            socket.on('cmd:expense_logged', () => window.location.reload());
            socket.on('emergencyFundSent', () => window.location.reload());
            socket.on('cmd:event_state_change', () => window.location.reload());
            
            // Dual Approval Sockets
            socket.on('cmd:dual_approval_required', () => {
                // Show notification and reload pending approvals
                alert('A pending dual authorization request has been dispatched!');
                loadPendingApprovals();
            });
            socket.on('cmd:dual_approval_approved', () => {
                loadPendingApprovals();
                window.location.reload();
            });
            socket.on('cmd:dual_approval_rejected', () => loadPendingApprovals());
            socket.on('cmd:dual_approval_expired', () => loadPendingApprovals());
        }
    }
</script>

<script>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', function() {
      navigator.serviceWorker.register('/admin/sw.js').then(function(registration) {
        console.log('Command Center ServiceWorker registration successful with scope: ', registration.scope);
      }, function(err) {
        console.log('ServiceWorker registration failed: ', err);
      });
    });
  }
</script>
